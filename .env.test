# define your env variables for the test env here
APP_ENV=test
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
APP_JWTSECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=999999
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots
DATABASE_URL="sqlite:///%kernel.project_dir%/var/test.db"
BREVO_LIST_ID=1
MAILER_DSN=null://null
MAILER_DSN_IMPORTANT=null://null

DEFAULT_FROM_EMAIL="no-reply@academie.lerocher.fr"
DEFAULT_FROM_NAME="Le Rocher Academie"
GEMINI_API_KEY=test

# Ports for isolated test environment
PUB_HTTP_PORT=9095
PUB_HTTPS_PORT=9096
PUB_MYSQL_PORT=4307
