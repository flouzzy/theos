{% extends "base.html.twig" %}
{% block body %}
    <div class="flex h-screen bg-background text-foreground overflow-hidden">
        <!-- Sidebar -->
        <aside class="hidden md:flex w-64 flex-col border-r bg-card">
            <div class="p-4 border-b h-16 flex items-center">
                <img src="{{ asset('images/logo.svg') }}" alt="Logo le rocher Academie" class="h-8 w-auto">
                <div class="ml-2 font-bold text-lg">
                    {% block toolBarTitle %}{% endblock %}
                </div>
            </div>
            
            <div class="flex-1 overflow-y-auto py-4 px-3 space-y-1">
                {% block menu %}
                    {% include "partials/_menu.html.twig" %}
                {% endblock %}
            </div>

             <div class="p-4 border-t">
                {% block menuFooter %}{% endblock %}
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <header class="h-16 flex items-center justify-between px-4 border-b bg-card">
                 <div class="flex items-center md:hidden">
                    {# Mobile menu button could go here #}
                    <button class="text-gray-500 focus:outline-none">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                         </svg>
                    </button>
                    <img src="{{ asset('images/logo.svg') }}" alt="Logo le rocher Academie" class="h-8 w-auto ml-2">
                 </div>

                <h1 class="text-xl font-semibold truncate flex-1 md:ml-0 ml-4">
                     {% block pageTitle %}
                        {{ block('title') }}
                    {% endblock %}
                </h1>

                <div class="flex items-center space-x-2">
                     {% block menuHeaderButtons %}
                        {% include "profile/_header_icon.html.twig" %}
                        {% include "notification/_notification_icon.html.twig" %}
                     {% endblock %}
                </div>
            </header>

            <!-- Main Scroll Area -->
            <main class="flex-1 overflow-x-hidden overflow-y-auto bg-muted/20 p-4 md:p-6">
                 {% include "partials/_flash.html.twig" %}
                {% include "partials/_warning.html.twig" %}
                
                <turbo-frame id="frame_app" data-turbo-action="advance">
                     {% block content %}{% endblock %}
                </turbo-frame>
            </main>
             <footer class="p-4 text-center text-sm text-muted-foreground border-t bg-card">
                 {{'now' | date('Y')}} &copy; Le Rocher Academie. {{'All rights reserved' | trans}}.
            </footer>
        </div>
    </div>
{% endblock %}
