{% extends 'landing.html.twig' %}

{% block title %}
	{{ 'Email envoyé' | trans }}
{% endblock %}

{% block content %}
    <div class="container mx-auto p-4 flex justify-center items-center min-h-[calc(100vh-100px)]">
        <div class="w-full max-w-md">
            {# Logo and Header #}
            <div class="text-center mb-8">
                <div class="inline-flex h-14 w-14 rounded-xl bg-primary items-center justify-center text-white font-bold text-2xl mb-4">
                    ✉️
                </div>
                <h1 class="text-3xl font-bold mb-2">{{ block('title') }}</h1>
                <p class="text-muted-foreground">{{ 'Vérifiez votre boîte de réception' | trans }}</p>
            </div>

            {# Main Card #}
            <div class="bg-white rounded-xl shadow-sm border border-border p-8 text-center text-muted-foreground">
                <p class="mb-4">
                    {{ 'Si un compte correspondant à votre adresse e-mail existe, un e-mail vient d\'être envoyé contenant un lien que vous pouvez utiliser pour réinitialiser votre mot de passe. Ce lien expirera dans' | trans }}
                    <span class="font-semibold text-foreground">{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</span>.
                </p>
                <p>
                    {{ 'Si vous ne recevez pas d\'e-mail, veuillez vérifier votre dossier de courriers indésirables ou' | trans }}
                    <a href="{{ path('forgot_password_request') }}" class="text-primary hover:underline font-semibold">{{ 'réessayer' | trans }}</a>.
                </p>
            </div>

            {# Back to Login Link #}
            <div class="text-center py-4">
                <a href="{{ path('login') }}" class="text-sm text-muted-foreground hover:text-foreground inline-flex items-center gap-1">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    {{ 'Retour à la connexion' | trans }}
                </a>
            </div>
        </div>
    </div>
{% endblock %}
