{% extends 'landing.html.twig' %}

{% block title %}
	{{ 'Reset your password' | trans }}
{% endblock %}

{% block content %}
    <div class="container mx-auto p-4 flex justify-center items-center min-h-[calc(100vh-100px)]">
        <div class="w-full max-w-md">
            {# Logo and Header #}
            <div class="text-center mb-8">
                <div class="inline-flex h-14 w-14 rounded-xl bg-primary items-center justify-center text-white font-bold text-2xl mb-4">
                    🔒
                </div>
                <h1 class="text-3xl font-bold mb-2">{{ block('title') }}</h1>
                <p class="text-muted-foreground">{{ 'Choose a new password' | trans }}</p>
            </div>

            {# Main Form Card #}
            <div class="bg-white rounded-xl shadow-sm border border-border p-8">
                {{ form_start(resetForm) }}
                    {# Password Field with Icon #}
                    <div class="mb-6">
                        <label for="{{ resetForm.plainPassword.vars.id }}" class="block text-sm font-medium mb-2">{{ form_label(resetForm.plainPassword) }}</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                </svg>
                            </div>
                            {{ form_widget(resetForm.plainPassword, {
                                'attr': {
                                    'class': 'w-full pl-10 pr-3 py-3 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary',
                                    'placeholder': '••••••••'
                                }
                            }) }}
                        </div>
                        <div class="mt-2 text-sm text-destructive">
                            {{ form_errors(resetForm.plainPassword) }}
                        </div>
                    </div>

                    {# Submit Button #}
                    <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-primary-foreground font-semibold py-3 rounded-lg transition-colors">
                        {{ 'Change password' | trans }}
                    </button>
                {{ form_end(resetForm) }}
            </div>
        </div>
    </div>
{% endblock %}
