{% extends 'landing.html.twig' %}

{% block title %}
	{{'Home' | trans}}
{% endblock %}

{% block content %}
	<div class="home ion-text-center">
		<h1 class="">
			{{'The school for builders of the kingdom of God' | trans}}
		</h1>
		<h2>
			{{'Equip yourself for the destiny God has for you' | trans}}
		</h2>
		<p class="ion-padding">
			<ion-button href="{{path('register')}}" color="app">{{'Enroll Now' | trans}}</ion-button>
		</p>
		<ion-grid>
			<ion-row class="ion-justify-content-center">
				<ion-col></ion-col>
				<ion-col size-sm="6" size="12">
					<ion-grid>
						<ion-row class="ion-justify-content-center">
							<ion-col size-sm="4" size="12">
								<img class="img-responsive border-radius" src="{{asset('images/landing-1.png')}}" alt="Image d'une étudiante sur son ordinateur">
							</ion-col>
							<ion-col size-sm="4" size="12">
								<img class="img-responsive border-radius ion-padding-top" src="{{asset('images/landing-2.png')}}" alt="Image d'un étudiant lisant la Bible">
							</ion-col>
							<ion-col size-sm="4" size="12">
								<img class="img-responsive border-radius" src="{{asset('images/landing-3.png')}}" alt="Image d'un étudiant diplomée">
							</ion-col>
						</ion-row>
					</ion-grid>
				</ion-col>
				<ion-col></ion-col>
			</ion-row>
		</ion-grid>
	</div>
{% endblock %}
