{% extends "app.html.twig" %}

{% block title %}🎯 {{ 'Dashboard' | trans }}{% endblock %}

{% block content %}
<div class="container mx-auto p-4 md:p-6 max-w-7xl">
    
    {# Welcome Header with Streak #}
    <div class="mb-8">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <h1 class="text-4xl md:text-5xl font-bold mb-2">
                    👋 {{ 'Welcome back' | trans }}, {{ app.user.firstname }}!
                </h1>
                <p class="text-lg text-muted-foreground">
                    {{ 'Keep the momentum going!' | trans }} 🚀
                </p>
            </div>
            
            {# Streak Counter #}
            <div class="bg-gradient-to-br from-primary/10 to-secondary/10 rounded-2xl p-6 border-2 border-primary/20 card-lift">
                <div class="flex items-center gap-3">
                    <div class="text-5xl streak-flame">🔥</div>
                    <div>
                        <div class="text-3xl font-black text-primary">7</div>
                        <div class="text-sm font-semibold text-muted-foreground uppercase tracking-wide">
                            {{ 'day streak' | trans }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Stats Cards Grid #}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
        
        {# Daily Goal Card #}
        <twig:Card class="card-lift border-2">
            <div class="p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-bold flex items-center gap-2">
                        🎯 {{ 'Daily Goal' | trans }}
                    </h3>
                    <span class="text-2xl font-black text-primary">3/5</span>
                </div>
                
                {# Progress Bar #}
                <div class="relative h-4 bg-muted rounded-full overflow-hidden">
                    <div class="progress-fill absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-secondary rounded-full" 
                         style="width: 60%"></div>
                </div>
                
                <p class="mt-3 text-sm text-muted-foreground">
                    {{ 'Complete 2 more lessons today!' | trans }} 💪
                </p>
            </div>
        </twig:Card>

        {# XP Card #}
        <twig:Card class="card-lift border-2 border-secondary/30">
            <div class="p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-bold flex items-center gap-2">
                        ⭐ {{ 'Total XP' | trans }}
                    </h3>
                    <span class="text-2xl font-black bg-gradient-to-r from-secondary to-accent bg-clip-text text-transparent">
                        1,250
                    </span>
                </div>
                
                {# Level Progress #}
                <div class="flex items-center gap-3">
                    <div class="flex-1">
                        <div class="relative h-3 bg-muted rounded-full overflow-hidden">
                            <div class="progress-fill absolute top-0 left-0 h-full bg-gradient-to-r from-secondary to-accent rounded-full" 
                                 style="width: 75%"></div>
                        </div>
                    </div>
                    <div class="text-sm font-bold text-muted-foreground">
                        {{ 'Lvl 12' | trans }}
                    </div>
                </div>
                
                <p class="mt-3 text-sm text-muted-foreground">
                    {{ '250 XP to Level 13' | trans }}
                </p>
            </div>
        </twig:Card>

        {# Weekly Activity #}
        <twig:Card class="card-lift border-2">
            <div class="p-6">
                <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
                    📊 {{ 'This Week' | trans }}
                </h3>
                
                <div class="grid grid-cols-7 gap-2 mb-3">
                    {% set weekProgress = [100, 80, 50, 100, 100, 100, 60] %}
                    {% for day in weekProgress %}
                        <div class="flex flex-col items-center gap-1">
                            <div class="w-full h-16 bg-muted rounded-lg overflow-hidden relative">
                                <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-primary to-primary/60 transition-all"
                                     style="height: {{ day }}%"></div>
                            </div>
                            <span class="text-xs text-muted-foreground">{{ ['M', 'T', 'W', 'T', 'F', 'S', 'S'][loop.index0] }}</span>
                        </div>
                    {% endfor %}
                </div>
                
                <p class="text-sm text-muted-foreground">
                    {{ '6 active days this week!' | trans }} 🎉
                </p>
            </div>
        </twig:Card>
    </div>

    {# Continue Learning Section #}
    <div class="mb-8">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            📚 {{ 'Continue Learning' | trans }}
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for i in 1..3 %}
                <twig:Card class="card-lift border-2 hover:border-primary/50 transition-all cursor-pointer">
                    <div class="p-6">
                        {# Course Icon with Progress Ring #}
                        <div class="relative w-20 h-20 mx-auto mb-4">
                            <svg class="w-20 h-20 transform -rotate-90">
                                <circle cx="40" cy="40" r="36" stroke="currentColor" 
                                        stroke-width="6" fill="none" class="text-muted" />
                                <circle cx="40" cy="40" r="36" stroke="currentColor" 
                                        stroke-width="6" fill="none" class="text-primary"
                                        stroke-dasharray="226" stroke-dashoffset="{{ 226 - (226 * (i * 25 / 100)) }}"
                                        stroke-linecap="round" />
                            </svg>
                            <div class="absolute inset-0 flex items-center justify-center text-3xl">
                                {{ ['📘', '📗', '📙'][i-1] }}
                            </div>
                        </div>
                        
                        <h3 class="text-lg font-bold text-center mb-2">
                            {{ 'Course ' ~ i | trans }}
                        </h3>
                        
                        <div class="flex items-center justify-center gap-2 mb-3">
                            <div class="flex-1 h-2 bg-muted rounded-full overflow-hidden">
                                <div class="h-full bg-gradient-to-r from-primary to-secondary rounded-full"
                                     style="width: {{ i * 25 }}%"></div>
                            </div>
                            <span class="text-sm font-bold text-primary">{{ i * 25 }}%</span>
                        </div>
                        
                        <button class="btn-playful w-full bg-primary text-primary-foreground font-bold py-3 rounded-xl hover:shadow-lg">
                            {{ 'Continue' | trans}} →
                        </button>
                    </div>
                </twig:Card>
            {% endfor %}
        </div>
    </div>

    {# Recent Achievements #}
    <div>
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            🏆 {{ 'Recent Achievements' | trans }}
        </h2>
        
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
            {% set badges = ['🥇', '🎖️', '⭐', '💎', '🔥', '🚀'] %}
            {% for badge in badges %}
                <div class="badge-unlock bg-gradient-to-br from-accent/20 to-secondary/20 rounded-2xl p-6 border-2 border-accent/30 text-center cursor-pointer hover:scale-105 transition-transform">
                    <div class="text-5xl mb-2">{{ badge }}</div>
                    <div class="text-xs font-bold text-muted-foreground">
                        {{ 'Achievement ' ~ loop.index }}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}
