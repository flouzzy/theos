<div class="mt-12 pt-8 border-t border-border">
    <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
        💬 {{ 'Discussions' | trans }} 
        <span class="text-sm font-normal text-muted-foreground">({{ currentLesson.comments|length }})</span>
    </h3>

    {# Comment Form #}
    {% if is_granted('IS_AUTHENTICATED') %}
        <div class="bg-muted/30 rounded-2xl p-4 mb-8">
            <form action="{{ path('lesson_add_comment', {id: currentLesson.id, courseSlug: course.slug, moduleSlug: module.slug}) }}" method="post" class="flex gap-4">
                <input type="hidden" name="_token" value="{{ csrf_token('add_comment') }}">
                <div class="flex-shrink-0">
                    <div class="w-10 h-10 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold shadow-sm">
                        {{ app.user.firstname|first }}{{ app.user.lastname|first }}
                    </div>
                </div>
                <div class="flex-1">
                    <textarea name="content" required placeholder="{{ 'Ajouter un commentaire...' | trans }}" 
                        class="w-full bg-white dark:bg-card border border-input rounded-xl px-4 py-3 min-h-[80px] focus:ring-2 focus:ring-primary/20 resize-y"></textarea>
                    <div class="flex justify-end mt-2">
                        <button type="submit" class="btn btn-primary rounded-xl px-6 py-2 text-sm font-bold">
                            {{ 'Publier' | trans }}
                        </button>
                    </div>
                </div>
            </form>
        </div>
    {% else %}
        <div class="bg-muted/50 rounded-xl p-4 text-center mb-8">
            <p class="text-muted-foreground">{{ 'Connectez-vous pour participer à la discussion.' | trans }}</p>
        </div>
    {% endif %}

    {# Comments List #}
    <div class="space-y-6">
        {% for comment in currentLesson.comments %}
            <div class="flex gap-4 group">
                {# Avatar #}
                <div class="flex-shrink-0">
                     <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-400 to-purple-500 text-white flex items-center justify-center font-bold shadow-sm">
                        {{ comment.user.firstname|first }}{{ comment.user.lastname|first }}
                    </div>
                </div>

                {# Content #}
                <div class="flex-1">
                    <div class="bg-card border border-border rounded-2xl rounded-tl-sm p-4 shadow-sm relative">
                        <div class="flex items-center justify-between mb-2">
                            <span class="font-bold text-sm">{{ comment.user.fullname }}</span>
                            <span class="text-xs text-muted-foreground">{{ comment.createdAt|date('d/m/Y H:i') }}</span>
                        </div>
                        <p class="text-foreground/90 leading-relaxed">{{ comment.content }}</p>
                    </div>
                    
                    {# Actions #}
                    <div class="flex items-center gap-4 mt-1 ml-2">
                        {# Like Button #}
                        <a href="{{ path('app_comment_like', {id: comment.id}) }}" class="flex items-center gap-1.5 text-xs font-semibold transition-colors {{ app.user and comment.likes.contains(app.user) ? 'text-red-500' : 'text-muted-foreground hover:text-red-500' }}">
                            <svg class="w-4 h-4 {{ app.user and comment.likes.contains(app.user) ? 'fill-current' : 'fill-none' }}" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                            </svg>
                            <span>{{ comment.likes|length }}</span>
                        </a>

                        <button class="flex items-center gap-1.5 text-xs font-semibold text-muted-foreground hover:text-primary transition-colors">
                            {{ 'Répondre' | trans }}
                        </button>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-center text-muted-foreground py-8">{{ 'Aucun commentaire pour le moment. Soyez le premier !' | trans }}</p>
        {% endfor %}
    </div>
</div>
