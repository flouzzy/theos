{% extends 'lesson/layout.html.twig' %}

{% block title %}
	{{module.title}}
{% endblock %}

	<turbo-frame id="frame_lesson" class="block space-y-6 max-w-4xl mx-auto p-4">
		<div class="text-center space-y-2">
			<h2 class="text-3xl font-bold tracking-tight">{{ currentLesson.title }}</h2>
		</div>

		<twig:Card class="p-6">
			<h3 class="font-semibold mb-2 text-lg">{{ 'Description'|trans }}</h3>
			<div class="text-muted-foreground">
				{{ currentLesson.description|raw }}
			</div>
		</twig:Card>

		<div class="space-y-6">
			{% if currentLesson.status == 'published' %}
				{% if currentLesson.videoEmbeded %}
					<div class="aspect-video w-full overflow-hidden rounded-lg border bg-muted">
						{{ currentLesson.videoEmbeded|raw }}
					</div>
				{% endif %}

				<div class="rounded-lg border bg-card text-card-foreground shadow-sm">
					<details class="group" {% if not currentLesson.videoEmbeded %}open{% endif %}>
						<summary class="flex cursor-pointer items-center justify-between p-6 font-medium transition-all hover:bg-muted/50 [&::-webkit-details-marker]:hidden">
							<span>{{ 'Text content'|trans }}</span>
							<twig:ux:icon name="lucide:chevron-down" class="h-4 w-4 transition-transform group-open:rotate-180" />
						</summary>
						<div class="border-t p-6 pt-0 mt-4">
							<div class="prose dark:prose-invert max-w-none">
								{{ currentLesson.content|raw }}
							</div>
						</div>
					</details>
				</div>

				<twig:Separator class="my-6" />

				{# User notes #}
				{% if is_granted('IS_AUTHENTICATED') %}
					<div class="space-y-4">
						{# Form #}
						{{ render(path('note_show_lesson', {id:currentLesson.id, courseSlug:course.slug, moduleSlug:module.slug})) }}
						{# List #}
						{{ render(path('note_index_lesson', {lessonId : currentLesson.id})) }}
					</div>
				{% endif %}
			{% else %}
				<div class="rounded-lg border border-destructive/50 p-4 text-destructive-foreground">
					<div class="flex items-center gap-3">
						<twig:ux:icon name="lucide:alert-circle" class="h-5 w-5" />
						<h3 class="font-semibold">
							{{ 'This lesson is currently unavailable'|trans }}
						</h3>
					</div>
				</div>
			{% endif %}
		</div>
	</turbo-frame>

{% block menuHeaderButtons %}
	<div class="flex items-center gap-2">
		{% if is_granted('ROLE_ADMIN') %}
			<twig:Button variant="ghost" size="icon" asChild>
				<a href="{{path('admin_lesson_edit', {id:currentLesson.id})}}" target="_blank">
					<twig:ux:icon name="lucide:pencil" class="h-4 w-4" />
				</a>
			</twig:Button>
		{% endif %}
		{% include "lesson/_complete.html.twig" %}
	</div>
{% endblock %}
