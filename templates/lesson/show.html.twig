{% extends 'lesson/layout.html.twig' %}

{% block title %}{{ currentLesson.title }}{% endblock %}

{% block content %}
<div class="flex h-[calc(100vh-64px)] overflow-hidden bg-background" x-data="{ showNotes: false }">
    
    {# 1. Left Sidebar (Syllabus) #}
    <aside class="w-80 flex-shrink-0 border-r border-border bg-muted/30 overflow-y-auto hidden lg:block">
        <div class="p-6">
            <h3 class="font-serif font-bold text-lg mb-1">{{ course.title }}</h3>
            <div class="w-full bg-muted rounded-full h-2 mb-4 overflow-hidden">
                <div class="bg-primary h-full rounded-full" style="width: 45%"></div> {# Mock progress #}
            </div>
        </div>

        <div class="space-y-1 px-3 pb-6">
            {% for mod in course.modules %}
                {% set isModuleCurrent = (currentLesson.module.id == mod.id) %}
                <div class="space-y-1" x-data="{ expanded: {{ isModuleCurrent ? 'true' : 'false' }} }">
                    <button @click="expanded = !expanded" class="w-full flex items-center justify-between px-3 py-2 font-bold text-sm text-foreground/80 uppercase tracking-wider hover:bg-muted/50 rounded-lg transition-colors">
                        <span>{{ mod.title }}</span>
                        <svg class="w-4 h-4 transition-transform duration-200" :class="expanded ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>
                    
                    <div x-show="expanded" x-collapse>
                        {% for less in mod.lessons %}
                            {% set isCurrent = (less.id == currentLesson.id) %}
                            {% set isCompleted = less.id in completedLessonIds %}
                            
                            <a href="{{ path('lesson_show', {courseSlug: course.slug, moduleSlug: mod.slug, lessonId: less.id}) }}" 
                               class="flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors {{ isCurrent ? 'bg-primary/10 text-primary font-medium' : 'text-muted-foreground hover:bg-muted hover:text-foreground' }}">
                                
                                <div class="flex-shrink-0">
                                    {% if isCompleted %}
                                        <div class="w-5 h-5 rounded-full bg-primary text-primary-foreground flex items-center justify-center">
                                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                            </svg>
                                        </div>
                                    {% elseif isCurrent %}
                                         <div class="w-5 h-5 rounded-full border-2 border-primary flex items-center justify-center">
                                             <div class="w-2 h-2 rounded-full bg-primary"></div>
                                         </div>
                                    {% else %}
                                        <div class="w-5 h-5 rounded-full border-2 border-muted-foreground/30"></div>
                                    {% endif %}
                                </div>
                                
                                <span class="line-clamp-1">{{ less.title }}</span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
                {% if not loop.last %}
                    <div class="my-2 border-t border-border/50 mx-3"></div>
                {% endif %}
            {% endfor %}
        </div>
    </aside>

    {# 2. Main Content (The Stage) #}
    <main class="flex-1 overflow-y-auto min-w-0 bg-background relative" 
          id="main-content"
          data-controller="swipe-navigation offline-lesson"
          data-swipe-navigation-next-url-value="{{ nextLesson ? path('lesson_show', {courseSlug: course.slug, moduleSlug: nextLesson.module.slug, lessonId: nextLesson.id}) : '' }}"
          data-swipe-navigation-prev-url-value="{{ prevLesson ? path('lesson_show', {courseSlug: course.slug, moduleSlug: prevLesson.module.slug, lessonId: prevLesson.id}) : '' }}"
          data-offline-lesson-lesson-id-value="{{ currentLesson.id }}"
          data-offline-lesson-title-value="{{ currentLesson.title }}"
          data-offline-lesson-content-value="{{ currentLesson.content|default('')|raw }}"
    >
        {# Offline Indicator #}
        <div data-offline-lesson-target="offlineStatus" class="hidden sticky top-0 z-50 bg-amber-500 text-white py-2 px-4 text-center text-sm font-bold shadow-md">
            {{ 'Mode Hors-ligne : Vous consultez une version enregistrée de cette leçon.' | trans }}
        </div>

        <div class="max-w-4xl mx-auto p-6 md:p-10 space-y-8">
            
            {# Breadcrumbs #}
            <nav class="flex items-center text-sm text-muted-foreground">
                <a href="{{ path('course_index') }}" class="hover:text-primary transition-colors">{{ 'Cours' | trans }}</a>
                <svg class="w-4 h-4 mx-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                <span class="truncate max-w-[150px]">{{ course.title }}</span>
                <svg class="w-4 h-4 mx-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                <span class="text-foreground font-medium truncate">{{ currentLesson.title }}</span>
            </nav>

            {# Video Container #}
            <div class="relative bg-black rounded-2xl overflow-hidden shadow-2xl ring-1 ring-border aspect-video group"
                 data-controller="offline-video video-shortcuts auto-play audio-mode"
                 data-offline-video-url-value="{{ currentLesson.videoUrl }}"
                 data-offline-video-lesson-id-value="{{ currentLesson.id }}"
                 data-auto-play-enabled-value="true"
            >
                <div data-offline-video-target="playerContainer" data-audio-mode-target="videoContainer" class="w-full h-full">
                    {% if currentLesson.videoEmbeded %}
                        {{ currentLesson.videoEmbeded|default('')|raw }}
                    {% else %}
                        <div class="absolute inset-0 flex items-center justify-center text-white/50 bg-slate-900">
                            <div class="text-center">
                                <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <p>{{ 'Aucune vidéo pour cette leçon' | trans }}</p>
                            </div>
                        </div>
                    {% endif %}
                </div>

                {# Video Player Actions #}
                <div class="absolute top-4 left-4 z-10 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <button type="button" data-action="click->video-shortcuts#togglePiP" class="inline-flex items-center justify-center rounded-md text-xs font-medium bg-black/50 text-white hover:bg-black/70 h-8 px-2" title="{{ 'Picture-in-Picture' | trans }} (P)">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h8a2 2 0 012 2v6a2 2 0 01-2 2H8a2 2 0 01-2-2V9a2 2 0 012-2z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 13h2v2h-2z" /></svg>
                    </button>
                    <button type="button" data-action="click->audio-mode#toggle" class="inline-flex items-center justify-center rounded-md text-xs font-medium bg-black/50 text-white hover:bg-black/70 h-8 px-2" title="{{ 'Audio-only mode' | trans }}">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" /></svg>
                    </button>
                </div>

                {# Offline Controls #}
                <div class="absolute top-4 right-4 z-10 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300" data-offline-video-target="actions">
                    <button type="button" data-offline-video-target="downloadBtn" data-action="click->offline-video#download" class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-secondary text-secondary-foreground hover:bg-secondary/80 h-9 px-3 hidden">
                        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                        {{ 'Download' | trans }}
                    </button>
                    <button type="button" data-offline-video-target="playBtn" data-action="click->offline-video#play" class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-3 hidden">
                         <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /></svg>
                        {{ 'Play Offline' | trans }}
                    </button>
                    <button type="button" data-offline-video-target="deleteBtn" data-action="click->offline-video#delete" class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-destructive text-destructive-foreground hover:bg-destructive/90 h-9 px-3 hidden" title="{{ 'Delete offline video' | trans }}">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    </button>
                    <div data-offline-video-target="progressBar" class="hidden text-white text-xs bg-black/50 px-2 py-1 rounded flex items-center">
                        <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        Downloading...
                    </div>
                </div>
            </div>

            <script>
                window.translations = window.translations || {};
                window.translations.saved_offline = "{{ 'Enregistré' | trans }}";
                window.translations.remove_offline_confirm = "{{ 'Supprimer de la consultation hors-ligne ?' | trans }}";
                window.translations.lesson_saved_success = "{{ 'Leçon enregistrée pour consultation hors-ligne.' | trans }}";
            </script>

            {# Lesson Title & Navigation #}
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 pb-6 border-b border-border">
                <div>
                    <h1 class="text-2xl md:text-3xl font-serif font-bold text-foreground">{{ currentLesson.title }}</h1>
                    <p class="text-muted-foreground mt-1">{{ module.title }}</p>
                </div>
                
                <div class="flex items-center gap-3">
                    <button type="button" 
                            data-offline-lesson-target="offlineBtn" 
                            data-action="click->offline-lesson#toggleOffline" 
                            class="inline-flex items-center justify-center rounded-lg border border-border bg-background px-4 py-2 text-sm font-medium hover:bg-muted transition-colors gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                        {{ 'Sauvegarder hors-ligne' | trans }}
                    </button>

                    {% if currentLesson.videoUrl %}
                    <div data-controller="offline-video" 
                         data-offline-video-lesson-id-value="{{ currentLesson.id }}"
                         data-offline-video-url-value="{{ currentLesson.videoUrl }}"
                         class="flex items-center gap-2">
                        
                        <button type="button" 
                                data-offline-video-target="downloadBtn"
                                data-action="click->offline-video#download"
                                class="inline-flex items-center justify-center rounded-lg border border-border bg-background px-4 py-2 text-sm font-medium hover:bg-muted transition-colors gap-2">
                            <twig:ux:icon name="lucide:video" class="w-4 h-4" />
                            {{ 'Vidéo hors-ligne' | trans }}
                        </button>

                        <div data-offline-video-target="progressBar" class="hidden h-9 w-32 bg-slate-100 rounded-lg overflow-hidden relative border border-slate-200">
                            <div class="h-full bg-primary animate-pulse w-full"></div>
                            <span class="absolute inset-0 flex items-center justify-center text-[10px] font-bold text-primary-foreground uppercase tracking-tighter">{{ 'Téléchargement...' | trans }}</span>
                        </div>

                        <button type="button" 
                                data-offline-video-target="playBtn"
                                data-action="click->offline-video#play"
                                class="hidden inline-flex items-center justify-center rounded-lg border border-green-200 bg-green-50 text-green-700 px-4 py-2 text-sm font-medium hover:bg-green-100 transition-colors gap-2">
                            <twig:ux:icon name="lucide:play-circle" class="w-4 h-4" />
                            {{ 'Lecture hors-ligne' | trans }}
                        </button>
                    </div>
                    {% endif %}

                    <button data-controller="distraction-free" data-action="click->distraction-free#toggle" class="p-2 hover:bg-muted rounded-full transition-colors text-muted-foreground hover:text-foreground hidden lg:flex" title="{{ 'Mode immersion' | trans }}">
                        <twig:ux:icon name="lucide:maximize-2" class="w-5 h-5" />
                    </button>

                    {# Previous Button #}
                    {% if prevLesson %}
                        <a href="{{ path('lesson_show', {courseSlug: course.slug, moduleSlug: prevLesson.module.slug, lessonId: prevLesson.id}) }}" class="btn btn-ghost">
                            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                            {{ 'Précédent' | trans }}
                        </a>
                    {% else %}
                        <button class="btn btn-ghost" disabled>
                            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                            {{ 'Précédent' | trans }}
                        </button>
                    {% endif %}
                    
                    {# Mark Complete / Next Action #}
                    {% include "lesson/_complete.html.twig" with {'nextButton': true} %}

                    {% if currentLesson.assignment %}
                         <a href="{{ path('assignment_show', {id: currentLesson.assignment.id}) }}" class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 transition-colors gap-2 ml-2">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                            </svg>
                            {{ 'Devoir' | trans }}
                        </a>
                    {% endif %}
                </div>
            </div>

            {# Tabs Content #}
            <div class="space-y-8" x-data="{ tab: 'overview' }">
                {# Tab Headers #}
                <div class="flex border-b border-border">
                    <button @click="tab = 'overview'" :class="tab === 'overview' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'" class="px-4 py-3 text-sm font-semibold border-b-2 transition-colors">
                        {{ 'Vue d\'ensemble' | trans }}
                    </button>
                    <button @click="tab = 'resources'" :class="tab === 'resources' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'" class="px-4 py-3 text-sm font-semibold border-b-2 transition-colors">
                        {{ 'Ressources' | trans }}
                    </button>
                    <button @click="tab = 'transcript'" :class="tab === 'transcript' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'" class="px-4 py-3 text-sm font-semibold border-b-2 transition-colors">
                        {{ 'Transcription' | trans }}
                    </button>
                    <button @click="tab = 'comments'" :class="tab === 'comments' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'" class="px-4 py-3 text-sm font-semibold border-b-2 transition-colors">
                        {{ 'Discussions' | trans }}
                    </button>
                </div>

            {# Tab Panels #}
                <div x-show="tab === 'overview'" class="space-y-8">
                    {% if currentLesson.audioPath %}
                        <div class="bg-indigo-50 dark:bg-indigo-950/30 border border-indigo-100 dark:border-indigo-900/50 rounded-2xl p-6 flex flex-col md:flex-row items-center gap-6 animate-in fade-in slide-in-from-top-4 duration-700">
                            <div class="flex-shrink-0 w-16 h-16 bg-indigo-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-indigo-200 dark:shadow-none">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
                                </svg>
                            </div>
                            <div class="flex-1 text-center md:text-left">
                                <h4 class="font-bold text-indigo-900 dark:text-indigo-100">Version Audio (IA)</h4>
                                <p class="text-sm text-indigo-700 dark:text-indigo-300/80 mb-4">Écoutez cette leçon lue par notre assistant pédagogique.</p>
                                <audio controls class="w-full h-10 rounded-lg" data-audio-mode-target="audioPlayer">
                                    <source src="{{ asset(currentLesson.audioPath) }}" type="audio/mpeg">
                                    Your browser does not support the audio element.
                                </audio>
                            </div>
                            {% if currentLesson.audioDuration %}
                                <div class="hidden md:block text-right">
                                    <span class="text-xs font-mono font-bold text-indigo-400 dark:text-indigo-500 uppercase tracking-widest">Durée</span>
                                    <div class="text-lg font-serif font-bold text-indigo-900 dark:text-indigo-100">{{ (currentLesson.audioDuration // 60) }}:{{ "%02d"|format(currentLesson.audioDuration % 60) }}</div>
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}

                    <div class="prose prose-slate dark:prose-invert max-w-none animate-in fade-in slide-in-from-bottom-2" 
                         data-controller="glossary recommendation-nudge easter-egg"
                         data-recommendation-nudge-url-value="{{ path('app_lesson_nudge', {id: currentLesson.id}) }}"
                         data-easter-egg-url-value="{{ path('lesson_claim_easter_egg', {courseSlug: course.slug, moduleSlug: module.slug}) }}"
                         data-easter-egg-token-value="{{ csrf_token('claim_egg') }}">
                        {{ currentLesson.content|default('')|raw }}
                    </div>

                    {# Recommendations Section #}
                    {{ component('Recommendation', { lesson: currentLesson, lazy: true }) }}

                </div>

                <div x-show="tab === 'resources'" style="display: none;" class="animate-in fade-in slide-in-from-bottom-2">
                     <div class="bg-card rounded-xl border border-border p-6 text-center">
                        <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-muted mb-4">
                            <svg class="h-6 w-6 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                            </svg>
                        </div>
                        <h3 class="text-lg font-bold">{{ 'Ressources attachées' | trans }}</h3>
                        <p class="text-muted-foreground text-sm">{{ 'Aucun fichier joint à cette leçon.' | trans }}</p>
                    </div>
                </div>

                <div x-show="tab === 'transcript'" style="display: none;" class="animate-in fade-in slide-in-from-bottom-2">
                    {{ component('Transcript', { lesson: currentLesson }) }}
                </div>

                <div x-show="tab === 'comments'"
 style="display: none;" class="animate-in fade-in slide-in-from-bottom-2">
                    {% include 'comment/_section.html.twig' %}
                </div>
            </div>

        </div>
    </main>

    {# Notes Sidebar (Right) #}
    <div 
        x-show="showNotes" 
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="translate-x-full"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="translate-x-full"
        class="fixed right-0 top-16 bottom-0 w-80 bg-background border-l border-border shadow-2xl z-40 flex flex-col"
        style="display: none;"
    >
        <div class="p-4 border-b border-border flex items-center justify-between bg-muted/20">
            <h2 class="font-bold text-lg flex items-center gap-2">
                <twig:ux:icon name="lucide:pencil-line" class="w-5 h-5 text-yellow-500" />
                {{ 'Notes de cours' | trans }}
            </h2>
            <button @click="showNotes = false" class="p-2 hover:bg-muted rounded-full transition-colors">
                <twig:ux:icon name="lucide:x" class="w-5 h-5" />
            </button>
        </div>
        <div class="flex-1 overflow-y-auto p-4">
            {{ component('NoteManager', { lessonId: currentLesson.id }) }}
        </div>
    </div>
</div>

{# Floating Actions #}
<div class="fixed bottom-6 right-24 z-50">
    <button @click="showNotes = !showNotes" class="h-14 w-14 rounded-full bg-yellow-500 text-white shadow-lg flex items-center justify-center hover:scale-110 transition-transform focus:outline-none focus:ring-4 focus:ring-yellow-500/30" title="{{ 'Mes Notes' | trans }}">
        <twig:ux:icon name="lucide:pencil-line" class="w-7 h-7" />
    </button>
</div>

{# Mobile Sidebar Toggle (Floating, bottom left or top left) #}
<div class="lg:hidden fixed bottom-6 left-6 z-50">
     <button class="h-12 w-12 rounded-full bg-background border border-border text-foreground shadow-lg flex items-center justify-center">
