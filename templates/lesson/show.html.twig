{% extends 'lesson/layout.html.twig' %}

{% block title %}
	{{currentLesson.title}}
	-
	{{module.title}}
{% endblock %}

{% block content %}
	<ion-card>
		<ion-card-content>
			<ion-text color="dark">
				{{currentLesson.description | raw}}
			</ion-text>
		</ion-card-content>
	</ion-card>
	<div class="ion-padding">

		<div>
			{{currentLesson.videoEmbeded | raw}}
		</div>
		<hr>
		<ion-text color="dark">
			{{currentLesson.content | raw}}
		</ion-text>


		{# User notes #}
		{% if app.user %}
			{{ render(path('note_show', {id:currentLesson.id, courseSlug:course.slug, moduleSlug:module.slug})) }}
		{% endif %}


	</div>
{% endblock %}

{% block menuHeaderButtons %}
	<ion-buttons slot="end">
		{% include "lesson/_complete.html.twig" %}
	</ion-buttons>
{% endblock %}
