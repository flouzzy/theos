{% if recommendation %}
<div class="fixed bottom-24 right-6 max-w-sm w-full bg-white rounded-2xl shadow-2xl border border-primary/10 overflow-hidden animate-in fade-in slide-in-from-bottom-10 duration-500 z-40" id="recommendation-nudge">
    <div class="p-1 bg-gradient-to-r from-primary to-indigo-600"></div>
    <div class="p-5">
        <div class="flex items-center justify-between mb-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-primary/10 text-primary uppercase tracking-wider">
                {{ 'Suggéré pour toi' | trans }}
            </span>
            <button onclick="document.getElementById('recommendation-nudge').remove()" class="text-slate-400 hover:text-slate-600 transition-colors">
                <twig:ux:icon name="lucide:x" class="w-4 h-4" />
            </button>
        </div>
        
        <h4 class="font-bold text-slate-900 mb-2 line-clamp-2">{{ recommendation.title }}</h4>
        <p class="text-xs text-slate-500 mb-4 line-clamp-2 italic">"{{ recommendation.getExcerpt(80) }}"</p>
        
        {% set recCourse = recommendation.module.course %}
        <a href="{{ path('lesson_show', {courseSlug: recCourse.slug, moduleSlug: recommendation.module.slug, lessonId: recommendation.id}) }}" class="flex items-center justify-center w-full py-2 bg-primary text-white text-xs font-bold rounded-lg hover:bg-primary/90 transition-colors gap-2">
            {{ 'Lire la suite' | trans }}
            <twig:ux:icon name="lucide:arrow-right" class="w-3 h-3" />
        </a>
    </div>
</div>
{% endif %}
