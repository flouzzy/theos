{% extends 'app.html.twig' %}

{% block title %}{{ 'Classement global' | trans }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto p-6">

    {% set podiumUsers = topUsers|slice(0, 3) %}
    {% set otherUsers = topUsers|slice(3) %}

    {# Podium Top 3 #}
    {% if podiumUsers|length >= 3 %}
    <div class="flex justify-center items-end gap-2 sm:gap-8 mb-16 mt-8 h-56 relative">
        {# 2ème #}
        {% set user2 = podiumUsers[1] %}
        <div class="flex flex-col items-center w-28 sm:w-36 z-10 translate-y-6">
            <a href="{{ path('user_profile', {username: user2.username}) }}" class="flex flex-col items-center">
                <twig:UserAvatar :user="user2" class="w-14 h-14 sm:w-16 sm:h-16 shadow-lg z-10 border-4 border-slate-300 dark:border-slate-600 mb-2" showBadge="true" badgeContent="2" wrapperClass="mb-2" />
                <span class="font-bold text-sm text-center truncate w-full px-2" title="{{ user2.fullname }}">{{ user2.firstname }}</span>
            </a>
            <span class="text-xs text-muted-foreground font-medium mb-1">{{ user2.xp }} XP</span>
            <div class="w-full bg-slate-200 dark:bg-slate-800 rounded-t-lg h-28 mt-2 border-t border-x border-slate-300 dark:border-slate-700/50 flex justify-center items-start pt-2">
                <span class="text-2xl sm:text-3xl opacity-50">🥈</span>
            </div>
        </div>

        {# 1er #}
        {% set user1 = podiumUsers[0] %}
        <div class="flex flex-col items-center w-32 sm:w-44 z-20">
            <div class="text-3xl sm:text-4xl mb-1 animate-bounce">👑</div>
            <a href="{{ path('user_profile', {username: user1.username}) }}" class="flex flex-col items-center">
                <twig:UserAvatar :user="user1" class="w-16 h-16 sm:w-20 sm:h-20 shadow-xl z-10 border-4 border-yellow-400 ring-4 ring-yellow-400/20 mb-2" showBadge="true" badgeContent="1" wrapperClass="mb-2" />
                <span class="font-bold text-base sm:text-lg text-center truncate w-full px-2 text-yellow-600 dark:text-yellow-500" title="{{ user1.fullname }}">{{ user1.firstname }}</span>
            </a>
            <span class="text-sm font-bold text-yellow-600/80 dark:text-yellow-500/80 mb-1">{{ user1.xp }} XP</span>
            <div class="w-full bg-gradient-to-b from-yellow-100 to-yellow-50 dark:from-yellow-900/40 dark:to-yellow-900/10 rounded-t-lg h-36 mt-2 border-t border-x border-yellow-300 dark:border-yellow-700/50 shadow-[0_-10px_15px_-3px_rgba(250,204,21,0.1)] flex justify-center items-start pt-2">
                <span class="text-3xl sm:text-4xl opacity-80">🥇</span>
            </div>
        </div>

        {# 3ème #}
        {% set user3 = podiumUsers[2] %}
        <div class="flex flex-col items-center w-28 sm:w-36 z-10 translate-y-12">
            <a href="{{ path('user_profile', {username: user3.username}) }}" class="flex flex-col items-center">
                <twig:UserAvatar :user="user3" class="w-12 h-12 sm:w-14 sm:h-14 shadow-lg z-10 border-4 border-amber-700/60 dark:border-amber-900/80 mb-2" showBadge="true" badgeContent="3" wrapperClass="mb-2" />
                <span class="font-bold text-sm text-center truncate w-full px-2" title="{{ user3.fullname }}">{{ user3.firstname }}</span>
            </a>
            <span class="text-xs text-muted-foreground font-medium mb-1">{{ user3.xp }} XP</span>
            <div class="w-full bg-amber-50/50 dark:bg-amber-900/20 rounded-t-lg h-24 mt-2 border-t border-x border-amber-200 dark:border-amber-800/50 flex justify-center items-start pt-2">
                <span class="text-2xl sm:text-3xl opacity-50">🥉</span>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-border bg-muted/50">
                    <th class="p-4 font-semibold text-foreground">#</th>
                    <th class="p-4 font-semibold text-foreground">{{ 'Utilisateur' | trans }}</th>
                    <th class="p-4 font-semibold text-foreground text-center">{{ 'Ligue' | trans }}</th>
                    <th class="p-4 font-semibold text-foreground text-center">XP</th>
                    <th class="p-4 font-semibold text-foreground text-center">{{ 'Série' | trans }}</th>
                    <th class="p-4 font-semibold text-foreground text-center">{{ 'Badges' | trans }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                {% for user in otherUsers %}
                    {% set position = loop.index + 3 %}
                    <tr class="hover:bg-muted/30 transition-colors {{ app.user == user ? 'bg-indigo-50 dark:bg-indigo-900/20' : '' }}">
                        <td class="p-4 font-bold text-muted-foreground w-16">
                            {{ position }}
                        </td>
                        <td class="p-4">
                            <a href="{{ path('user_profile', {username: user.username}) }}" class="flex items-center gap-3 group">
                                <twig:UserAvatar :user="user" />
                                <span class="font-medium group-hover:underline {{ app.user == user ? 'text-indigo-600 dark:text-indigo-400' : 'text-foreground' }}">
                                    {{ user.fullname }}
                                </span>
                            </a>
                        </td>
                        <td class="p-4 text-center">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-black uppercase tracking-wider
                                {% if 'Diamant' in user.tier %}bg-cyan-100 text-cyan-700 border border-cyan-200
                                {% elseif 'Or' in user.tier %}bg-yellow-100 text-yellow-700 border border-yellow-200
                                {% elseif 'Argent' in user.tier %}bg-slate-100 text-slate-700 border border-slate-200
                                {% elseif 'Bronze' in user.tier %}bg-amber-100 text-amber-700 border border-amber-200
                                {% else %}bg-emerald-50 text-emerald-600 border border-emerald-100
                                {% endif %}">
                                {{ user.tier }}
                            </span>
                        </td>
                        <td class="p-4 text-center font-bold text-indigo-600">{{ user.xp }} XP</td>
                        <td class="p-4 text-center">
                            {% if user.streak > 0 %}
                                <twig:StreakBadge streak="{{ user.streak }}" size="xs" showValue="true" />
                            {% else %}
                                <span class="text-muted-foreground text-xs">-</span>
                            {% endif %}
                        </td>
                         <td class="p-4 text-center font-medium">
                            {{ user.badges.count }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="p-8 text-center text-muted-foreground">
                            {{ 'Aucun utilisateur trouvé.' | trans }}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
