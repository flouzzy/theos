{% extends 'base.html.twig' %}

{% block body %}
	<div class="flex flex-col min-h-screen">
		<header class="border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
			<div class="container flex h-16 items-center justify-between px-4">
				<a href="{{path('home')}}" class="flex items-center gap-2">
					<img src="{{asset('images/logo.svg')}}" alt="Logo le rocher Academie" class="h-10 w-auto">
				</a>
				<div class="flex items-center gap-4">
					{% if is_granted('IS_AUTHENTICATED_FULLY') %}
						<twig:Button variant="ghost" asChild>
							<a href="{{path('home')}}">
								<twig:ux:icon name="lucide:home" class="mr-2 h-4 w-4" />
								<span class="hidden md:inline">{{'Back to home' | trans}}</span>
							</a>
						</twig:Button>
					{% else %}
						<twig:Button variant="ghost" asChild>
							<a href="{{path('login')}}">
								<twig:ux:icon name="lucide:log-in" class="mr-2 h-4 w-4" />
								{{'Sign in' | trans}}
							</a>
						</twig:Button>
						<twig:Button asChild>
							<a href="{{path('register')}}">
								{{'Sign up' | trans}}
							</a>
						</twig:Button>
					{% endif %}
				</div>
			</div>
		</header>

		<main class="flex-1">
			{% block content %}{% endblock %}
		</main>

		<footer class="border-t py-6 md:px-8 md:py-0">
			<div class="container flex flex-col items-center justify-between gap-4 md:h-24 md:flex-row">
				<p class="text-center text-sm leading-loose text-muted-foreground md:text-left">
					{{'now' | date('Y')}} &copy; Le Rocher Academie. {{'All rights reserved' | trans}}
				</p>
			</div>
		</footer>
	</div>
{% endblock %}
