<ion-button href="{{path('notification_index')}}" fill="clear">
	<ion-icon name="notifications{% if notifications | length == 0 %}-outline{% endif %}"></ion-icon>
	{% if notifications | length > 0 %}
		<ion-badge slot="end" color="danger">
			{{notifications | length}}
		</ion-badge>
	{% endif %}
</ion-button>
