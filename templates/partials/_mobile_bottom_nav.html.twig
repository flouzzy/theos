{% if app.user %}
<nav id="mobile-bottom-nav" class="fixed bottom-0 left-0 right-0 z-[60] bg-background/95 backdrop-blur-md border-t border-border lg:hidden pb-safe shadow-[0_-4px_10px_rgba(0,0,0,0.05)]">
    <div class="flex w-full px-2 min-[375px]:px-3 min-[425px]:w-[90%] min-[425px]:px-0 mx-auto items-center h-16 min-[425px]:h-[68px] overflow-hidden">
        {# Tab 1: Accueil #}
        <a href="{{ path('cohort_index') }}" class="tab-item {{ app.request.attributes.get('_route') starts with 'cohort_' ? 'text-primary' : 'text-muted-foreground' }} flex-1 min-w-0 flex flex-col items-center justify-center gap-1 group">
            <div class="p-1 rounded-xl transition-all {{ app.request.attributes.get('_route') starts with 'cohort_' ? 'bg-primary/10' : 'group-active:bg-muted' }}">
                <svg class="h-5 w-5 min-[375px]:h-[22px] min-[375px]:w-[22px] min-[425px]:h-6 min-[425px]:w-6" fill="{{ app.request.attributes.get('_route') starts with 'cohort_' ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
            </div>
            <span class="text-[9px] min-[375px]:text-[10px] min-[425px]:text-[11px] font-bold truncate max-w-full leading-tight">{{ 'Home' | trans }}</span>
        </a>

        {# Tab 2: Cours #}
        <a href="{{ path('course_index') }}" class="tab-item {{ app.request.attributes.get('_route') starts with 'course' ? 'text-primary' : 'text-muted-foreground' }} flex-1 min-w-0 flex flex-col items-center justify-center gap-1 group">
            <div class="p-1 rounded-xl transition-all {{ app.request.attributes.get('_route') starts with 'course' ? 'bg-primary/10' : 'group-active:bg-muted' }}">
               <svg class="h-5 w-5 min-[375px]:h-[22px] min-[375px]:w-[22px] min-[425px]:h-6 min-[425px]:w-6" fill="{{ app.request.attributes.get('_route') starts with 'course' ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
            </div>
            <span class="text-[9px] min-[375px]:text-[10px] min-[425px]:text-[11px] font-bold truncate max-w-full leading-tight">{{ 'Courses' | trans }}</span>
        </a>

        {# Tab 3: Bloc-notes #}
        <a href="{{ path('note_index') }}" class="tab-item {{ app.request.attributes.get('_route') starts with 'note_' ? 'text-primary' : 'text-muted-foreground' }} flex-1 min-w-0 flex flex-col items-center justify-center gap-1 group">
            <div class="p-1 rounded-xl transition-all {{ app.request.attributes.get('_route') starts with 'note_' ? 'bg-primary/10' : 'group-active:bg-muted' }}">
                <svg class="h-5 w-5 min-[375px]:h-[22px] min-[375px]:w-[22px] min-[425px]:h-6 min-[425px]:w-6" fill="{{ app.request.attributes.get('_route') starts with 'note_' ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
            </div>
            <span class="text-[9px] min-[375px]:text-[10px] min-[425px]:text-[11px] font-bold truncate max-w-full leading-tight">{{ 'Notes' | trans }}</span>
        </a>

        {# Tab 4: Evaluations #}
        <a href="{{ path('evaluation_index') }}" class="tab-item {{ app.request.attributes.get('_route') starts with 'evaluation_' ? 'text-primary' : 'text-muted-foreground' }} flex-1 min-w-0 flex flex-col items-center justify-center gap-1 group">
            <div class="p-1 rounded-xl transition-all {{ app.request.attributes.get('_route') starts with 'evaluation_' ? 'bg-primary/10' : 'group-active:bg-muted' }}">
                <svg class="h-5 w-5 min-[375px]:h-[22px] min-[375px]:w-[22px] min-[425px]:h-6 min-[425px]:w-6" fill="{{ app.request.attributes.get('_route') starts with 'evaluation_' ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
            </div>
            <span class="text-[9px] min-[375px]:text-[10px] min-[425px]:text-[11px] font-bold truncate max-w-full leading-tight">{{ 'Eval.' | trans }}</span>
        </a>

        {# Tab 5: Plus (Opens drawer) #}
        <button @click="moreMenuOpen = true" type="button" class="tab-item flex-1 min-w-0 flex flex-col items-center justify-center gap-1 group text-muted-foreground hover:text-foreground">
            <div class="p-1 rounded-xl transition-all group-active:bg-muted">
                <svg class="h-5 w-5 min-[375px]:h-[22px] min-[375px]:w-[22px] min-[425px]:h-6 min-[425px]:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </div>
            <span class="text-[9px] min-[375px]:text-[10px] min-[425px]:text-[11px] font-bold truncate max-w-full leading-tight">{{ 'More' | trans }}</span>
        </button>
    </div>
</nav>
{% endif %}
