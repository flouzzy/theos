{% set 
    menuItems = {
        'home': {'title': 'Home', 'icon': 'lucide:home', 'path': 'home'},
        'courses': {'title': 'Courses', 'icon': 'lucide:book-open', 'path': 'course_index'},
        'calendar': {'title': 'Calendar', 'icon': 'lucide:calendar', 'path': 'calendar'},
        'notes': {'title': 'Notes', 'icon': 'lucide:sticky-note', 'path': 'note_index'},
    } 
%}

{# Main Navigation #}
<div class="space-y-1">
    <div class="px-2 py-1 text-xs font-semibold text-muted-foreground uppercase tracking-wider">
        {{ 'Navigation' | trans }}
    </div>
    
    {% for key, menu in menuItems %}
        <a href="{{ path(menu.path) }}" 
           class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-all
                  {% if app.request.attributes.get('_route') == menu.path %}
                      bg-primary text-primary-foreground
                  {% else %}
                      text-muted-foreground hover:text-foreground hover:bg-muted
                  {% endif %}">
            <twig:ux:icon name="{{ menu.icon }}" class="h-4 w-4 flex-shrink-0" />
            <span>{{ menu.title | trans }}</span>
        </a>
    {% endfor %}

    {# Notifications with Badge #}
    <a href="{{ path('notification_index') }}" 
       class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-all
              {% if app.request.attributes.get('_route') == 'notification_index' %}
                  bg-primary text-primary-foreground
              {% else %}
                  text-muted-foreground hover:text-foreground hover:bg-muted
              {% endif %}">
        <twig:ux:icon name="lucide:bell" class="h-4 w-4 flex-shrink-0" />
        <span class="flex-1">{{ 'Notifications' | trans }}</span>
        {% if notifications|default([]) | length > 0 %}
            <span class="inline-flex items-center justify-center rounded-full bg-destructive px-2 py-0.5 text-xs font-medium text-destructive-foreground">
                {{ notifications|default([]) | length }}
            </span>
        {% endif %}
    </a>
</div>

{# Account Section #}
{% if is_granted('IS_AUTHENTICATED') %}
    <div class="mt-6 space-y-1">
        <div class="px-2 py-1 text-xs font-semibold text-muted-foreground uppercase tracking-wider">
            {{ 'Account' | trans }}
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin') }}" 
               class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-all text-muted-foreground hover:text-foreground hover:bg-muted">
                <twig:ux:icon name="lucide:settings" class="h-4 w-4 flex-shrink-0" />
                <span>{{ 'Administration' | trans }}</span>
            </a>
        {% endif %}

        <a href="{{ path('profile_index') }}" 
           class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-all
                  {% if app.request.attributes.get('_route') == 'profile_index' %}
                      bg-primary text-primary-foreground
                  {% else %}
                      text-muted-foreground hover:text-foreground hover:bg-muted
                  {% endif %}">
            <twig:ux:icon name="lucide:user" class="h-4 w-4 flex-shrink-0" />
            <span>{{ 'Profile' | trans }}</span>
        </a>

        <a href="{{ path('_logout_main') }}" 
           class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-all text-muted-foreground hover:text-foreground hover:bg-muted">
            <twig:ux:icon name="lucide:log-out" class="h-4 w-4 flex-shrink-0" />
            <span>{{ 'Sign out' | trans }}</span>
        </a>
    </div>
{% else %}
    <div class="mt-6 space-y-1">
        <div class="px-2 py-1 text-xs font-semibold text-muted-foreground uppercase tracking-wider">
            {{ 'Account' | trans }}
        </div>

        <a href="{{ path('login') }}" 
           class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-all text-muted-foreground hover:text-foreground hover:bg-muted">
            <twig:ux:icon name="lucide:log-in" class="h-4 w-4 flex-shrink-0" />
            <span>{{ 'Sign in' | trans }}</span>
        </a>

        <a href="{{ path('register') }}" 
           class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-all text-muted-foreground hover:text-foreground hover:bg-muted">
            <twig:ux:icon name="lucide:user-plus" class="h-4 w-4 flex-shrink-0" />
            <span>{{ 'Sign up' | trans }}</span>
        </a>
    </div>
{% endif %}
