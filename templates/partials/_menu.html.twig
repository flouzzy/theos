{% set 
    menuItems = {
         'home':{'title':'Home', 'icon':'/images/icons/home.svg', 'path':'home'},
		 'course':{'title':'All courses', 'icon':'/images/icons/course.svg', 'path':'course_index'}
    } 
%}

<ion-list>
	{% for menu in menuItems %}
		<ion-item href="{{path(menu.path)}}" {% if current_path == menu.path %} color="{{colorActive}}" {% endif %}>
			<ion-icon slot="start" src="{{menu.icon}}" color="app"></ion-icon>
			<ion-label>
				{{menu.title | trans}}
			</ion-label>
		</ion-item>
	{% endfor %}

	{% set notifications = app_notification.findAllUnread %}
	<ion-item button href="{{path('notification_index')}}">
		<ion-icon slot="start" name="notifications-outline" color="app"></ion-icon>
		<ion-label>
			{{'Notifications' | trans}}
			{% if notifications | length > 0 %}
				<ion-text color="danger">
					({{notifications | length}})
				</ion-text>
			{% endif %}
		</ion-label>
	</ion-item>
</ion-list>

{# User connected #}
<ion-list>
	<ion-list-header>
		{{'Account' | trans}}
	</ion-list-header>


	{% if is_granted('IS_AUTHENTICATED') %}

		{% if is_granted('ROLE_ADMIN') %}
			<ion-item button href="{{path('admin')}}">
				<ion-icon slot="start" name="build-outline" color="app"></ion-icon>
				<ion-label>
					{{'Administration' | trans}}
				</ion-label>
			</ion-item>
		{% endif %}

		<ion-item button href="{{path('profile_index')}}" {% if current_path == 'profile_index' %} color="{{colorActive}}" {% endif %}>
			<ion-icon slot="start" src="/images/icons/profile.svg" color="app"></ion-icon>
			<ion-label>
				{{'Profile' | trans}}
			</ion-label>
		</ion-item>
		<ion-item button href="{{path('_logout_main')}}">
			<ion-icon slot="start" name="log-out-outline" color="app"></ion-icon>
			<ion-label>
				{{'Sign out' | trans}}
			</ion-label>
		</ion-item>
	{% else %}
		<ion-item button href="{{path('login')}}">
			<ion-icon slot="start" name="log-in-outline" color="app"></ion-icon>
			<ion-label>
				{{'Sign in' | trans}}
			</ion-label>
		</ion-item>
		<ion-item button href="{{path('register')}}">
			<ion-icon slot="start" name="people-outline" color="app"></ion-icon>
			<ion-label>
				{{'Sign up' | trans}}
			</ion-label>
		</ion-item>
	{% endif %}
</ion-list>
