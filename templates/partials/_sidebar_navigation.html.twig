{# Unified Sidebar Navigation - Premium UI/UX - 5 Items Max #}
{% set forceExpanded = desktopSidebarOpen is defined ? desktopSidebarOpen : false %}
{% set currentRoute = app.request.attributes.get('_route') %}

<nav class="flex flex-1 flex-col gap-2 mt-4">
    {# 1. Accueil / Dashboard #}
    {% set isActive = currentRoute == 'cohort_index' %}
    <a href="{{ path('cohort_index') }}"
       class="group flex items-center py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 {{ isActive ? 'text-primary' ~ (forceExpanded ? ' bg-primary/10' : '') : 'text-muted-foreground hover:bg-muted hover:text-foreground' }} {{ forceExpanded ? 'gap-3 px-3 justify-start' : '' }}"
       {% if not forceExpanded %}:class="desktopSidebarOpen ? 'gap-3 px-3 justify-start{% if isActive %} bg-primary/10{% endif %}' : 'gap-0 px-2 justify-center'"{% endif %}>
       <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
       </div>
        {% if forceExpanded %}
            <span class="whitespace-nowrap">{{ 'Accueil' | trans }}</span>
        {% else %}
            <span x-show="desktopSidebarOpen" x-transition.opacity class="whitespace-nowrap">{{ 'Accueil' | trans }}</span>
        {% endif %}
    </a>

    {# 2. Mes Cours #}
    {% set isActive = currentRoute starts with 'course' or currentRoute starts with 'lesson' %}
    <a href="{{ path('course_index') }}"
       class="group flex items-center py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 {{ isActive ? 'text-primary' ~ (forceExpanded ? ' bg-primary/10' : '') : 'text-muted-foreground hover:bg-muted hover:text-foreground' }} {{ forceExpanded ? 'gap-3 px-3 justify-start' : '' }}"
       {% if not forceExpanded %}:class="desktopSidebarOpen ? 'gap-3 px-3 justify-start{% if isActive %} bg-primary/10{% endif %}' : 'gap-0 px-2 justify-center'"{% endif %}>
        <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
        </div>
        {% if forceExpanded %}
            <span class="whitespace-nowrap">{{ 'Cours' | trans }}</span>
        {% else %}
            <span x-show="desktopSidebarOpen" x-transition.opacity class="whitespace-nowrap">{{ 'Cours' | trans }}</span>
        {% endif %}
    </a>

    {# 3. Bloc-notes #}
    {% set isActive = currentRoute starts with 'note' %}
    <a href="{{ path('note_index') }}"
       class="group flex items-center py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 {{ isActive ? 'text-primary' ~ (forceExpanded ? ' bg-primary/10' : '') : 'text-muted-foreground hover:bg-muted hover:text-foreground' }} {{ forceExpanded ? 'gap-3 px-3 justify-start' : '' }}"
       {% if not forceExpanded %}:class="desktopSidebarOpen ? 'gap-3 px-3 justify-start{% if isActive %} bg-primary/10{% endif %}' : 'gap-0 px-2 justify-center'"{% endif %}>
       <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
       </div>
        {% if forceExpanded %}
            <span class="whitespace-nowrap">{{ 'Bloc-notes' | trans }}</span>
        {% else %}
            <span x-show="desktopSidebarOpen" x-transition.opacity class="whitespace-nowrap">{{ 'Bloc-notes' | trans }}</span>
        {% endif %}
    </a>

    {# 4. Classement #}
    {% set isActive = currentRoute == 'leaderboard_index' %}
    <a href="{{ path('leaderboard_index') }}"
       class="group flex items-center py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 {{ isActive ? 'text-primary' ~ (forceExpanded ? ' bg-primary/10' : '') : 'text-muted-foreground hover:bg-muted hover:text-foreground' }} {{ forceExpanded ? 'gap-3 px-3 justify-start' : '' }}"
       {% if not forceExpanded %}:class="desktopSidebarOpen ? 'gap-3 px-3 justify-start{% if isActive %} bg-primary/10{% endif %}' : 'gap-0 px-2 justify-center'"{% endif %}>
       <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
       </div>
        {% if forceExpanded %}
            <span class="whitespace-nowrap">{{ 'Classement' | trans }}</span>
        {% else %}
            <span x-show="desktopSidebarOpen" x-transition.opacity class="whitespace-nowrap">{{ 'Classement' | trans }}</span>
        {% endif %}
    </a>

    {# ── Secondary Section ── #}
    {% if forceExpanded %}
        <div class="mt-4 mb-2 px-3">
            <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">{{ 'Outils' | trans }}</span>
        </div>
    {% else %}
        <div x-show="desktopSidebarOpen" x-transition.opacity class="mt-4 mb-2 px-3">
            <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">{{ 'Outils' | trans }}</span>
        </div>
    {% endif %}

    {# Calendrier #}
    {% set isActive = currentRoute starts with 'calendar' %}
    <a href="{{ path('calendar_index') }}"
       class="group flex items-center py-2 rounded-xl text-sm font-medium transition-all duration-200 {{ isActive ? 'text-primary' ~ (forceExpanded ? ' bg-primary/10' : '') : 'text-muted-foreground hover:bg-muted hover:text-foreground' }} {{ forceExpanded ? 'gap-3 px-3 justify-start' : '' }}"
       {% if not forceExpanded %}:class="desktopSidebarOpen ? 'gap-3 px-3 justify-start{% if isActive %} bg-primary/10{% endif %}' : 'gap-0 px-2 justify-center'"{% endif %}>
       <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <twig:ux:icon name="lucide:calendar" class="w-5 h-5" />
       </div>
        {% if forceExpanded %}
            <span class="whitespace-nowrap">{{ 'Calendrier' | trans }}</span>
        {% else %}
            <span x-show="desktopSidebarOpen" x-transition.opacity class="whitespace-nowrap">{{ 'Calendrier' | trans }}</span>
        {% endif %}
    </a>

    {# Évaluations #}
    {% set isActive = currentRoute starts with 'evaluation' %}
    <a href="{{ path('evaluation_index') }}"
       class="group flex items-center py-2 rounded-xl text-sm font-medium transition-all duration-200 {{ isActive ? 'text-primary' ~ (forceExpanded ? ' bg-primary/10' : '') : 'text-muted-foreground hover:bg-muted hover:text-foreground' }} {{ forceExpanded ? 'gap-3 px-3 justify-start' : '' }}"
       {% if not forceExpanded %}:class="desktopSidebarOpen ? 'gap-3 px-3 justify-start{% if isActive %} bg-primary/10{% endif %}' : 'gap-0 px-2 justify-center'"{% endif %}>
       <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
       </div>
        {% if forceExpanded %}
            <span class="whitespace-nowrap">{{ 'Évaluations' | trans }}</span>
        {% else %}
            <span x-show="desktopSidebarOpen" x-transition.opacity class="whitespace-nowrap">{{ 'Évaluations' | trans }}</span>
        {% endif %}
    </a>

    {# Notifications #}
    {% set isActive = currentRoute starts with 'notification' %}
    <a href="{{ path('notification_index') }}"
       class="group flex items-center py-2 rounded-xl text-sm font-medium transition-all duration-200 {{ isActive ? 'text-primary' ~ (forceExpanded ? ' bg-primary/10' : '') : 'text-muted-foreground hover:bg-muted hover:text-foreground' }} {{ forceExpanded ? 'gap-3 px-3 justify-start' : '' }}"
       {% if not forceExpanded %}:class="desktopSidebarOpen ? 'gap-3 px-3 justify-start{% if isActive %} bg-primary/10{% endif %}' : 'gap-0 px-2 justify-center'"{% endif %}>
       <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
       </div>
        {% if forceExpanded %}
            <span class="whitespace-nowrap">{{ 'Notifications' | trans }}</span>
        {% else %}
            <span x-show="desktopSidebarOpen" x-transition.opacity class="whitespace-nowrap">{{ 'Notifications' | trans }}</span>
        {% endif %}
        {% set unreadCount = unread_notifications_count() %}
        {% if unreadCount > 0 %}
            {% if forceExpanded %}
                <span class="ml-auto inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold leading-none text-white bg-red-500 rounded-full">{{ unreadCount }}</span>
            {% else %}
                <span x-show="desktopSidebarOpen" x-transition.opacity class="ml-auto inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold leading-none text-white bg-red-500 rounded-full">{{ unreadCount }}</span>
            {% endif %}
        {% endif %}
    </a>

    {# Coach (Feature-flagged) #}
    {% if coach_enabled() %}
    {% set isActive = currentRoute starts with 'coach' %}
    <a href="{{ path('coach_index') }}"
       class="group flex items-center py-2 rounded-xl text-sm font-medium transition-all duration-200 {{ isActive ? 'text-primary' ~ (forceExpanded ? ' bg-primary/10' : '') : 'text-muted-foreground hover:bg-muted hover:text-foreground' }} {{ forceExpanded ? 'gap-3 px-3 justify-start' : '' }}"
       {% if not forceExpanded %}:class="desktopSidebarOpen ? 'gap-3 px-3 justify-start{% if isActive %} bg-primary/10{% endif %}' : 'gap-0 px-2 justify-center'"{% endif %}>
        <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
        </div>
        {% if forceExpanded %}
            <span class="whitespace-nowrap">{{ 'Coach IA' | trans }}</span>
        {% else %}
            <span x-show="desktopSidebarOpen" x-transition.opacity class="whitespace-nowrap">{{ 'Coach IA' | trans }}</span>
        {% endif %}
    </a>
    {% endif %}

    {# Team Management (Authorized users) #}
    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_MANAGER') %}
    {% set isActive = currentRoute starts with 'team' %}
    <a href="{{ path('team_dashboard') }}"
       class="group flex items-center py-2 rounded-xl text-sm font-medium transition-all duration-200 {{ isActive ? 'text-primary' ~ (forceExpanded ? ' bg-primary/10' : '') : 'text-muted-foreground hover:bg-muted hover:text-foreground' }} {{ forceExpanded ? 'gap-3 px-3 justify-start' : '' }}"
       {% if not forceExpanded %}:class="desktopSidebarOpen ? 'gap-3 px-3 justify-start{% if isActive %} bg-primary/10{% endif %}' : 'gap-0 px-2 justify-center'"{% endif %}>
        <div class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
        </div>
        {% if forceExpanded %}
            <span class="whitespace-nowrap">{{ 'Mon Équipe' | trans }}</span>
        {% else %}
            <span x-show="desktopSidebarOpen" x-transition.opacity class="whitespace-nowrap">{{ 'Mon Équipe' | trans }}</span>
        {% endif %}
    </a>
    {% endif %}
</nav>
