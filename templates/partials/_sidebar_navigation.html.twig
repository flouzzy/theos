{# Unified Sidebar Navigation - Premium UI/UX - 5 Items Max #}

<nav class="flex flex-1 flex-col gap-2 mt-4">
    {# 1. Accueil / Dashboard #}
    <a href="{{ path('cohort_index') }}" 
       class="group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 {{ app.request.attributes.get('_route') == 'cohort_index' ? 'bg-primary/10 text-primary' : 'text-muted-foreground hover:bg-muted hover:text-foreground' }}">
       <div class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors {{ app.request.attributes.get('_route') == 'cohort_index' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
       </div>
        <span :class="{'hidden': !desktopSidebarOpen}" class="whitespace-nowrap">{{ 'Accueil' | trans }}</span>
    </a>

    {# 2. Mes Cours #}
    <a href="{{ path('course_index') }}" 
       class="group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'course' or app.request.attributes.get('_route') starts with 'lesson' ? 'bg-primary/10 text-primary' : 'text-muted-foreground hover:bg-muted hover:text-foreground' }}">
        <div class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors {{ app.request.attributes.get('_route') starts with 'course' or app.request.attributes.get('_route') starts with 'lesson' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
        </div>
        <span :class="{'hidden': !desktopSidebarOpen}" class="whitespace-nowrap">{{ 'Cours' | trans }}</span>
    </a>

    {# 3. Classement #}
    <a href="{{ path('leaderboard_index') }}" 
       class="group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 {{ app.request.attributes.get('_route') == 'leaderboard_index' ? 'bg-primary/10 text-primary' : 'text-muted-foreground hover:bg-muted hover:text-foreground' }}">
       <div class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors {{ app.request.attributes.get('_route') == 'leaderboard_index' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
       </div>
        <span :class="{'hidden': !desktopSidebarOpen}" class="whitespace-nowrap">{{ 'Classement' | trans }}</span>
    </a>

    {# 4. Bloc-notes #}
    <a href="{{ path('note_index') }}" 
       class="group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'note' ? 'bg-primary/10 text-primary' : 'text-muted-foreground hover:bg-muted hover:text-foreground' }}">
       <div class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors {{ app.request.attributes.get('_route') starts with 'note' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
       </div>
        <span :class="{'hidden': !desktopSidebarOpen}" class="whitespace-nowrap">{{ 'Bloc-notes' | trans }}</span>
    </a>

    {# 5. Profil #}
    <a href="{{ path('profile_index') }}" 
       class="group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'profile' ? 'bg-primary/10 text-primary' : 'text-muted-foreground hover:bg-muted hover:text-foreground' }}">
        <div class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors {{ app.request.attributes.get('_route') starts with 'profile' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
        </div>
        <span :class="{'hidden': !desktopSidebarOpen}" class="whitespace-nowrap">{{ 'Profil' | trans }}</span>
    </a>

    {# ── Secondary Section ── #}
    <div class="mt-4 mb-2 px-3" :class="{'hidden': !desktopSidebarOpen}">
        <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">{{ 'Outils' | trans }}</span>
    </div>

    {# Évaluations #}
    <a href="{{ path('evaluation_index') }}" 
       class="group flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'evaluation' ? 'bg-primary/10 text-primary' : 'text-muted-foreground hover:bg-muted hover:text-foreground' }}">
       <div class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors {{ app.request.attributes.get('_route') starts with 'evaluation' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
       </div>
        <span :class="{'hidden': !desktopSidebarOpen}" class="whitespace-nowrap">{{ 'Évaluations' | trans }}</span>
    </a>

    {# Notifications #}
    <a href="{{ path('notification_index') }}" 
       class="group flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'notification' ? 'bg-primary/10 text-primary' : 'text-muted-foreground hover:bg-muted hover:text-foreground' }}">
       <div class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors {{ app.request.attributes.get('_route') starts with 'notification' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
       </div>
        <span :class="{'hidden': !desktopSidebarOpen}" class="whitespace-nowrap">{{ 'Notifications' | trans }}</span>
        {% set unreadCount = unread_notifications_count() %}
        {% if unreadCount > 0 %}
            <span :class="{'hidden': !desktopSidebarOpen}" class="ml-auto inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold leading-none text-white bg-red-500 rounded-full">{{ unreadCount }}</span>
        {% endif %}
    </a>

    {# Coach (Feature-flagged) #}
    {% if coach_enabled() %}
    <a href="{{ path('coach_index') }}" 
       class="group flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'coach' ? 'bg-primary/10 text-primary' : 'text-muted-foreground hover:bg-muted hover:text-foreground' }}">
        <div class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors {{ app.request.attributes.get('_route') starts with 'coach' ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-transparent group-hover:bg-muted' }}">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
        </div>
        <span :class="{'hidden': !desktopSidebarOpen}" class="whitespace-nowrap">{{ 'Coach IA' | trans }}</span>
    </a>
    {% endif %}
</nav>
