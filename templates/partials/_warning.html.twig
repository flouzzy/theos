{# Si un compte n'est pas vérifié, on affiche un message #}

{% if app.user and not app.user.isVerified %}
    <div class="max-w-4xl mx-auto mb-6">
        <div class="rounded-lg border border-yellow-200 bg-yellow-50/50 p-4 [&>svg]:text-yellow-600 text-yellow-900 shadow-sm" role="alert">
            <div class="flex items-start gap-4">
                 {# Icon #}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 mt-0.5">
                    <circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/>
                </svg>
                
                <div class="flex-1">
                    <h5 class="mb-1 font-medium leading-none tracking-tight">
                         {{ app.user.firstname }}, {{ 'your account has not been verified yet' | trans }}
                    </h5>
                    <div class="text-sm [&_p]:leading-relaxed opacity-90 mt-2">
                        <p>
                            {{ 'Please check your inbox (including Spam).' | trans }}
                        </p>
                         <p class="mt-1">
                            {{ 'Or' | trans }} 
                            <a href="{{ path('verify_email_resend') }}" class="font-medium underline hover:text-yellow-950 underline-offset-4">
                                {{ 'Click here to resend a verification email' | trans }}
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endif %}
