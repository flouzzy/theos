{#
  PWA Install CTA — Le Rocher Académie
  - Android/Chrome : banner discret en bas
  - iOS/Safari     : modal avec instructions visuelles
  Géré par `pwa_controller.js`
#}

{# ─── BANNER ANDROID (apparaît via JS quand beforeinstallprompt se déclenche) ─── #}
<div id="pwa-android-banner"
     class="hidden fixed bottom-0 inset-x-0 z-50 p-3 sm:p-4 sm:max-w-sm sm:mx-auto sm:mb-4 sm:rounded-2xl"
     data-controller="pwa"
     data-pwa-platform-value="android">
  <div class="flex items-center gap-3 bg-slate-900 text-white rounded-2xl px-4 py-3 shadow-2xl border border-white/10">
    <img src="{{ asset('images/favicon/android-chrome-192x192.png') }}" alt="App icon" class="w-10 h-10 rounded-xl flex-shrink-0" />
    <div class="flex-1 min-w-0">
      <p class="font-semibold text-sm leading-tight">Installer l'application</p>
      <p class="text-xs text-slate-400 leading-tight mt-0.5 truncate">Accès rapide depuis l'écran d'accueil</p>
    </div>
    <div class="flex gap-2 flex-shrink-0">
      <button id="pwa-android-dismiss"
              class="text-slate-400 hover:text-white px-2 py-1 text-xs rounded-lg transition-colors"
              data-action="click->pwa#dismissAndroid">
        Plus tard
      </button>
      <button id="pwa-android-install"
              class="bg-indigo-500 hover:bg-indigo-400 text-white text-xs font-semibold px-3 py-1.5 rounded-lg transition-colors"
              data-action="click->pwa#installAndroid">
        Installer
      </button>
    </div>
  </div>
</div>

{# ─── MODAL iOS (instructions "Ajouter à l'écran d'accueil") ─── #}
<div id="pwa-ios-modal"
     class="hidden fixed inset-0 z-50 flex items-end justify-center sm:items-center p-4"
     aria-modal="true" role="dialog" aria-labelledby="pwa-ios-title">

  {# Fond semi-transparent #}
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" data-action="click->pwa#dismissIos"></div>

  <div class="relative w-full max-w-sm bg-white rounded-3xl shadow-2xl overflow-hidden" data-controller="pwa" data-pwa-platform-value="ios">
    {# Poignée draggable sur mobile #}
    <div class="flex justify-center pt-3 pb-0">
      <div class="w-10 h-1 bg-slate-200 rounded-full"></div>
    </div>

    <div class="p-6 text-center">
      <img src="{{ asset('images/favicon/apple-touch-icon.png') }}" alt="App icon"
           class="w-16 h-16 rounded-2xl mx-auto mb-4 shadow-md" />
      <h2 id="pwa-ios-title" class="text-lg font-bold text-slate-900 mb-1">Installer Le Rocher Académie</h2>
      <p class="text-sm text-slate-500 mb-6">Ajoutez l'application à votre écran d'accueil pour un accès rapide, même hors ligne.</p>

      {# Étapes visuelles #}
      <ol class="space-y-3 text-left mb-6">
        <li class="flex items-start gap-3">
          <span class="flex-shrink-0 w-7 h-7 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center font-bold text-sm">1</span>
          <span class="text-sm text-slate-700 pt-0.5">
            Appuyez sur l'icône
            <strong class="inline-flex items-center gap-1">
              {# Icône partage Safari #}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-blue-500 inline">
                <path d="M15.75 2.25H21a.75.75 0 0 1 .75.75v5.25a.75.75 0 0 1-1.5 0V4.81L8.03 17.03a.75.75 0 0 1-1.06-1.06L19.19 3.75h-3.44a.75.75 0 0 1 0-1.5Zm-3 1.5H5.25A1.5 1.5 0 0 0 3.75 5.25v13.5A1.5 1.5 0 0 0 5.25 20.25h13.5a1.5 1.5 0 0 0 1.5-1.5V11.25a.75.75 0 0 1 1.5 0v7.5a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V5.25a3 3 0 0 1 3-3h7.5a.75.75 0 0 1 0 1.5Z"/>
              </svg>
              Partager
            </strong>
            dans Safari
          </span>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex-shrink-0 w-7 h-7 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center font-bold text-sm">2</span>
          <span class="text-sm text-slate-700 pt-0.5">
            Faites défiler et sélectionnez
            <strong>« Sur l'écran d'accueil »</strong>
          </span>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex-shrink-0 w-7 h-7 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center font-bold text-sm">3</span>
          <span class="text-sm text-slate-700 pt-0.5">
            Confirmez en appuyant sur <strong>« Ajouter »</strong>
          </span>
        </li>
      </ol>

      <div class="flex gap-3">
        <button class="flex-1 text-sm text-slate-500 hover:text-slate-700 py-2.5 rounded-xl border border-slate-200 hover:bg-slate-50 transition-colors font-medium"
                data-action="click->pwa#dismissIos">
          Fermer
        </button>
        <button class="flex-1 text-sm text-white bg-indigo-600 hover:bg-indigo-700 py-2.5 rounded-xl transition-colors font-semibold"
                data-action="click->pwa#dismissIos">
          Compris !
        </button>
      </div>
    </div>

    {# Indicateur visuel sur quel écran appuyer (flèche vers le bas) #}
    <div class="bg-slate-50 border-t border-slate-100 px-6 py-3 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-400 flex-shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9" />
      </svg>
      <p class="text-xs text-slate-500">L'icône de partage se trouve dans la barre d'outils de Safari en bas (ou en haut) de l'écran.</p>
    </div>
  </div>
</div>
