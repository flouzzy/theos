{% extends 'app.html.twig' %}

{% block title %}{{ 'Revue par les pairs' | trans }} - {{ assignment.title }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto p-6 space-y-8">

    <div class="flex items-center gap-4 mb-4">
        <a href="{{ path('assignment_show', {id: assignment.id}) }}" class="text-muted-foreground hover:text-foreground">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
        </a>
        <h1 class="text-3xl font-bold">{{ 'Revue du devoir' | trans }}</h1>
    </div>

    {# Submission Content #}
    <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
        <div class="px-6 py-4 border-b border-border bg-muted/30">
            <h2 class="text-lg font-semibold">{{ 'Réponse de l\'étudiant' | trans }}</h2>
            <span class="text-xs text-muted-foreground">{{ 'Soumis le' | trans }} {{ submission.createdAt|date('d M Y') }}</span>
        </div>
        <div class="p-6">
            <div class="bg-muted p-4 rounded-lg font-mono text-sm whitespace-pre-wrap">
                {{ submission.content }}
            </div>
        </div>
    </div>

    {# Review Form #}
    <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
        <div class="px-6 py-4 border-b border-border bg-muted/30">
            <h2 class="text-lg font-semibold">{{ 'Votre évaluation' | trans }}</h2>
        </div>
        <div class="p-6">
            <form action="{{ path('assignment_submit_review', {id: assignment.id, submissionId: submission.id}) }}" method="POST" class="space-y-6">
                <input type="hidden" name="_token" value="{{ csrf_token('submit_review' ~ submission.id) }}">

                <div>
                    <label for="score" class="block text-sm font-medium mb-2">{{ 'Note (1-10)' | trans }}</label>
                    <input type="number" name="score" id="score" min="1" max="10" required class="w-24 rounded-md border border-input bg-background px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                </div>

                <div>
                    <label for="feedback" class="block text-sm font-medium mb-2">{{ 'Commentaires constructifs' | trans }}</label>
                    <textarea name="feedback" id="feedback" required class="w-full h-48 p-3 rounded-md border border-input bg-background focus:ring-2 focus:ring-primary focus:border-primary resize-y" placeholder="{{ 'Donnez des conseils pour améliorer ce travail...' | trans }}"></textarea>
                </div>

                <div class="flex items-center justify-end gap-4">
                    <a href="{{ path('assignment_show', {id: assignment.id}) }}" class="px-4 py-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">
                        {{ 'Annuler' | trans }}
                    </a>
                    <button type="submit" class="inline-flex items-center justify-center rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
                        {{ 'Soumettre l\'évaluation' | trans }}
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>
{% endblock %}
