{% extends 'appWithBottomTabs.html.twig' %}

{% block title %}{{ 'Settings' | trans }}{% endblock %}
{% block page_title %}{{ 'Settings' | trans }}{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto space-y-8">
    
    {# Profile Section #}
    <div class="bg-card border border-border rounded-3xl p-6 flex items-center gap-4">
        <div class="h-16 w-16 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold text-2xl">
            {{ app.user.firstname|first }}{{ app.user.lastname|first }}
        </div>
        <div class="flex-1">
            <h2 class="text-xl font-bold">{{ app.user.fullname }}</h2>
            <p class="text-muted-foreground">{{ app.user.email }}</p>
        </div>
        <button class="btn btn-outline text-sm">
            {{ 'Edit' | trans }}
        </button>
    </div>

    {# Main Settings List #}
    <div class="bg-card border border-border rounded-3xl overflow-hidden">
        
        <div class="p-6 border-b border-border">
            <h3 class="font-bold text-lg mb-1">{{ 'Account' | trans }}</h3>
            <p class="text-sm text-muted-foreground">{{ 'Manage your personal information' | trans }}</p>
        </div>

        <div class="divide-y divide-border">
             <a href="{{ path('profile_edit') }}" class="flex items-center justify-between p-4 hover:bg-muted transition-colors">
                 <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </div>
                    <span class="font-medium">{{ 'Profile information' | trans }}</span>
                 </div>
                 <svg class="w-5 h-5 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                 </svg>
             </a>

             <a href="#" class="flex items-center justify-between p-4 hover:bg-muted transition-colors">
                 <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-green-100 text-green-600 flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                        </svg>
                    </div>
                    <span class="font-medium">{{ 'Notifications' | trans }}</span>
                 </div>
                 <svg class="w-5 h-5 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                 </svg>
             </a>

             <a href="#" class="flex items-center justify-between p-4 hover:bg-muted transition-colors">
                 <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </div>
                    <span class="font-medium">{{ 'Security & Password' | trans }}</span>
                 </div>
                 <svg class="w-5 h-5 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                 </svg>
             </a>
        </div>
    </div>
    
    {# General Settings #}
     <div class="bg-card border border-border rounded-3xl overflow-hidden">
        <div class="p-6 border-b border-border">
            <h3 class="font-bold text-lg mb-1">{{ 'General' | trans }}</h3>
            <p class="text-sm text-muted-foreground">{{ 'Privacy and support' | trans }}</p>
        </div>
        <div class="divide-y divide-border">
             <a href="#" class="flex items-center justify-between p-4 hover:bg-muted transition-colors">
                 <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-gray-100 text-gray-600 flex items-center justify-center">
                       <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <span class="font-medium">{{ 'Aide & Support' | trans }}</span>
                 </div>
                  <svg class="w-5 h-5 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                 </svg>
             </a>
              <a href="{{ path('_logout_main') }}" class="flex items-center justify-between p-4 hover:bg-red-50 hover:text-red-600 transition-colors group">
                 <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-red-100 text-red-600 flex items-center justify-center group-hover:bg-red-200 transition-colors">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l-4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                    </div>
                    <span class="font-medium">{{ 'Sign out' | trans }}</span>
                 </div>
             </a>
        </div>
     </div>
</div>
{% endblock %}
