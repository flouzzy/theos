{% extends 'appWithBottomTabs.html.twig' %}

{% block title %}{{ 'Mon Coach' | trans }}{% endblock %}
{% block page_title %}{{ 'Coach IA' | trans }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto space-y-6">
    
    {# Compact Stats Banner #}
    <div class="flex flex-wrap items-center gap-3">
        <div class="flex items-center gap-2 px-3 py-1.5 bg-orange-50 text-orange-600 rounded-full text-sm font-bold border border-orange-100">
            🔥 {{ streak }} {{ 'jours' | trans }}
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 bg-indigo-50 text-indigo-600 rounded-full text-sm font-bold border border-indigo-100">
            ⚡ {{ xp }} XP
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 bg-blue-50 text-blue-600 rounded-full text-sm font-bold border border-blue-100">
            🏆 {{ badgesCount }} {{ 'badges' | trans }}
        </div>
        <div class="ml-auto text-sm text-muted-foreground font-medium">
            {{ weeklyXpTotal }} XP {{ 'cette semaine' | trans }}
        </div>
    </div>

    {# Quick Actions — Compact Row #}
    {% if nextLesson or reviewLesson %}
    <div class="flex flex-wrap gap-3">
        {% if nextLesson %}
        <a href="{{ path('lesson_show', {lessonId: nextLesson.id, moduleSlug: nextLesson.module.slug, courseSlug: nextLesson.module.course.slug}) }}" 
           class="flex items-center gap-3 bg-card border border-border rounded-xl px-4 py-3 hover:shadow-md transition-shadow flex-1 min-w-[200px] no-underline text-foreground group">
            <div class="w-10 h-10 rounded-lg bg-orange-100 text-orange-600 flex items-center justify-center text-lg flex-shrink-0">🔥</div>
            <div class="flex-1 min-w-0">
                <p class="font-bold text-sm truncate">{{ streakInfo.message }}</p>
                <p class="text-xs text-muted-foreground">+10 XP</p>
            </div>
            <svg class="w-4 h-4 text-muted-foreground group-hover:text-primary transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
        </a>
        {% endif %}

        {% if reviewLesson %}
        <a href="{{ path('lesson_show', {lessonId: reviewLesson.id, moduleSlug: reviewLesson.module.slug, courseSlug: reviewLesson.module.course.slug}) }}" 
           class="flex items-center gap-3 bg-card border border-border rounded-xl px-4 py-3 hover:shadow-md transition-shadow flex-1 min-w-[200px] no-underline text-foreground group">
            <div class="w-10 h-10 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center text-lg flex-shrink-0">🔄</div>
            <div class="flex-1 min-w-0">
                <p class="font-bold text-sm truncate">{{ reviewLesson.title }}</p>
                <p class="text-xs text-muted-foreground">{{ 'Réviser' | trans }}</p>
            </div>
            <svg class="w-4 h-4 text-muted-foreground group-hover:text-primary transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
        </a>
        {% endif %}
    </div>
    {% endif %}

    {# Chat Interface — Full Width, Main Focus #}
    <div class="bg-card border border-border rounded-2xl shadow-sm flex flex-col" style="height: calc(100vh - 320px); min-height: 400px;">
        {# Chat Header #}
        <div class="flex items-center gap-3 px-6 py-4 border-b border-border">
            <div class="h-10 w-10 flex items-center justify-center rounded-xl bg-indigo-100 text-indigo-600 text-xl">
                🦉
            </div>
            <div class="flex-1">
                <h2 class="font-bold text-base">{{ 'Coach IA' | trans }}</h2>
                <p class="text-xs text-muted-foreground flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-green-500 inline-block"></span>
                    {{ 'En ligne — Prêt à t\'aider' | trans }}
                </p>
            </div>
        </div>
        
        {# Messages Area #}
        <div id="chat-messages" class="flex-1 overflow-y-auto px-6 py-4 space-y-4 scrollbar-thin">
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-sm shrink-0">🦉</div>
                <div class="bg-muted rounded-2xl rounded-tl-none p-3 text-sm max-w-[85%]">
                    <p>{{ 'Salut ! 👋 Je suis ton coach IA. Pose-moi une question sur tes cours, ou demande-moi des explications !' | trans }}</p>
                </div>
            </div>
        </div>

        {# Input Area #}
        <div class="px-6 py-4 border-t border-border">
            <div class="relative">
                <input type="text" id="chat-input" placeholder="{{ 'Tape ton message...' | trans }}" 
                    class="w-full bg-muted/30 border border-border focus:border-primary rounded-xl pl-4 pr-12 py-3 text-sm transition-all outline-none focus:ring-2 focus:ring-primary/20">
                <button id="chat-submit" class="absolute right-2 top-1/2 -translate-y-1/2 p-2 text-primary hover:bg-primary/10 rounded-lg transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const chatInput = document.getElementById('chat-input');
    const chatSubmit = document.getElementById('chat-submit');
    const chatMessages = document.getElementById('chat-messages');
    let history = [];
    
    const addMessageToUI = (text, isUser = false) => {
        const msgDiv = document.createElement('div');
        msgDiv.className = 'flex gap-3 justify-' + (isUser ? 'end' : 'start');
        
        let innerHtml = '';
        if (isUser) {
            innerHtml = `
                <div class="bg-primary text-primary-foreground rounded-2xl rounded-tr-none p-3 text-sm max-w-[85%]">
                    <p>${text}</p>
                </div>
            `;
        } else {
            innerHtml = `
                <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-sm shrink-0">🦉</div>
                <div class="bg-muted rounded-2xl rounded-tl-none p-3 text-sm max-w-[85%] prose-sm">
                    <p>${text}</p>
                </div>
            `;
        }
        
        msgDiv.innerHTML = innerHtml;
        chatMessages.appendChild(msgDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    };

    const toggleTypingIndicator = (show) => {
        if (show) {
            const typingDiv = document.createElement('div');
            typingDiv.id = 'typing-indicator';
            typingDiv.className = 'flex gap-3 justify-start opacity-60';
            typingDiv.innerHTML = `
                <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-sm shrink-0">🦉</div>
                <div class="bg-muted rounded-2xl rounded-tl-none px-4 py-3 text-sm flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-foreground/40 animate-pulse"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-foreground/40 animate-pulse" style="animation-delay: 75ms"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-foreground/40 animate-pulse" style="animation-delay: 150ms"></span>
                </div>
            `;
            chatMessages.appendChild(typingDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        } else {
            const typingDiv = document.getElementById('typing-indicator');
            if (typingDiv) typingDiv.remove();
        }
    };

    const sendMessage = async () => {
        const message = chatInput.value.trim();
        if (!message) return;
        
        addMessageToUI(message, true);
        chatInput.value = '';
        chatInput.disabled = true;
        
        toggleTypingIndicator(true);

        try {
            const response = await fetch('{{ path("coach_chat") }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ message: message, history: history })
            });

            const data = await response.json();
            toggleTypingIndicator(false);
            
            if (data.reply) {
                addMessageToUI(data.reply, false);
                history.push({ role: 'user', content: message });
                history.push({ role: 'model', content: data.reply });
            } else {
                addMessageToUI("Désolé, je n'ai pas pu répondre. Réessaie !", false);
            }
        } catch (e) {
            toggleTypingIndicator(false);
            addMessageToUI("Erreur de connexion ! Vérifie ta connexion.", false);
            console.error(e);
        }
        
        chatInput.disabled = false;
        chatInput.focus();
    };

    chatSubmit.addEventListener('click', sendMessage);
    chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendMessage();
    });
});
</script>

{% endblock %}
