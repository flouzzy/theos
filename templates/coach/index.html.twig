{% extends 'appWithBottomTabs.html.twig' %}

{% block title %}{{ 'Mon Coach' | trans }}{% endblock %}
{% block page_title %}{{ 'Coach IA' | trans }}{% endblock %}

{% block content %}
<div class="space-y-6">
    
    {# Header Banner (Light) #}
    <div class="bg-card border border-border rounded-3xl p-6 flex flex-col md:flex-row items-center justify-between gap-6 shadow-sm">
        <div class="flex items-center gap-6">
             <div class="h-16 w-16 flex items-center justify-center rounded-2xl bg-indigo-100 text-indigo-600 text-3xl shadow-sm">
                🦉
             </div>
             <div>
                <h1 class="text-2xl font-bold mb-1">{{ 'Ton Coach IA' | trans }}</h1>
                <p class="text-muted-foreground text-sm">{{ 'Prêt à atteindre tes objectifs ?' | trans }}</p>
             </div>
        </div>
        
        {# Stats Row (Compact) #}
        <div class="flex flex-wrap justify-center gap-4">
            <div class="flex items-center gap-2 px-4 py-2 bg-orange-50 text-orange-600 rounded-xl border border-orange-100">
                <span class="text-lg">🔥</span>
                <div class="flex flex-col leading-none">
                    <span class="font-bold text-lg">{{ streak }}</span>
                    <span class="text-[10px] uppercase font-bold">{{ 'Série' | trans }}</span>
                </div>
            </div>
             <div class="flex items-center gap-2 px-4 py-2 bg-yellow-50 text-yellow-600 rounded-xl border border-yellow-100">
                <span class="text-lg">⚡</span>
                <div class="flex flex-col leading-none">
                    <span class="font-bold text-lg">{{ xp }}</span>
                    <span class="text-[10px] uppercase font-bold">{{ 'XP' | trans }}</span>
                </div>
            </div>
            <div class="flex items-center gap-2 px-4 py-2 bg-blue-50 text-blue-600 rounded-xl border border-blue-100">
                <span class="text-lg">🏆</span>
                <div class="flex flex-col leading-none">
                    <span class="font-bold text-lg">{{ badgesCount }}</span>
                    <span class="text-[10px] uppercase font-bold">{{ 'Badges' | trans }}</span>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        
        {# Main Column (3/4) #}
        <div class="lg:col-span-3 space-y-6">
            
            {# Quick Actions Grid (Simplified) #}
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                <button class="bg-card hover:border-blue-300 border border-border p-4 rounded-2xl flex flex-col items-center justify-center gap-2 transition-all hover:shadow-md group">
                    <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-500 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                        🎯
                    </div>
                    <span class="font-bold text-sm text-center">{{ 'Fixer un objectif' | trans }}</span>
                </button>
                <button class="bg-card hover:border-pink-300 border border-border p-4 rounded-2xl flex flex-col items-center justify-center gap-2 transition-all hover:shadow-md group">
                    <div class="w-10 h-10 rounded-full bg-pink-100 text-pink-500 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                        📖
                    </div>
                    <span class="font-bold text-sm text-center">{{ 'Reprendre' | trans }}</span>
                </button>
                <button class="bg-card hover:border-green-300 border border-border p-4 rounded-2xl flex flex-col items-center justify-center gap-2 transition-all hover:shadow-md group">
                    <div class="w-10 h-10 rounded-full bg-green-100 text-green-500 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                        🧠
                    </div>
                    <span class="font-bold text-sm text-center">{{ 'Quiz du jour' | trans }}</span>
                </button>
                 <button class="bg-card hover:border-orange-300 border border-border p-4 rounded-2xl flex flex-col items-center justify-center gap-2 transition-all hover:shadow-md group">
                    <div class="w-10 h-10 rounded-full bg-orange-100 text-orange-500 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                        🏅
                    </div>
                    <span class="font-bold text-sm text-center">{{ 'Achievements' | trans }}</span>
                </button>
            </div>

            {# Recommendations #}
            <div>
                <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
                    <span class="text-xl">✨</span> {{ 'Pour toi aujourd\'hui' | trans }} {# codespell-ignore #}
                </h3>
                
                <div class="space-y-4">
                    {# Recommendation Card 1 #}
                    <div class="bg-card border border-border rounded-2xl p-6 flex flex-col sm:flex-row gap-6 hover:shadow-md transition-shadow">
                        <div class="w-12 h-12 rounded-xl bg-orange-100 text-orange-600 flex items-center justify-center text-2xl flex-shrink-0">
                            🔥
                        </div>
                        <div class="flex-1">
                             <div class="flex justify-between items-start mb-2">
                                <div>
                                    <h4 class="font-bold text-lg leading-tight">{{ 'Ne brise pas ta série !' | trans }}</h4>
                                    <p class="text-sm text-muted-foreground mt-1">
                                        {{ 'Complète une leçon pour atteindre' | trans }} <span class="font-bold text-orange-500">4 {{ 'jours' | trans }}</span>
                                    </p>
                                </div>
                                <span class="bg-orange-100 text-orange-700 text-xs font-bold px-2 py-1 rounded-full">+20 XP</span>
                             </div>
                             
                             <div class="h-2 bg-muted rounded-full overflow-hidden mb-4 mt-2">
                                <div class="h-full bg-orange-500 w-[70%] rounded-full"></div>
                            </div>

                             <div class="flex justify-end">
                                 <button class="btn btn-sm bg-orange-500 hover:bg-orange-600 text-white rounded-lg px-6">
                                     {{ 'Go !' | trans }}
                                 </button>
                             </div>
                        </div>
                    </div>

                    {# Recommendation Card 2 #}
                    <div class="bg-card border border-border rounded-2xl p-6 flex flex-col sm:flex-row gap-6 hover:shadow-md transition-shadow">
                        <div class="w-12 h-12 rounded-xl bg-purple-100 text-purple-600 flex items-center justify-center text-2xl flex-shrink-0">
                            🔄
                        </div>
                        <div class="flex-1">
                             <h4 class="font-bold text-lg leading-tight mb-1">{{ 'Révision recommandée' | trans }}</h4>
                             <p class="text-sm text-muted-foreground mb-4">
                                 {{ 'Rafraîchis tes connaissances sur "Props et State"' | trans }}
                             </p>
                             
                             <div class="flex justify-end">
                                 <button class="btn btn-sm btn-outline hover:bg-purple-50 hover:text-purple-600 rounded-lg px-6">
                                     {{ 'Réviser' | trans }}
                                 </button>
                             </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Sidebar (1/4) #}
        <div class="space-y-6">
            
            {# Weekly Activity #}
            <div class="bg-card border border-border rounded-2xl p-6 shadow-sm">
                 <h3 class="font-bold text-sm uppercase text-muted-foreground mb-4">
                    {{ 'Cette semaine' | trans }}
                 </h3>
                 
                 <div class="flex items-baseline gap-1 mb-4">
                     <span class="text-3xl font-extrabold text-foreground">555</span>
                     <span class="text-sm font-bold text-muted-foreground">XP</span>
                 </div>

                 {# Weekly Graph #}
                 <div class="flex justify-between items-end h-24 gap-1">
                     {% for day, height in {'L': '40%', 'M': '60%', 'M.': '30%', 'J': '80%', 'V': '50%', 'S': '90%', 'D': '20%'} %}
                        <div class="flex flex-col items-center gap-1 flex-1">
                            <div class="w-full bg-muted/50 rounded-t-md h-full relative group">
                                <div class="absolute bottom-0 left-0 right-0 bg-indigo-500 rounded-t-md transition-all group-hover:bg-indigo-600" style="height: {{ height }}"></div>
                            </div>
                            <span class="text-[10px] font-bold text-muted-foreground">{{ day|first }}</span>
                        </div>
                     {% endfor %}
                 </div>
            </div>

            {# Chat Interface #}
            <div class="bg-card border border-border rounded-2xl p-4 shadow-sm h-[400px] flex flex-col">
                 <div class="flex items-center gap-2 mb-4 pb-4 border-b border-border">
                    <div class="w-2 h-2 rounded-full bg-green-500"></div>
                    <span class="font-bold text-sm">{{ 'Coach en ligne' | trans }}</span>
                 </div>
                 
                 <div id="chat-messages" class="flex-1 overflow-y-auto space-y-4 mb-4 scrollbar-thin">
                     <div class="flex gap-3">
                         <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-sm shrink-0">🦉</div>
                         <div class="bg-muted rounded-2xl rounded-tl-none p-3 text-sm">
                             <p>{{ 'Salut ! Prêt pour une session ?' | trans }}</p>
                         </div>
                     </div>
                 </div>

                 <div class="relative">
                     <input type="text" id="chat-input" placeholder="..." 
                        class="w-full bg-muted/30 border border-border focus:border-primary rounded-xl pl-3 pr-10 py-2 text-sm transition-all outline-none">
                     <button id="chat-submit" class="absolute right-1 top-1/2 -translate-y-1/2 p-1.5 text-primary hover:bg-primary/10 rounded-lg transition-colors">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                        </svg>
                     </button>
                 </div>
            </div>

        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const chatInput = document.getElementById('chat-input');
    const chatSubmit = document.getElementById('chat-submit');
    const chatMessages = document.getElementById('chat-messages');
    let history = []; // Stockage de l'historique Gemini
    
    // Fonction d'ajout de message UI
    const addMessageToUI = (text, isUser = false) => {
        const msgDiv = document.createElement('div');
        msgDiv.className = 'flex gap-3 justify-' + (isUser ? 'end' : 'start');
        
        let innerHtml = '';
        if (isUser) {
            innerHtml = `
                <div class="bg-primary text-primary-foreground rounded-2xl rounded-tr-none p-3 text-sm max-w-[85%]">
                    <p>${text}</p>
                </div>
            `;
        } else {
            innerHtml = `
                <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-sm shrink-0">🦉</div>
                <div class="bg-muted rounded-2xl rounded-tl-none p-3 text-sm max-w-[85%] prose-sm">
                    <p>${text}</p>
                </div>
            `;
        }
        
        msgDiv.innerHTML = innerHtml;
        chatMessages.appendChild(msgDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    };

    // Animation ou Loader pendant le temps de réflexion de l'IA
    const toggleTypingIndicator = (show) => {
        if (show) {
            const typingDiv = document.createElement('div');
            typingDiv.id = 'typing-indicator';
            typingDiv.className = 'flex gap-3 justify-start opacity-50';
            typingDiv.innerHTML = `
                <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-sm shrink-0">🦉</div>
                <div class="bg-muted rounded-2xl rounded-tl-none p-3 text-sm flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-foreground animate-pulse"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-foreground animate-pulse delay-75"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-foreground animate-pulse delay-150"></span>
                </div>
            `;
            chatMessages.appendChild(typingDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        } else {
            const typingDiv = document.getElementById('typing-indicator');
            if (typingDiv) typingDiv.remove();
        }
    };

    const sendMessage = async () => {
        const message = chatInput.value.trim();
        if (!message) return;
        
        // 1. Affiche le message de l'utilisateur
        addMessageToUI(message, true);
        chatInput.value = '';
        chatInput.disabled = true;
        
        // 2. Affiche le loader d'IA
        toggleTypingIndicator(true);

        // 3. Appel de notre Endpoint Symfony AI
        try {
            const response = await fetch('{{ path("coach_chat") }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ message: message, history: history })
            });

            const data = await response.json();
            toggleTypingIndicator(false);
            
            if (data.reply) {
                // Affiche la réponse dans l'interface
                addMessageToUI(data.reply, false);
                
                // Sauvegarde de l'historique de conversation
                history.push({ role: 'user', content: message });
                history.push({ role: 'model', content: data.reply });
            } else {
                addMessageToUI("Désolé, mais je n'arrive pas à me concentrer. Vérifie ton API KEY !", false);
            }
        } catch (e) {
            toggleTypingIndicator(false);
            addMessageToUI("Aïe, erreur réseau !", false);
            console.error(e);
        }
        
        chatInput.disabled = false;
        chatInput.focus();
    };

    chatSubmit.addEventListener('click', sendMessage);
    chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendMessage();
    });
});
</script>

{% endblock %}
