{% extends 'admin/layout.html.twig' %}

{% block title %}{{ calendar.title }}{% endblock %}

{% block content %}
    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
            <a href="{{ path('admin_calendar_index') }}" class="p-2 bg-white border border-slate-200 rounded-xl text-slate-400 hover:text-slate-600 transition-colors">
                <twig:ux:icon name="lucide:arrow-left" class="w-5 h-5" />
            </a>
            <div>
                <h1 class="text-3xl font-black text-slate-900">{{ calendar.title }}</h1>
                <div class="flex items-center gap-2 text-slate-500">
                    <twig:ux:icon name="lucide:users" class="w-4 h-4" />
                    <span class="text-sm">{{ calendar.cohorts|length }} promos associées</span>
                </div>
            </div>
        </div>
        
        <div class="flex items-center gap-3">
            <a href="{{ path('admin_calendar_edit', {'id': calendar.id}) }}" class="btn bg-white border border-slate-200 text-slate-700 px-4 py-2 rounded-xl font-bold hover:bg-slate-50 transition-colors flex items-center gap-2">
                <twig:ux:icon name="lucide:edit" class="w-4 h-4" />
                {{ 'Modifier' | trans }}
            </a>
            <a href="{{ path('admin_calendar_event_new', {'id': calendar.id}) }}" class="btn bg-primary text-white px-4 py-2 rounded-xl font-bold shadow-lg shadow-primary/20 hover:scale-105 transition-transform flex items-center gap-2">
                <twig:ux:icon name="lucide:plus" class="w-4 h-4" />
                {{ 'Ajouter un événement' | trans }}
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {# Stats / Infos Sidebar #}
        <div class="space-y-6">
            <div class="bg-white rounded-3xl border border-slate-200 p-6 shadow-sm">
                <h3 class="font-bold text-slate-900 mb-4">{{ 'Informations' | trans }}</h3>
                <div class="space-y-4">
                    {% if calendar.url %}
                        <div>
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">URL iCal</span>
                            <a href="{{ calendar.url }}" target="_blank" class="text-sm text-primary font-medium break-all hover:underline">{{ calendar.url }}</a>
                        </div>
                    {% endif %}
                    
                    <div>
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1">Description</span>
                        <p class="text-sm text-slate-600 italic">
                            {{ calendar.description ?: 'Aucune description fournie.' }}
                        </p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-3xl border border-slate-200 p-6 shadow-sm">
                <h3 class="font-bold text-slate-900 mb-4">{{ 'Promos associées' | trans }}</h3>
                <div class="space-y-3">
                    {% for cohort in calendar.cohorts %}
                        <a href="{{ path('admin_cohort_edit', {id: cohort.id}) }}" class="flex items-center justify-between p-3 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors group">
                            <span class="font-bold text-slate-700">{{ cohort.title }}</span>
                            <twig:ux:icon name="lucide:chevron-right" class="w-4 h-4 text-slate-300 group-hover:text-primary transition-colors" />
                        </a>
                    {% else %}
                        <p class="text-sm text-slate-400 italic text-center py-4">
                            Ce calendrier n'est encore associé à aucune promotion.
                        </p>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Events List #}
        <div class="lg:col-span-2">
            <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                    <h3 class="text-lg font-bold text-slate-900">{{ 'Événements programmés' | trans }}</h3>
                    <span class="bg-white px-3 py-1 rounded-full border border-slate-200 text-xs font-bold text-slate-500">
                        {{ calendar.events|length }} événements
                    </span>
                </div>

                <div class="divide-y divide-slate-100">
                    {% for event in calendar.events|sort((a, b) => a.startAt <=> b.startAt) %}
                        <div class="p-6 hover:bg-slate-50/50 transition-colors group">
                            <div class="flex items-start gap-4">
                                <div class="flex-shrink-0 w-14 h-14 bg-white border border-slate-200 rounded-2xl flex flex-col items-center justify-center text-center shadow-sm">
                                    <span class="text-[10px] font-black text-slate-400 uppercase leading-none mb-1">{{ event.startAt|date('M') }}</span>
                                    <span class="text-xl font-black text-slate-900 leading-none">{{ event.startAt|date('d') }}</span>
                                </div>

                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="px-2 py-0.5 rounded-lg bg-indigo-50 text-indigo-600 text-[10px] font-black uppercase tracking-wider">
                                            {{ event.type|trans }}
                                        </span>
                                        <span class="text-xs font-bold text-slate-400">
                                            {{ event.startAt|date('H:i') }} {% if event.endAt %} - {{ event.endAt|date('H:i') }}{% endif %}
                                        </span>
                                    </div>
                                    <h4 class="text-lg font-bold text-slate-900 truncate">{{ event.title }}</h4>
                                    {% if event.location %}
                                        <div class="flex items-center gap-1.5 mt-1 text-sm text-slate-500">
                                            <twig:ux:icon name="lucide:map-pin" class="w-3.5 h-3.5" />
                                            <span class="truncate">{{ event.location }}</span>
                                        </div>
                                    {% endif %}
                                </div>

                                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <form method="post" action="{{ path('admin_calendar_event_duplicate', {id: event.id}) }}" class="inline-block">
                                        <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ event.id) }}">
                                        <button title="Dupliquer" class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-white hover:shadow-sm rounded-lg transition-all">
                                            <twig:ux:icon name="lucide:copy" class="w-4 h-4" />
                                        </button>
                                    </form>
                                    <a href="{{ path('admin_calendar_event_edit', {id: event.id}) }}" class="p-2 text-slate-400 hover:text-primary hover:bg-white hover:shadow-sm rounded-lg transition-all">
                                        <twig:ux:icon name="lucide:edit-2" class="w-4 h-4" />
                                    </a>
                                    <form method="post" action="{{ path('admin_calendar_event_delete', {id: event.id}) }}" onsubmit="return confirm('Supprimer cet événement ?');" class="inline-block">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                                        <button class="p-2 text-slate-400 hover:text-red-600 hover:bg-white hover:shadow-sm rounded-lg transition-all">
                                            <twig:ux:icon name="lucide:trash-2" class="w-4 h-4" />
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="py-20 text-center">
                            <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-300">
                                <twig:ux:icon name="lucide:list-todo" class="w-8 h-8" />
                            </div>
                            <p class="text-slate-500 font-medium">{{ 'Aucun événement pour le moment.' | trans }}</p>
                            <a href="{{ path('admin_calendar_event_new', {'id': calendar.id}) }}" class="text-primary font-bold hover:underline mt-2 inline-block">
                                {{ 'Ajouter le premier événement' | trans }}
                            </a>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
