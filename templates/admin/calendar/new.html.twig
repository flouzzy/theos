{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Nouveau calendrier' | trans }}{% endblock %}

{% block content %}
    <div class="mb-8">
        <a href="{{ path('admin_calendar_index') }}" class="flex items-center gap-2 text-slate-500 hover:text-primary transition-colors mb-2 group">
            <twig:ux:icon name="lucide:arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
            {{ 'Retour à la liste' | trans }}
        </a>
        <h1 class="text-3xl font-black text-slate-900">{{ 'Créer un calendrier' | trans }}</h1>
    </div>

    <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden max-w-2xl">
        {{ include('admin/calendar/_form.html.twig') }}
    </div>
{% endblock %}
