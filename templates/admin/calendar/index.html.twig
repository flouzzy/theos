{% extends 'admin/layout.html.twig' %}

{% block menuBackButton %}
	<ion-button href="{{path('admin_calendar_index')}}">
		<ion-icon name="arrow-back-outline"></ion-icon>
		{{'Back' | trans}}
	</ion-button>
{% endblock %}

{% block title %}
	{{'Calendar' | trans}}
{% endblock %}

{% block content %}
	<h1>Calendar index</h1>

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Description</th>
				<th>Promotion</th>
				<th>Url</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for calendar in calendars %}
				<tr>
					<td>{{ calendar.id }}</td>
					<td>{{ calendar.description }}</td>
					<td>{{ calendar.cohort ? calendar.cohort.title : 'Aucune' }}</td>
					<td>{{ calendar.url }}</td>
					<td class="flex items-center gap-2">
						<a href="{{ path('admin_calendar_show', {'id': calendar.id}) }}" class="btn btn-sm btn-outline">{{ 'Détails' | trans }}</a>
						<a href="{{ path('admin_calendar_edit', {'id': calendar.id}) }}" class="btn btn-sm btn-primary">{{ 'Modifier' | trans }}</a>
                        <form method="post" action="{{ path('admin_calendar_duplicate', {'id': calendar.id}) }}" onsubmit="return confirm('Voulez-vous vraiment dupliquer ce calendrier ?');" style="display:inline-block">
                            <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ calendar.id) }}">
                            <button class="btn btn-sm btn-secondary cursor-pointer">{{ 'Dupliquer' | trans }}</button>
                        </form>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a href="{{ path('admin_calendar_new') }}">Create new</a>
{% endblock %}
