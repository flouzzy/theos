<ion-item-group>
	<ion-item-divider>
		<ion-label>
			{{'Completion percentage' | trans}}
		</ion-label>
	</ion-item-divider>
	<ion-item>
		<ion-label>
			{{'Completed courses' | trans}}
			({{user.courseCompletions | length}})
		</ion-label>
		{% for completion in user.courseCompletions %}
			<ion-item lines="none" href="{{ path('course_show', {slug:completion.course.slug}) }}">
				{{completion.course.title}}
			</ion-item>
		{% endfor %}
	</ion-item>
	<ion-item>
		<ion-label>
			{{'Completed modules' | trans}}
			({{user.moduleCompletions | length}})
		</ion-label>
		{% for completion in user.moduleCompletions %}
			<ion-item lines="none" href="{{ path('admin_module_show', {id:completion.module.id}) }}">
				{{completion.module.title}}
			</ion-item>
		{% endfor %}
	</ion-item>
	<ion-item>
		<ion-label>
			{{'Completed lessons' | trans}}
			({{user.completions | length}})
		</ion-label>
		{% for completion in user.completions %}
			<ion-item lines="none" href="{{ path('admin_lesson_show', {id:completion.lesson.id}) }}">
				{{completion.lesson.title}}
			</ion-item>
		{% endfor %}
	</ion-item>
</ion-item-group>
