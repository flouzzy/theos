{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{'Users' | trans}}
{% endblock %}

{% block content %}
	<div class="container mx-auto py-10">
		<div class="flex justify-between items-center mb-6">
			<h1 class="text-2xl font-bold tracking-tight">{{ 'Users'|trans }}</h1>
				<a href="{{ path('admin_user_new') }}">
					<twig:ux:icon name="lucide:plus" class="mr-2 h-4 w-4" />
					{{ 'New User'|trans }}
				</a>
		</div>

		<div class="rounded-md border">
			<twig:Table>
				<twig:Table:Header>
					<twig:Table:Row>
						<twig:Table:Head>{{ 'User'|trans }}</twig:Table:Head>
						<twig:Table:Head>{{ 'Roles'|trans }}</twig:Table:Head>
						<twig:Table:Head>{{ 'Status'|trans }}</twig:Table:Head>
						<twig:Table:Head>{{ 'Completion'|trans }}</twig:Table:Head>
						<twig:Table:Head class="text-right">{{ 'Actions'|trans }}</twig:Table:Head>
					</twig:Table:Row>
				</twig:Table:Header>
				<twig:Table:Body>
					{% for user in users %}
						<twig:Table:Row>
							<twig:Table:Cell class="font-medium">
								<div class="flex items-center gap-3">
									<twig:Avatar>
										<twig:Avatar:Image src="{{ asset(user.image) }}" alt="{{ user.fullname }}" />
										<twig:Avatar:Text>{{ user.fullname|slice(0, 2)|upper }}</twig:Avatar:Text>
									</twig:Avatar>
									<div class="flex flex-col">
										<span>{{ user.fullname }}</span>
										<span class="text-xs text-muted-foreground">{{ user.email }}</span>
									</div>
								</div>
							</twig:Table:Cell>
							<twig:Table:Cell>
								{% for role in user.roles %}
									{% if role != 'ROLE_USER' %}
										<twig:Badge variant="outline" class="mr-1 mb-1">{{ role|replace({'ROLE_': ''})|capitalize }}</twig:Badge>
									{% endif %}
								{% endfor %}
							</twig:Table:Cell>
							<twig:Table:Cell>
								{% if user.isVerified %}
									<twig:Badge variant="secondary" class="bg-green-100 text-green-800 hover:bg-green-100">Verified</twig:Badge>
								{% else %}
									<twig:Badge variant="secondary" class="bg-yellow-100 text-yellow-800 hover:bg-yellow-100">Pending</twig:Badge>
								{% endif %}
							</twig:Table:Cell>
							<twig:Table:Cell>
								<div class="text-sm">
									<div>{{ user.courseCompletions|filter(c => c.completed)|length }} Courses</div>
									<div>{{ user.moduleCompletions|filter(c => c.completed)|length }} Modules</div>
								</div>
							</twig:Table:Cell>
							<twig:Table:Cell class="text-right">
								<twig:Button variant="ghost" size="sm" asChild>
									<a href="{{ path('admin_user_edit', {id: user.id}) }}">Edit</a>
								</twig:Button>
							</twig:Table:Cell>
						</twig:Table:Row>
					{% else %}
						<twig:Table:Row>
							<twig:Table:Cell colspan="5" class="h-24 text-center">
								{{ 'No users found.'|trans }}
							</twig:Table:Cell>
						</twig:Table:Row>
					{% endfor %}
				</twig:Table:Body>
			</twig:Table>
		</div>

		<div class="mt-4 flex items-center justify-center space-x-2">
			{% if currentPage > 1 %}
				<a href="{{ path('admin_user_index', {page: currentPage - 1}) }}" class="px-3 py-1 border rounded hover:bg-gray-100">
					{{ 'Previous'|trans }}
				</a>
			{% endif %}

			<span class="px-3 py-1">
				{{ 'Page %current% of %total%'|trans({'%current%': currentPage, '%total%': totalPages}) }}
			</span>

			{% if currentPage < totalPages %}
				<a href="{{ path('admin_user_index', {page: currentPage + 1}) }}" class="px-3 py-1 border rounded hover:bg-gray-100">
					{{ 'Next'|trans }}
				</a>
			{% endif %}
		</div>
	</div>
{% endblock %}

