{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{'Users' | trans}}
{% endblock %}

{% block content %}
	<div class="ion-padding">
		<ion-grid>
			{% for user in users %}
				<ion-row>
					<ion-item href="{{path('admin_user_edit', {id:user.id})}}">
						<ion-col size="4">
							{{ user.fullname }}
						</ion-col>
						<ion-col size="4">
							{% if user.isVerified %}
								<ion-icon name="checkmark-circle-outline" color="app"></ion-icon>
							{% endif %}
							{{ user.email }}
						</ion-col>
						<ion-col>{{ user.roles ? user.roles|json_encode : '' }}</ion-col>
						<ion-col>{{ user.lastConnectionAt ? user.lastConnectionAt|date('Y-m-d H:i:s') : '' }}</ion-col>
					</ion-item>
				</ion-row>
			{% else %}
				<ion-row>
					<ion-col>{{'No item found' | trans}}</ion-col>
				</ion-row>
			{% endfor %}
		</ion-grid>
	</div>

	<ion-fab slot="fixed" vertical="bottom" horizontal="end">
		<ion-fab-button href="{{ path('admin_user_new') }}">
			<ion-icon name="add"></ion-icon>
		</ion-fab-button>
	</ion-fab>
{% endblock %}
