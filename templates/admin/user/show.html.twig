{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{user.fullname}}
{% endblock %}

{% block content %}
	<div class="ion-padding">
		<table class="table">
			<tbody>
				<tr>
					<th>Id</th>
					<td>{{ user.id }}</td>
				</tr>
				<tr>
					<th>Email</th>
					<td>{{ user.email }}</td>
				</tr>
				<tr>
					<th>Roles</th>
					<td>{{ user.roles ? user.roles|json_encode : '' }}</td>
				</tr>
				<tr>
					<th>Password</th>
					<td>{{ user.password }}</td>
				</tr>
				<tr>
					<th>IsVerified</th>
					<td>{{ user.isVerified ? 'Yes' : 'No' }}</td>
				</tr>
				<tr>
					<th>Firstname</th>
					<td>{{ user.firstname }}</td>
				</tr>
				<tr>
					<th>Lastname</th>
					<td>{{ user.lastname }}</td>
				</tr>
				<tr>
					<th>Fullname</th>
					<td>{{ user.fullname }}</td>
				</tr>
				<tr>
					<th>CreatedAt</th>
					<td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : '' }}</td>
				</tr>
				<tr>
					<th>UpdatedAt</th>
					<td>{{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
				</tr>
				<tr>
					<th>LastConnectionAt</th>
					<td>{{ user.lastConnectionAt ? user.lastConnectionAt|date('Y-m-d H:i:s') : '' }}</td>
				</tr>
				<tr>
					<th>Username</th>
					<td>{{ user.username }}</td>
				</tr>
				<tr>
					<th>Image</th>
					<td>{{ user.image }}</td>
				</tr>
				<tr>
					<th>Bio</th>
					<td>{{ user.bio }}</td>
				</tr>
			</tbody>
		</table>

		<a href="{{ path('admin_user_edit', {'id': user.id}) }}">edit</a>

		{{ include('admin/user/_delete_form.html.twig') }}
	</div>
{% endblock %}


{% block menuBackButton %}
	<ion-button href="{{path('admin_user_index')}}" color="light">
		<ion-icon name="arrow-back-outline"></ion-icon>
	</ion-button>
{% endblock %}
