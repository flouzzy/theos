{% extends 'admin/layout.html.twig' %}

{% block title %}{{ user.fullname }}{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="{{ user.fullname }}" 
        subtitle="{{ 'Détails du compte utilisateur' | trans }}"
        backPath="{{ path('admin_user_index') }}"
    />

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {# Main Info Card #}
        <div class="lg:col-span-2 space-y-8">
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <h3 class="font-bold text-slate-800">{{ 'Informations Générales' | trans }}</h3>
                </div>
                <div class="p-6">
                    <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'Nom complet' | trans }}</dt>
                            <dd class="mt-1 text-sm text-slate-900 font-semibold">{{ user.fullname }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'Email' | trans }}</dt>
                            <dd class="mt-1 text-sm text-slate-900 font-semibold">{{ user.email }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'Rôles' | trans }}</dt>
                            <dd class="mt-1 flex flex-wrap gap-1">
                                {% for role in user.roles %}
                                    <span class="px-2 py-0.5 rounded bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider border border-slate-200">
                                        {{ role|replace({'ROLE_': ''}) }}
                                    </span>
                                {% endfor %}
                            </dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'Statut' | trans }}</dt>
                            <dd class="mt-1">
                                {% if user.isVerified %}
                                    <twig:Badge variant="default" class="bg-emerald-50 text-emerald-700 border-emerald-100 shadow-none">
                                        {{ 'Vérifié' | trans }}
                                    </twig:Badge>
                                {% else %}
                                    <twig:Badge variant="outline" class="bg-amber-50 text-amber-700 border-amber-100 shadow-none">
                                        {{ 'En attente' | trans }}
                                    </twig:Badge>
                                {% endif %}
                            </dd>
                        </div>
                        <div class="md:col-span-2">
                            <dt class="text-sm font-medium text-slate-500">{{ 'Bio' | trans }}</dt>
                            <dd class="mt-1 text-sm text-slate-700 leading-relaxed">{{ user.bio|default('Aucune bio renseignée.'|trans) }}</dd>
                        </div>
                    </dl>
                </div>
            </div>

            {# Stats / Additional Info #}
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <h3 class="font-bold text-slate-800">{{ 'Historique des connexions' | trans }}</h3>
                </div>
                <div class="p-6">
                    <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'Créé le' | trans }}</dt>
                            <dd class="mt-1 text-sm text-slate-900">{{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : '-' }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'Dernière connexion' | trans }}</dt>
                            <dd class="mt-1 text-sm text-slate-900">{{ user.lastConnectionAt ? user.lastConnectionAt|date('d/m/Y H:i') : '-' }}</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>

        {# Sidebar Info #}
        <div class="space-y-8">
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 text-center">
                <div class="w-24 h-24 rounded-full bg-slate-100 mx-auto flex items-center justify-center text-slate-400 overflow-hidden border-4 border-white shadow-sm ring-1 ring-slate-100 mb-4">
                    {% if user.image %}
                        <img src="{{ asset(user.image) }}" alt="" class="w-full h-full object-cover">
                    {% else %}
                        <span class="text-2xl font-bold uppercase">{{ user.fullname|slice(0, 2) }}</span>
                    {% endif %}
                </div>
                <h2 class="text-lg font-bold text-slate-900">{{ user.fullname }}</h2>
                <p class="text-sm text-slate-500 mb-6">{{ user.email }}</p>
                
                <div class="flex flex-col gap-2">
                    <twig:Button as="a" href="{{ path('admin_user_edit', {'id': user.id}) }}" variant="default" class="w-full">
                        <twig:ux:icon name="lucide:pencil" class="w-4 h-4 mr-2" />
                        {{ 'Modifier le profil' | trans }}
                    </twig:Button>
                </div>
            </div>

            <div class="bg-emerald-50 rounded-xl p-6 border border-emerald-100">
                <h3 class="text-emerald-900 font-bold mb-2 flex items-center gap-2">
                    <twig:ux:icon name="lucide:award" class="w-5 h-5 text-emerald-600" />
                    {{ 'Progression' | trans }}
                </h3>
                <p class="text-emerald-700 text-sm mb-4">{{ 'Suivi pédagogique de l\'élève' | trans }}</p>
                <twig:Button as="a" href="#" variant="outline" class="w-full bg-white text-emerald-700 border-emerald-200 hover:bg-emerald-50">
                    {{ 'Voir les rapports' | trans }}
                </twig:Button>
            </div>

            <div class="bg-red-50 rounded-xl p-6 border border-red-100">
                <h3 class="text-red-900 font-bold mb-2">{{ 'Zone de danger' | trans }}</h3>
                <p class="text-red-700 text-sm mb-4">{{ 'Supprimer définitivement cet utilisateur.' | trans }}</p>
                {{ include('admin/user/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
