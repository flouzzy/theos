<form method="post" action="{{ path('admin_user_delete', {'id': user.id}) }}" onsubmit="return confirm('{{'Êtes-vous sûr de vouloir supprimer cet utilisateur ?' | trans}}');">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
	<twig:Button variant="destructive">
        <twig:ux:icon name="lucide:trash-2" class="w-4 h-4 mr-2" />
        {{ 'Supprimer' | trans }}
    </twig:Button>
</form>
