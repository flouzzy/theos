{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{page.title}}
{% endblock %}

{% block content %}

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ page.id }}</td>
			</tr>
			<tr>
				<th>Title</th>
				<td>{{ page.title }}</td>
			</tr>
			<tr>
				<th>Content</th>
				<td>{{ page.content }}</td>
			</tr>
			<tr>
				<th>Slug</th>
				<td>{{ page.slug }}</td>
			</tr>
			<tr>
				<th>CreatedAt</th>
				<td>{{ page.createdAt ? page.createdAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
			<tr>
				<th>UpdatedAt</th>
				<td>{{ page.updatedAt ? page.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('admin_page_edit', {'id': page.id}) }}">edit</a>

	{{ include('admin/page/_delete_form.html.twig') }}
{% endblock %}

{% block menuBackButton %}
	<ion-button href="{{path('admin_page_index')}}">
		<ion-icon name="arrow-back-outline"></ion-icon>
	</ion-button>
{% endblock %}
