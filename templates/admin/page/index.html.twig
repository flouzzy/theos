{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{'Pages' | trans}}
{% endblock %}

{% block content %}
	<div class="ion-padding-vertical">
		<table class=" table">
			<thead>
				<tr>
					<th>Id</th>
					<th>Title</th>
					<th>CreatedAt</th>
					<th>UpdatedAt</th>
					<th>actions</th>
				</tr>
			</thead>
			<tbody>
				{% for page in pages %}
					<tr>
						<td>{{ page.id }}</td>
						<td>{{ page.title }}</td>
						<td>{{ page.createdAt ? page.createdAt|date('Y-m-d H:i:s') : '' }}</td>
						<td>{{ page.updatedAt ? page.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
						<td>
							<a href="{{ path('admin_page_show', {'id': page.id}) }}">show</a>
							<a href="{{ path('admin_page_edit', {'id': page.id}) }}">edit</a>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="7">no records found</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>

		<a href="{{ path('admin_page_new') }}">Create new</a>
	</div>
{% endblock %}
