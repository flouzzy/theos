<div data-controller="editor" class="space-y-10">
    {{ form_start(form, {'attr': {'class': 'divide-y divide-slate-100 font-sans'}}) }}
        
        <div class="pb-8">
            <div class="flex items-center gap-2 mb-6">
                <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600">
                    <twig:ux:icon name="lucide:type" class="w-4 h-4" />
                </div>
                <h2 class="text-lg font-bold text-slate-800">{{ 'Informations Générales' | trans }}</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    {{ form_label(form.title, 'Titre de la page'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                    {{ form_widget(form.title, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-medium'}}) }}
                    {{ form_errors(form.title) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.slug, 'Slug URL'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                    {{ form_widget(form.slug, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-500 font-mono text-sm'}}) }}
                    {{ form_errors(form.slug) }}
                </div>
            </div>
        </div>

        <div class="py-8">
            <div class="flex items-center gap-2 mb-6">
                <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600">
                    <twig:ux:icon name="lucide:file-edit" class="w-4 h-4" />
                </div>
                <h2 class="text-lg font-bold text-slate-800">{{ 'Contenu de la Page' | trans }}</h2>
            </div>
            <div class="space-y-2 prose prose-slate max-w-none">
                {{ form_label(form.content, 'Corps de la page'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                <div class="rounded-xl border border-slate-200 overflow-hidden focus-within:ring-4 focus-within:ring-primary/10 transition-all">
                    {{ form_widget(form.content, {'attr': {'class': 'text-editor'}}) }}
                </div>
                {{ form_errors(form.content) }}
            </div>
        </div>

        <div class="pt-8 flex items-center justify-end gap-4">
            <twig:Button as="a" href="{{ path('admin_page_index') }}" variant="ghost" class="text-slate-500 hover:bg-slate-100">
                {{ 'Annuler' | trans }}
            </twig:Button>
            <twig:Button type="submit" variant="default" class="px-8 py-3 shadow-lg shadow-primary/20 hover:scale-105 transition-all">
                <twig:ux:icon name="lucide:save" class="w-5 h-5 mr-2" />
                {{ button_label|default('Enregistrer')|trans }}
            </twig:Button>
        </div>
    {{ form_end(form) }}
</div>
