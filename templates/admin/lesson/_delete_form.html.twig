<ion-item>
	<form method="post" action="{{ path('admin_lesson_delete', {'id': lesson.id}) }}" onsubmit="return confirm('{{'Are you sure you want to delete this item ?' | trans}}');">
		<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ lesson.id) }}">
		<ion-button type="submit" color="danger">
			{{'Delete' | trans}}
		</ion-button>
	</form>
</ion-item>
