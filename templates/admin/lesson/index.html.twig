{% extends 'admin/layout.html.twig' %}

{% block title %}
    {{ 'Lessons' | trans }}
{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="Leçons" 
        subtitle="Gérez le contenu pédagogique de vos modules"
        addPath="{{ path('admin_lesson_new') }}"
        addLabel="Nouvelle Leçon"
    />

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <twig:Table>
            <twig:Table:Head>
                <twig:Table:Row>
                    <twig:Table:Header class="w-16">Id</twig:Table:Header>
                    <twig:Table:Header>{{ 'Titre' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Module' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Ordre' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Statut' | trans }}</twig:Table:Header>
                    <twig:Table:Header class="text-right">{{ 'Actions' | trans }}</twig:Table:Header>
                </twig:Table:Row>
            </twig:Table:Head>
            <twig:Table:Body>
                {% for lesson in lessons %}
                    <twig:Table:Row class="hover:bg-slate-50/50 transition-colors">
                        <twig:Table:Cell class="font-medium text-slate-500 w-16">#{{ lesson.id }}</twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="font-semibold text-slate-900">{{ lesson.title }}</div>
                            <div class="text-[10px] text-slate-400 truncate max-w-xs">{{ lesson.description|u.truncate(60, '...') }}</div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="flex items-center gap-2">
                                <twig:ux:icon name="lucide:layers" class="w-3.5 h-3.5 text-slate-400" />
                                <span class="text-xs text-slate-600 font-medium">{{ lesson.module.title }}</span>
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <span class="px-2 py-1 rounded-md bg-slate-50 text-slate-600 border border-slate-200 text-[10px] font-bold font-mono">
                                {{ lesson.itemOrder }}
                            </span>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            {% if lesson.status == 'published' %}
                                <twig:Badge variant="default" class="bg-emerald-50 text-emerald-700 border-emerald-100 shadow-none text-[10px] font-bold uppercase">
                                    {{ 'Publié' | trans }}
                                </twig:Badge>
                            {% else %}
                                <twig:Badge variant="outline" class="bg-slate-50 text-slate-500 border-slate-200 shadow-none text-[10px] font-bold uppercase">
                                    {{ 'Brouillon' | trans }}
                                </twig:Badge>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                <twig:Button as="a" href="{{ path('admin_lesson_show', {'id': lesson.id}) }}" variant="ghost" size="icon-sm" title="{{ 'Voir' | trans }}">
                                    <twig:ux:icon name="lucide:eye" class="w-4 h-4" />
                                </twig:Button>
                                <twig:Button as="a" href="{{ path('admin_lesson_edit', {'id': lesson.id}) }}" variant="outline" size="icon-sm" title="{{ 'Modifier' | trans }}">
                                    <twig:ux:icon name="lucide:pencil" class="w-4 h-4 text-slate-600" />
                                </twig:Button>
                            </div>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% else %}
                    <twig:Table:Row>
                        <twig:Table:Cell colspan="6" class="py-12 text-center text-slate-400">
                            {{ 'Aucun enregistrement trouvé' | trans }}
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>
    </div>
{% endblock %}
