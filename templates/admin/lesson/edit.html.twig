{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Modifier la Leçon' | trans }}{% endblock %}

{% block content %}
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="flex items-start gap-5">
            <div class="mt-1">
                <twig:Button as="a" href="{{ path('admin_lesson_index') }}" variant="outline" size="icon" class="rounded-xl shadow-sm hover:bg-white hover:text-primary transition-all">
                    <twig:ux:icon name="lucide:chevron-left" class="w-5 h-5" />
                </twig:Button>
            </div>
            <div>
                <nav class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">
                    <a href="{{ path('admin_course_index') }}" class="hover:text-primary transition-colors">{{ lesson.module.course.title }}</a>
                    <twig:ux:icon name="lucide:chevron-right" class="w-3 h-3" />
                    <a href="{{ path('admin_module_index') }}" class="hover:text-primary transition-colors">{{ lesson.module.title }}</a>
                </nav>
                <h1 class="text-4xl font-black text-slate-900 leading-tight">
                    {{ 'Modifier la Leçon' | trans }}
                </h1>
                <p class="text-slate-500 font-medium mt-1">
                    <span class="text-primary/70">#{{ lesson.itemOrder }}</span> — {{ lesson.title }}
                </p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <twig:Button as="a" href="{{ path('lesson_show', {
                'courseSlug': lesson.module.course.slug,
                'moduleSlug': lesson.module.slug,
                'lessonId': lesson.id
            }) }}" target="_blank" variant="ghost" class="text-slate-600 hover:text-primary">
                <twig:ux:icon name="lucide:external-link" class="w-4 h-4 mr-2" />
                {{ 'Voir en direct' | trans }}
            </twig:Button>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-8 max-w-5xl mx-auto">
        {# Colonne Principale : Formulaire #}
        <div class="xl:col-span-3 space-y-8">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="p-8">
                    {{ include('admin/lesson/_form.html.twig', {'button_label': 'Mettre à jour la leçon'}) }}
                </div>
            </div>
        </div>

            {# Colonne Latérale : Actions & Stats #}
        <div class="space-y-8">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                    <twig:ux:icon name="lucide:mic" class="w-4 h-4 text-indigo-600" />
                    {{ 'Audio par IA' | trans }}
                </h3>
                
                {% if lesson.audioPath %}
                    <div class="mb-4 p-3 bg-indigo-50 border border-indigo-100 rounded-xl">
                        <div class="flex items-center gap-2 text-indigo-700 text-xs font-bold uppercase mb-2">
                            <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                            Audio disponible
                        </div>
                        <audio controls class="w-full h-8">
                            <source src="{{ asset(lesson.audioPath) }}" type="audio/mpeg">
                        </audio>
                    </div>
                {% else %}
                    <p class="text-slate-500 text-xs mb-4">
                        {{ 'Aucune version audio générée pour le moment.' | trans }}
                    </p>
                {% endif %}

                <form action="{{ path('admin_lesson_generate_audio', {id: lesson.id}) }}" method="POST">
                    <twig:Button type="submit" variant="outline" class="w-full justify-center gap-2 border-indigo-200 text-indigo-700 hover:bg-indigo-50">
                        <twig:ux:icon name="lucide:sparkles" class="w-4 h-4" />
                        {{ lesson.audioPath ? 'Régénérer l\'audio' : 'Générer l\'audio' | trans }}
                    </twig:Button>
                </form>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                    <twig:ux:icon name="lucide:link" class="w-4 h-4 text-amber-600" />
                    {{ 'Recommandations IA' | trans }}
                </h3>
                
                {% if lesson.embeddings %}
                    <div class="mb-4 p-3 bg-amber-50 border border-amber-100 rounded-xl">
                        <div class="flex items-center gap-2 text-amber-700 text-xs font-bold uppercase">
                            <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                            Indexé pour recommandations
                        </div>
                    </div>
                {% else %}
                    <p class="text-slate-500 text-xs mb-4">
                        {{ 'Cette leçon n\'a pas encore d\'embedding.' | trans }}
                    </p>
                {% endif %}

                <form action="{{ path('admin_lesson_generate_embedding', {id: lesson.id}) }}" method="POST">
                    <twig:Button type="submit" variant="outline" class="w-full justify-center gap-2 border-amber-200 text-amber-700 hover:bg-amber-50">
                        <twig:ux:icon name="lucide:brain" class="w-4 h-4" />
                        {{ lesson.embeddings ? 'Mettre à jour l\'index' : 'Générer l\'embedding' | trans }}
                    </twig:Button>
                </form>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                    <twig:ux:icon name="lucide:clipboard-check" class="w-4 h-4 text-emerald-600" />
                    {{ 'Quiz par IA' | trans }}
                </h3>
                
                {% set quizCount = lesson.quizzes|length %}
                <p class="text-slate-500 text-xs mb-4">
                    {{ quizCount > 0 ? (quizCount ~ ' quiz(zes) déjà présent(s).') : 'Générez un quiz de 5 questions automatiquement.' | trans }}
                </p>

                <form action="{{ path('admin_ai_quiz_generate', {id: lesson.id}) }}" method="POST">
                    <twig:Button type="submit" variant="outline" class="w-full justify-center gap-2 border-emerald-200 text-emerald-700 hover:bg-emerald-50">
                        <twig:ux:icon name="lucide:brain-circuit" class="w-4 h-4" />
                        {{ 'Générer un Quiz (Gemini)' | trans }}
                    </twig:Button>
                </form>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                    <twig:ux:icon name="lucide:info" class="w-4 h-4 text-primary" />
                    {{ 'Informations' | trans }}
                </h3>
                <div class="space-y-4">
                    <div class="flex justify-between text-sm py-2 border-b border-slate-50">
                        <span class="text-slate-500">{{ 'Dernière modif' | trans }}</span>
                        <span class="text-slate-900 font-semibold">{{ lesson.updatedAt|date('d/m/Y H:i') }}</span>
                    </div>
                    <div class="flex justify-between text-sm py-2 border-b border-slate-50">
                        <span class="text-slate-500">{{ 'Créée le' | trans }}</span>
                        <span class="text-slate-900 font-semibold">{{ lesson.createdAt|date('d/m/Y') }}</span>
                    </div>
                </div>
            </div>

            <div class="bg-red-50 rounded-2xl p-6 border border-red-100">
                <h3 class="text-red-900 font-bold mb-2 flex items-center gap-2">
                    <twig:ux:icon name="lucide:alert-triangle" class="w-4 h-4 text-red-600" />
                    {{ 'Zone de danger' | trans }}
                </h3>
                <p class="text-red-700 text-xs mb-4">{{ 'La suppression de cette leçon est irréversible et affectera la progression des étudiants.' | trans }}</p>
                {{ include('admin/lesson/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
