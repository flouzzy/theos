<ion-item>
	<form method="post" action="{{ path('admin_notification_delete', {'id': notification.id}) }}" onsubmit="return confirm('{{ 'Êtes-vous sûr de vouloir supprimer cette notification ?'|trans }}');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ notification.id) }}">
    <twig:Button variant="destructive" class="w-full">
        <twig:ux:icon name="lucide:trash-2" class="w-4 h-4 mr-2" />
        {{ 'Supprimer' | trans }}
    </twig:Button>
</form>
</ion-item>
