{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Nouvelle Notification' | trans }}{% endblock %}

{% block content %}
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="flex items-start gap-5">
            <div class="mt-1">
                <twig:Button as="a" href="{{ path('admin_notification_index') }}" variant="outline" size="icon" class="rounded-xl shadow-sm hover:bg-white hover:text-primary transition-all">
                    <twig:ux:icon name="lucide:chevron-left" class="w-5 h-5" />
                </twig:Button>
            </div>
            <div>
                <nav class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">
                    <span>{{ 'Administration' | trans }}</span>
                    <twig:ux:icon name="lucide:chevron-right" class="w-3 h-3" />
                    <a href="{{ path('admin_notification_index') }}" class="hover:text-primary transition-colors">{{ 'Notifications' | trans }}</a>
                </nav>
                <h1 class="text-4xl font-black text-slate-900 leading-tight">
                    {{ 'Envoyer une Alerte' | trans }}
                </h1>
                <p class="text-slate-500 font-medium mt-1">
                    {{ 'Créez une notification système pour informer un étudiant' | trans }}
                </p>
            </div>
        </div>
    </div>

    <div class="max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="p-8">
                {{ include('admin/notification/_form.html.twig', {'button_label': 'Diffuser la notification'}) }}
            </div>
        </div>
    </div>
{% endblock %}
