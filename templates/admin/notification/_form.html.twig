{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
    
    <div class="flex items-center gap-2 mb-6">
        <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center text-red-600">
            <twig:ux:icon name="lucide:bell" class="w-4 h-4" />
        </div>
        <h2 class="text-lg font-bold text-slate-800">{{ 'Détails de la Notification' | trans }}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-6 border-b border-slate-100">
        <div class="space-y-2">
            {{ form_label(form.user, 'Destinataire'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
            {{ form_widget(form.user, {'attr': {'class': 'w-full px-4 py-2 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-sm'}}) }}
            {{ form_errors(form.user) }}
        </div>
        <div class="space-y-2">
            {{ form_label(form.title, 'Titre de l\'alerte'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
            {{ form_widget(form.title, {'attr': {'class': 'w-full px-4 py-2 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-bold', 'placeholder': 'Ex: Nouvelle leçon disponible'}}) }}
            {{ form_errors(form.title) }}
        </div>
    </div>

    <div class="pt-6 space-y-2">
        {{ form_label(form.message, 'Message de la notification'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
        {{ form_widget(form.message, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-700 leading-relaxed', 'rows': 5, 'placeholder': 'Écrivez ici le message...'}}) }}
        {{ form_errors(form.message) }}
    </div>

    <div class="pt-10 flex items-center justify-end gap-4">
        <twig:Button as="a" href="{{ path('admin_notification_index') }}" variant="ghost" class="text-slate-500 hover:bg-slate-100">
            {{ 'Annuler' | trans }}
        </twig:Button>
        <twig:Button type="submit" variant="default" class="px-8 py-3 shadow-lg shadow-primary/20 hover:scale-105 transition-all text-white bg-red-600 border-none hover:bg-red-700">
            <twig:ux:icon name="lucide:send" class="w-5 h-5 mr-2" />
            {{ button_label|default('Envoyer la notification')|trans }}
        </twig:Button>
    </div>
{{ form_end(form) }}
