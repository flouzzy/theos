{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{'Notifications' | trans}}
{% endblock %}

{% block content %}

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Message</th>
				<th>Title</th>
				<th>{{'Created at' | trans}}</th>
				<th>{{'Sent at' | trans}}</th>
				<th>{{'Send at' | trans}}</th>
				<th>IsRead</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for notification in notifications %}
				<tr>
					<td>{{ notification.id }}</td>
					<td>{{ notification.message | sanitize_html }}</td>
					<td>{{ notification.title }}</td>
					<td>{{ notification.createdAt ? notification.createdAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>{{ notification.sentAt ? notification.sentAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>{{ notification.sendAt ? notification.sendAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>{{ notification.isRead ? 'Yes' : 'No' }}</td>
					<td>
						<a href="{{ path('admin_notification_show', {'id': notification.id}) }}">show</a>
						<a href="{{ path('admin_notification_edit', {'id': notification.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="8">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<ion-fab slot="fixed" vertical="bottom" horizontal="end">
		<ion-fab-button href="{{ path('admin_notification_new') }}">
			<ion-icon name="add"></ion-icon>
		</ion-fab-button>
	</ion-fab>
{% endblock %}
