{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Notifications' | trans }}{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="Notifications" 
        subtitle="Gérez les messages système et les alertes envoyées aux utilisateurs"
        addPath="{{ path('admin_notification_new') }}"
        addLabel="Nouvelle Notification"
    />

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <twig:Table>
            <twig:Table:Head>
                <twig:Table:Row>
                    <twig:Table:Header class="w-16">Id</twig:Table:Header>
                    <twig:Table:Header>{{ 'Message' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Titre' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Statut' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Dates' | trans }}</twig:Table:Header>
                    <twig:Table:Header class="text-right">{{ 'Actions' | trans }}</twig:Table:Header>
                </twig:Table:Row>
            </twig:Table:Head>
            <twig:Table:Body>
                {% for notification in notifications %}
                    <twig:Table:Row class="hover:bg-slate-50/50 transition-colors">
                        <twig:Table:Cell class="font-medium text-slate-500 w-16">#{{ notification.id }}</twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="text-xs text-slate-500 line-clamp-1 max-w-sm italic">
                                {{ notification.message|default('')|raw }}
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <span class="font-semibold text-slate-900">{{ notification.title }}</span>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            {% if notification.isRead %}
                                <twig:Badge variant="outline" class="bg-slate-50 text-slate-400 border-slate-200 shadow-none text-[9px] font-bold uppercase">
                                    {{ 'Lu' | trans }}
                                </twig:Badge>
                            {% else %}
                                <twig:Badge variant="default" class="bg-blue-50 text-blue-700 border-blue-100 shadow-none text-[9px] font-bold uppercase">
                                    {{ 'Non lu' | trans }}
                                </twig:Badge>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="text-[10px] space-y-1">
                                <div class="text-slate-400 flex items-center gap-1">
                                    <twig:ux:icon name="lucide:calendar" class="w-3 h-3" />
                                    {{ notification.createdAt|date('d/m/Y H:i') }}
                                </div>
                                {% if notification.sentAt %}
                                    <div class="text-emerald-500 flex items-center gap-1 font-semibold">
                                        <twig:ux:icon name="lucide:send" class="w-3 h-3" />
                                        {{ notification.sentAt|date('d/m/Y H:i') }}
                                    </div>
                                {% endif %}
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                <twig:Button as="a" href="{{ path('admin_notification_show', {'id': notification.id}) }}" variant="ghost" size="icon-sm" title="{{ 'Voir' | trans }}">
                                    <twig:ux:icon name="lucide:eye" class="w-4 h-4" />
                                </twig:Button>
                                <twig:Button as="a" href="{{ path('admin_notification_edit', {'id': notification.id}) }}" variant="outline" size="icon-sm" title="{{ 'Modifier' | trans }}">
                                    <twig:ux:icon name="lucide:pencil" class="w-4 h-4 text-slate-600" />
                                </twig:Button>
                            </div>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% else %}
                    <twig:Table:Row>
                        <twig:Table:Cell colspan="6" class="py-12 text-center text-slate-400">
                            {{ 'Aucune notification trouvée' | trans }}
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>
    </div>

    <twig:Pagination
        currentPage="{{ currentPage }}"
        totalPages="{{ totalPages }}"
        routeName="admin_notification_index"
    />
{% endblock %}
