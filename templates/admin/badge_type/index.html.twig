{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Types de Badges' | trans }}{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="{{ 'Types de Badges' | trans }}" 
        subtitle="Définissez les badges et les récompenses pour les étudiants"
        addPath="{{ path('admin_badge_type_new') }}"
        addLabel="Nouveau Badge"
    />

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <twig:Table>
            <twig:Table:Head>
                <twig:Table:Row>
                    <twig:Table:Header class="w-16">Id</twig:Table:Header>
                    <twig:Table:Header>{{ 'Aperçu' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Titre' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Code / Identifiant' | trans }}</twig:Table:Header>
                    <twig:Table:Header class="text-right">{{ 'Actions' | trans }}</twig:Table:Header>
                </twig:Table:Row>
            </twig:Table:Head>
            <twig:Table:Body>
                {% for badge_type in badge_types %}
                    <twig:Table:Row class="hover:bg-slate-50/50 transition-colors group">
                        <twig:Table:Cell class="font-medium text-slate-500 w-16">#{{ badge_type.id }}</twig:Table:Cell>
                        <twig:Table:Cell class="w-20">
                            <div class="w-12 h-12 rounded-full bg-slate-100 border border-slate-200 overflow-hidden flex items-center justify-center p-2 group-hover:scale-110 transition-transform shadow-sm">
                                {% if badge_type.image %}
                                    <img src="{{ badge_type.image }}" alt="{{ badge_type.title }}" class="w-full h-full object-contain">
                                {% else %}
                                    <twig:ux:icon name="lucide:award" class="w-6 h-6 text-slate-400" />
                                {% endif %}
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="flex flex-col">
                                <span class="font-semibold text-slate-900">{{ badge_type.title }}</span>
                                <span class="text-xs text-slate-500 line-clamp-1">{{ badge_type.description }}</span>
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <code class="text-[10px] bg-slate-100 px-1.5 py-0.5 rounded text-slate-600 font-mono border border-slate-200">
                                {{ badge_type.code }}
                            </code>
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                <twig:Button as="a" href="{{ path('admin_badge_type_show', {'id': badge_type.id}) }}" variant="ghost" size="icon-sm" title="{{ 'Voir' | trans }}">
                                    <twig:ux:icon name="lucide:eye" class="w-4 h-4" />
                                </twig:Button>
                                <twig:Button as="a" href="{{ path('admin_badge_type_edit', {'id': badge_type.id}) }}" variant="outline" size="icon-sm" title="{{ 'Modifier' | trans }}">
                                    <twig:ux:icon name="lucide:pencil" class="w-4 h-4 text-slate-600" />
                                </twig:Button>
                            </div>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% else %}
                    <twig:Table:Row>
                        <twig:Table:Cell colspan="5" class="py-12 text-center text-slate-400 italic">
                            {{ 'Aucun badge défini' | trans }}
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>
    </div>
{% endblock %}
