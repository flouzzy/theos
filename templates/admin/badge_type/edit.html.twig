{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Modifier le Badge' | trans }}{% endblock %}

{% block content %}
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="flex items-start gap-5">
            <div class="mt-1">
                <twig:Button as="a" href="{{ path('admin_badge_type_index') }}" variant="outline" size="icon" class="rounded-xl shadow-sm hover:bg-white hover:text-primary transition-all">
                    <twig:ux:icon name="lucide:chevron-left" class="w-5 h-5" />
                </twig:Button>
            </div>
            <div>
                <nav class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">
                    <span>{{ 'Administration' | trans }}</span>
                    <twig:ux:icon name="lucide:chevron-right" class="w-3 h-3" />
                    <a href="{{ path('admin_badge_type_index') }}" class="hover:text-primary transition-colors">{{ 'Badges' | trans }}</a>
                </nav>
                <h1 class="text-4xl font-black text-slate-900 leading-tight">
                    {{ 'Modifier le Badge' | trans }}
                </h1>
                <p class="text-slate-500 font-medium mt-1">
                    {{ badge_type.title }} — <span class="text-xs font-mono bg-slate-100 px-2 py-0.5 rounded text-slate-600">{{ badge_type.code }}</span>
                </p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-8 max-w-[1600px] mx-auto">
        <div class="xl:col-span-3">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="p-8">
                    {{ include('admin/badge_type/_form.html.twig', {'button_label': 'Mettre à jour le badge'}) }}
                </div>
            </div>
        </div>

        <div class="space-y-8">
            {# Achievement Preview #}
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 text-center">
                <div class="w-20 h-20 mx-auto rounded-full bg-yellow-50 flex items-center justify-center text-yellow-600 mb-4 border-4 border-yellow-100 shadow-inner">
                    <twig:ux:icon name="lucide:award" class="w-10 h-10" />
                </div>
                <h3 class="font-bold text-slate-800 mb-1">{{ badge_type.title }}</h3>
                <p class="text-xs text-slate-500 italic">{{ 'Aperçu du badge' | trans }}</p>
            </div>

            <div class="bg-red-50 rounded-2xl p-6 border border-red-100">
                <h3 class="text-red-900 font-bold mb-2 flex items-center gap-2">
                    <twig:ux:icon name="lucide:alert-triangle" class="w-4 h-4 text-red-600" />
                    {{ 'Zone de danger' | trans }}
                </h3>
                <p class="text-red-700 text-xs mb-4">{{ 'La suppression d\'un type de badge affectera tous les utilisateurs l\'ayant déjà obtenu.' | trans }}</p>
                {{ include('admin/badge_type/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
