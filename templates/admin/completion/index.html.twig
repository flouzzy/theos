{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Statuts de complétion' | trans }}{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="{{ 'Statuts de complétion' | trans }}" 
        subtitle="Suivez l'avancement des étudiants par cours, module et leçon"
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {# Section Leçons #}
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden flex flex-col">
            <div class="p-6 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
                <h3 class="font-bold text-slate-800 flex items-center gap-2">
                    <twig:ux:icon name="lucide:book-open" class="w-5 h-5 text-primary" />
                    {{ 'Leçons' | trans }}
                </h3>
                <twig:Button as="a" href="{{ path('admin_completion_lesson') }}" variant="ghost" size="sm">
                    {{ 'Voir tout' | trans }}
                </twig:Button>
            </div>
            <div class="p-4 flex-1">
                <div class="space-y-3">
                    {% for completion in lessonsCompletion|slice(0, 5) %}
                        <div class="flex items-center justify-between p-3 rounded-lg bg-slate-50 border border-slate-100">
                            <div class="flex flex-col">
                                <span class="text-sm font-semibold text-slate-900 line-clamp-1">{{ completion.lesson?.title ?? 'Leçon Inconnue' }}</span>
                                <span class="text-xs text-slate-500">{{ completion.user?.fullname ?? 'Utilisateur Inconnu' }}</span>
                            </div>
                            <twig:Badge variant="outline" class="bg-green-50 text-green-700 border-green-200 text-[10px]">
                                {{ 'Complété' | trans }}
                            </twig:Badge>
                        </div>
                    {% else %}
                        <p class="text-center py-8 text-slate-400 text-sm italic">{{ 'Aucune donnée' | trans }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Section Modules #}
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden flex flex-col">
            <div class="p-6 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
                <h3 class="font-bold text-slate-800 flex items-center gap-2">
                    <twig:ux:icon name="lucide:layers" class="w-5 h-5 text-primary" />
                    {{ 'Modules' | trans }}
                </h3>
                <twig:Button as="a" href="{{ path('admin_completion_module') }}" variant="ghost" size="sm">
                    {{ 'Voir tout' | trans }}
                </twig:Button>
            </div>
            <div class="p-4 flex-1">
                <div class="space-y-3">
                    {% for completion in modulesCompletion|slice(0, 5) %}
                        <div class="flex items-center justify-between p-3 rounded-lg bg-slate-50 border border-slate-100">
                            <div class="flex flex-col">
                                <span class="text-sm font-semibold text-slate-900 line-clamp-1">{{ completion.module?.title ?? 'Module Inconnu' }}</span>
                                <span class="text-xs text-slate-500">{{ completion.user?.fullname ?? 'Utilisateur Inconnu' }}</span>
                            </div>
                            <twig:Badge variant="outline" class="bg-blue-50 text-blue-700 border-blue-200 text-[10px]">
                                {{ 'Complété' | trans }}
                            </twig:Badge>
                        </div>
                    {% else %}
                        <p class="text-center py-8 text-slate-400 text-sm italic">{{ 'Aucune donnée' | trans }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Section Cours #}
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden flex flex-col">
            <div class="p-6 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
                <h3 class="font-bold text-slate-800 flex items-center gap-2">
                    <twig:ux:icon name="lucide:graduation-cap" class="w-5 h-5 text-primary" />
                    {{ 'Cours' | trans }}
                </h3>
                <twig:Button as="a" href="{{ path('admin_completion_course') }}" variant="ghost" size="sm">
                    {{ 'Voir tout' | trans }}
                </twig:Button>
            </div>
            <div class="p-4 flex-1">
                <div class="space-y-3">
                    {% for completion in coursesCompletion|slice(0, 5) %}
                        <div class="flex items-center justify-between p-3 rounded-lg bg-slate-50 border border-slate-100">
                            <div class="flex flex-col">
                                <span class="text-sm font-semibold text-slate-900 line-clamp-1">{{ completion.course?.title ?? 'Cours Inconnu' }}</span>
                                <span class="text-xs text-slate-500">{{ completion.user?.fullname ?? 'Utilisateur Inconnu' }}</span>
                            </div>
                            <twig:Badge variant="outline" class="bg-purple-50 text-purple-700 border-purple-200 text-[10px]">
                                {{ 'Complété' | trans }}
                            </twig:Badge>
                        </div>
                    {% else %}
                        <p class="text-center py-8 text-slate-400 text-sm italic">{{ 'Aucune donnée' | trans }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
