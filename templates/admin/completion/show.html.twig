{% extends 'admin/layout.html.twig' %}

{% block title %}{{ title | trans }}{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="{{ title | trans }}" 
        subtitle="{{ 'Historique complet des complétions' | trans }}"
        backPath="{{ path('admin_completion_index') }}"
    />

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <twig:Table>
            <twig:Table:Head>
                <twig:Table:Row>
                    <twig:Table:Header>{{ 'Élément' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Étudiant' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Date de complétion' | trans }}</twig:Table:Header>
                    <twig:Table:Header class="text-right">{{ 'Statut' | trans }}</twig:Table:Header>
                </twig:Table:Row>
            </twig:Table:Head>
            <twig:Table:Body>
                {% for completion in completions %}
                    {% set completionData = attribute(completion, completionType) %}
                    <twig:Table:Row class="hover:bg-slate-50/50 transition-colors">
                        <twig:Table:Cell>
                            <span class="font-semibold text-slate-900">{{ completionData?.title ?? 'Élément Inconnu' }}</span>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="flex items-center gap-2">
                                <twig:UserAvatar user="{{ completion.user }}" size="sm" />
                                <span class="text-sm text-slate-600">{{ completion.user?.fullname ?? 'Utilisateur Inconnu' }}</span>
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <span class="text-xs text-slate-400">
                                {{ completion.createdAt|date('d/m/Y H:i') }}
                            </span>
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-right">
                            <twig:Badge variant="outline" class="bg-green-50 text-green-700 border-green-200">
                                {{ 'Terminé' | trans }}
                            </twig:Badge>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% else %}
                    <twig:Table:Row>
                        <twig:Table:Cell colspan="4" class="py-12 text-center text-slate-400 italic">
                            {{ 'Aucun enregistrement trouvé' | trans }}
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>

        {% if totalPages is defined and totalPages > 1 %}
            <div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex items-center justify-between">
                <div class="text-sm text-slate-500">
                    {{ 'Page %current% sur %total%'|trans({'%current%': currentPage, '%total%': totalPages}) }}
                </div>
                <div class="flex items-center gap-2">
                    {% if currentPage > 1 %}
                        <twig:Button as="a" href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({'page': currentPage - 1})) }}" variant="outline" size="sm">
                            <twig:ux:icon name="lucide:chevron-left" class="w-4 h-4 mr-1" />
                            {{ 'Précédent'|trans }}
                        </twig:Button>
                    {% endif %}

                    {% if currentPage < totalPages %}
                        <twig:Button as="a" href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({'page': currentPage + 1})) }}" variant="outline" size="sm">
                            {{ 'Suivant'|trans }}
                            <twig:ux:icon name="lucide:chevron-right" class="w-4 h-4 ml-1" />
                        </twig:Button>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
