{% extends 'admin/layout.html.twig' %}

{% block title %}
    {{ 'Paramètres Brevo' | trans }}
{% endblock %}

{% block content %}
    <div class="p-4">
        <h1 class="text-2xl font-bold mb-6 text-white">{{ 'Configuration des listes Brevo' | trans }}</h1>
        
        {{ form_start(form) }}
            <div class="space-y-4">
                <div class="bg-dark p-4 rounded-lg shadow">
                    <div class="mb-4">
                        {{ form_label(form.brevoListOnboarded, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-1'}}) }}
                        {{ form_widget(form.brevoListOnboarded, {'attr': {'class': 'w-full bg-gray-800 text-white border-gray-700 rounded-md shadow-sm focus:border-indigo-500 focus:ring-indigo-500'}}) }}
                        {{ form_help(form.brevoListOnboarded, {'help_attr': {'class': 'mt-1 text-xs text-gray-400'}}) }}
                        {{ form_errors(form.brevoListOnboarded) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.brevoListAlumni, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-1'}}) }}
                        {{ form_widget(form.brevoListAlumni, {'attr': {'class': 'w-full bg-gray-800 text-white border-gray-700 rounded-md shadow-sm focus:border-indigo-500 focus:ring-indigo-500'}}) }}
                        {{ form_help(form.brevoListAlumni, {'help_attr': {'class': 'mt-1 text-xs text-gray-400'}}) }}
                        {{ form_errors(form.brevoListAlumni) }}
                    </div>
                </div>

                <div class="flex justify-end mt-6">
                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-6 rounded-lg transition duration-150 ease-in-out">
                        {{ 'Enregistrer les modifications' | trans }}
                    </button>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}

{% block menuBackButton %}
    <ion-button href="{{ path('admin') }}" color="light">
        <ion-icon name="arrow-back-outline"></ion-icon>
    </ion-button>
{% endblock %}
