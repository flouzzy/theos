{% extends 'admin/layout.html.twig' %}

{% block title %}
    {{ 'Modifier l\'Évaluation' | trans }} - {{ evaluation.title }}
{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="{{ 'Modifier l\'Évaluation' | trans }}" 
        subtitle="{{ evaluation.title }}"
        backPath="{{ path('app_admin_evaluation_index') }}"
    />

    <div class="max-w-4xl">
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 md:p-8">
            {{ include('admin/evaluation/_form.html.twig', {'button_label': 'Update'}) }}
        </div>
        
        <div class="mt-8 pt-8 border-t border-slate-200">
            <div class="bg-red-50 rounded-xl border border-red-100 p-6 flex items-center justify-between">
                <div>
                    <h4 class="text-red-900 font-semibold">{{ 'Zone de Danger' | trans }}</h4>
                    <p class="text-red-600 text-sm">{{ 'Cette action est irréversible. Toutes les données de cette évaluation seront supprimées.' | trans }}</p>
                </div>
                {{ include('admin/evaluation/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
