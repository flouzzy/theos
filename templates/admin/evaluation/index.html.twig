{% extends 'admin/layout.html.twig' %}

{% block title %}
    {{ 'Evaluations' | trans }}
{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="Évaluations" 
        subtitle="Gérez les évaluations de l'académie"
        addPath="{{ path('app_admin_evaluation_new') }}"
        addLabel="Nouvelle Évaluation"
    />

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <twig:Table>
            <twig:Table:Head>
                <twig:Table:Row>
                    <twig:Table:Header>{{ 'Titre' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Score' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Créé le' | trans }}</twig:Table:Header>
                    <twig:Table:Header class="text-right">{{ 'Actions' | trans }}</twig:Table:Header>
                </twig:Table:Row>
            </twig:Table:Head>
            <twig:Table:Body>
                {% for evaluation in evaluations %}
                    <twig:Table:Row class="hover:bg-slate-50/50 transition-colors">
                        <twig:Table:Cell>
                            <div class="font-semibold text-slate-900 leading-tight">{{ evaluation.title }}</div>
                            <div class="text-xs text-slate-400">ID: {{ evaluation.id }}</div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <twig:Badge variant="outline" class="bg-slate-50 text-slate-700 border-slate-100 shadow-none font-mono">
                                {{ evaluation.score }} / {{ evaluation.maxScore }}
                            </twig:Badge>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="text-xs text-slate-500">
                                {{ evaluation.createdAt ? evaluation.createdAt|date('d/m/Y H:i') : '-' }}
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                <twig:Button as="a" href="{{ path('app_admin_evaluation_show', {'id': evaluation.id}) }}" variant="ghost" size="icon-sm" title="{{ 'Voir' | trans }}">
                                    <twig:ux:icon name="lucide:eye" class="w-4 h-4" />
                                </twig:Button>
                                <twig:Button as="a" href="{{ path('app_admin_evaluation_edit', {'id': evaluation.id}) }}" variant="outline" size="icon-sm" title="{{ 'Modifier' | trans }}">
                                    <twig:ux:icon name="lucide:pencil" class="w-4 h-4 text-slate-600" />
                                </twig:Button>
                            </div>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% else %}
                    <twig:Table:Row>
                        <twig:Table:Cell colspan="4" class="py-12 text-center text-slate-400">
                            {{ 'Aucune évaluation trouvée' | trans }}
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>
    </div>
{% endblock %}
