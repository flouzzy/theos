{{ form_start(form, {'attr': {'class': 'divide-y divide-slate-100'}}) }}
    
    {# Section 1 : Informations Générales #}
    <div class="pb-10">
        <div class="flex items-center gap-2 mb-6">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600">
                <twig:ux:icon name="lucide:layers" class="w-4 h-4" />
            </div>
            <h2 class="text-lg font-bold text-slate-800">{{ 'Détails du Module' | trans }}</h2>
        </div>
        
        <div class="grid grid-cols-1 gap-8">
            <div class="space-y-2">
                {{ form_label(form.title, 'Titre du module'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                {{ form_widget(form.title, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-medium', 'placeholder': 'Ex: Fondements Bibliques'}}) }}
                {{ form_errors(form.title) }}
            </div>
            <div class="space-y-2">
                {{ form_label(form.description, 'Bref résumé'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-700 leading-relaxed', 'rows': 4, 'placeholder': 'Ce que les étudiants apprendront dans ce module...'}}) }}
                {{ form_errors(form.description) }}
            </div>
        </div>
    </div>

    {# Section 2 : Hiérarchie #}
    <div class="py-10">
        <div class="flex items-center gap-2 mb-6">
            <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600">
                <twig:ux:icon name="lucide:git-branch" class="w-4 h-4" />
            </div>
            <h2 class="text-lg font-bold text-slate-800">{{ 'Emplacement & Ordre' | trans }}</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
                {{ form_label(form.courses, 'Cours parent(s)'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                {{ form_widget(form.courses, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-medium'}}) }}
                {{ form_errors(form.courses) }}
            </div>
            <div class="space-y-2">
                {{ form_label(form.itemOrder, 'Ordre d\'affichage'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                {{ form_widget(form.itemOrder, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-medium'}}) }}
                {{ form_errors(form.itemOrder) }}
            </div>
        </div>
    </div>

    {# Actions #}
    <div class="pt-10 flex items-center justify-end gap-4">
        <twig:Button as="a" href="{{ path('admin_module_index') }}" variant="ghost" class="text-slate-500 hover:bg-slate-100">
            {{ 'Annuler' | trans }}
        </twig:Button>
        <twig:Button type="submit" variant="default" class="px-8 py-3 shadow-lg shadow-primary/20 hover:scale-105 transition-all">
            <twig:ux:icon name="lucide:save" class="w-5 h-5 mr-2" />
            {{ button_label|default('Enregistrer')|trans }}
        </twig:Button>
    </div>
{{ form_end(form) }}
