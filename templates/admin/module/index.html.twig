{% extends 'admin/layout.html.twig' %}

{% block title %}
    {{ 'Modules' | trans }}
{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="Modules" 
        subtitle="Gérez les modules constituant vos cours"
        addPath="{{ path('admin_module_new') }}"
        addLabel="Nouveau Module"
    />

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <twig:Table>
            <twig:Table:Head>
                <twig:Table:Row>
                    <twig:Table:Header class="w-16">Id</twig:Table:Header>
                    <twig:Table:Header>{{ 'Titre' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Cours' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Auteur' | trans }}</twig:Table:Header>
                    <twig:Table:Header class="text-right">{{ 'Actions' | trans }}</twig:Table:Header>
                </twig:Table:Row>
            </twig:Table:Head>
            <twig:Table:Body>
                {% for module in modules %}
                    <twig:Table:Row class="hover:bg-slate-50/50 transition-colors">
                        <twig:Table:Cell class="font-medium text-slate-500">#{{ module.id }}</twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="font-semibold text-slate-900 leading-tight">{{ module.title }}</div>
                            <div class="text-xs text-slate-500 truncate max-w-sm">{{ module.description|striptags }}</div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="flex items-center gap-2">
                                <twig:ux:icon name="lucide:book" class="w-3.5 h-3.5 text-slate-400" />
                                <span class="text-sm text-slate-600">{{ module.course ? module.course.title : '-' }}</span>
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <span class="text-xs font-medium text-slate-600 bg-slate-100 px-2 py-1 rounded-full">
                                {{ module.author ? module.author.fullname : '-' }}
                            </span>
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                <twig:Button as="a" href="{{ path('admin_module_show', {'id': module.id}) }}" variant="ghost" size="icon-sm" title="{{ 'Voir' | trans }}">
                                    <twig:ux:icon name="lucide:eye" class="w-4 h-4" />
                                </twig:Button>
                                <twig:Button as="a" href="{{ path('admin_module_edit', {'id': module.id}) }}" variant="outline" size="icon-sm" title="{{ 'Modifier' | trans }}">
                                    <twig:ux:icon name="lucide:pencil" class="w-4 h-4 text-slate-600" />
                                </twig:Button>
                            </div>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% else %}
                    <twig:Table:Row>
                        <twig:Table:Cell colspan="5" class="py-12 text-center text-slate-400">
                            {{ 'Aucun module trouvé' | trans }}
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>
    </div>
{% endblock %}
