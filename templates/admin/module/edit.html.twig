{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Modifier le Module' | trans }}{% endblock %}

{% block content %}
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="flex items-start gap-5">
            <div class="mt-1">
                <twig:Button as="a" href="{{ path('admin_module_index') }}" variant="outline" size="icon" class="rounded-xl shadow-sm hover:bg-white hover:text-primary transition-all">
                    <twig:ux:icon name="lucide:chevron-left" class="w-5 h-5" />
                </twig:Button>
            </div>
            <div>
                <nav class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">
                    <span>{{ 'Administration' | trans }}</span>
                    <twig:ux:icon name="lucide:chevron-right" class="w-3 h-3" />
                    <a href="{{ path('admin_module_index') }}" class="hover:text-primary transition-colors">{{ 'Modules' | trans }}</a>
                </nav>
                <h1 class="text-4xl font-black text-slate-900 leading-tight">
                    {{ 'Modifier le Module' | trans }}
                </h1>
                <p class="text-slate-500 font-medium mt-1">
                    {{ module.title }} — <span class="text-primary/70 font-bold ml-1 text-sm">{{ module.course ? module.course.title : '' }}</span>
                </p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-8 max-w-5xl mx-auto">
        <div class="xl:col-span-3">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="p-8">
                    {{ include('admin/module/_form.html.twig', {'button_label': 'Mettre à jour le module'}) }}
                </div>
            </div>
        </div>

        <div class="space-y-8">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                    <twig:ux:icon name="lucide:layers" class="w-4 h-4 text-primary" />
                    {{ 'Contenu' | trans }}
                </h3>
                <div class="space-y-4 text-sm">
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <span class="text-slate-500">{{ 'Leçons' | trans }}</span>
                        <span class="text-slate-900 font-bold">{{ module.lessons|length }}</span>
                    </div>
                </div>
            </div>

            <div class="bg-red-50 rounded-2xl p-6 border border-red-100">
                <h3 class="text-red-900 font-bold mb-2 flex items-center gap-2">
                    <twig:ux:icon name="lucide:alert-triangle" class="w-4 h-4 text-red-600" />
                    {{ 'Zone de danger' | trans }}
                </h3>
                <p class="text-red-700 text-xs mb-4">{{ 'La suppression d\'un module effacera également toutes ses leçons associées.' | trans }}</p>
                {{ include('admin/module/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
