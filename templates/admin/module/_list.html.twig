<ion-grid>
	<ion-row>
		{% for module in modules %}
			<ion-col size="12" size-sm="3">
				<ion-item href="{{path('admin_module_edit', {id:module.id})}}" lines="none">
					<ion-card>
						<ion-card-header>
							<ion-card-title>{{ module.title }}</ion-card-title>
						</ion-card-header>

						<ion-card-content>
							{{ module.description|u.truncate(100, '...') }}
						</ion-card-content>
					</ion-card>
				</ion-item>
			</ion-col>
		{% else %}
			<ion-col>
				{{'No item found' | trans}}
			</ion-col>
		{% endfor %}
	</ion-row>
</ion-grid>
