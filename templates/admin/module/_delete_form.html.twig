<ion-item>
	<form method="post" action="{{ path('admin_module_delete', {'id': module.id}) }}" onsubmit="return confirm('{{'Are you sure you want to delete this item ?' | trans}}');">
		<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ module.id) }}">
		<ion-button color="danger" type="submit">{{'Delete' | trans}}</ion-button>
	</form>
</ion-item>
