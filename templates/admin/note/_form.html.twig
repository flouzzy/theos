{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
    
    <div class="flex items-center gap-2 mb-6">
        <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
            <twig:ux:icon name="lucide:sticky-note" class="w-4 h-4" />
        </div>
        <h2 class="text-lg font-bold text-slate-800">{{ 'Détails de la Note' | trans }}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-6 border-b border-slate-100">
        <div class="space-y-2">
            {{ form_label(form.user, 'Appartient à'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
            {{ form_widget(form.user, {'attr': {'class': 'w-full px-4 py-2 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-sm'}}) }}
            {{ form_errors(form.user) }}
        </div>
        <div class="space-y-2">
            {{ form_label(form.lesson, 'Lié à la leçon'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
            {{ form_widget(form.lesson, {'attr': {'class': 'w-full px-4 py-2 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-sm'}}) }}
            {{ form_errors(form.lesson) }}
        </div>
    </div>

    <div class="pt-6 space-y-2">
        {{ form_label(form.content, 'Contenu de la note'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
        {{ form_widget(form.content, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-700 leading-relaxed', 'rows': 8, 'placeholder': 'Écrivez ici le contenu de la note...'}}) }}
        {{ form_errors(form.content) }}
    </div>

    <div class="pt-10 flex items-center justify-end gap-4">
        <twig:Button as="a" href="{{ path('admin_note_index') }}" variant="ghost" class="text-slate-500 hover:bg-slate-100">
            {{ 'Annuler' | trans }}
        </twig:Button>
        <twig:Button type="submit" variant="default" class="px-8 py-3 shadow-lg shadow-primary/20 hover:scale-105 transition-all">
            <twig:ux:icon name="lucide:save" class="w-5 h-5 mr-2" />
            {{ button_label|default('Enregistrer')|trans }}
        </twig:Button>
    </div>
{{ form_end(form) }}
