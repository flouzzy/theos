<ion-item>
	<form method="post" action="{{ path('admin_note_delete', {'id': note.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
		<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ note.id) }}">
		<ion-button type="submit" color="danger">{{'Delete' | trans}}</ion-button>
	</form>
</ion-item>
