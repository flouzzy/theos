{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{'Note' | trans}}
{% endblock %}

{% block content %}

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ note.id }}</td>
			</tr>
			<tr>
				<th>Content</th>
				<td>{{ note.content }}</td>
			</tr>
			<tr>
				<th>CreatedAt</th>
				<td>{{ note.createdAt ? note.createdAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
			<tr>
				<th>UpdatedAt</th>
				<td>{{ note.updatedAt ? note.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('admin_note_edit', {'id': note.id}) }}">{{'Edit' | trans}}</a>

	{{ include('admin/note/_delete_form.html.twig') }}
{% endblock %}


{% block menuBackButton %}
	<ion-button href="{{path('admin_note_index')}}" color="light">
		<ion-icon name="arrow-back-outline"></ion-icon>
	</ion-button>
{% endblock %}
