{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{'Notes' | trans}}
{% endblock %}

{% block content %}
	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Content</th>
				<th>CreatedAt</th>
				<th>UpdatedAt</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for note in notes %}
				<tr>
					<td>{{ note.id }}</td>
					<td>{{ note.content }}</td>
					<td>{{ note.createdAt ? note.createdAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>{{ note.updatedAt ? note.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>
						<a href="{{ path('admin_note_show', {'id': note.id}) }}">show</a>
						<a href="{{ path('admin_note_edit', {'id': note.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
	<ion-fab slot="fixed" vertical="bottom" horizontal="end">
		<ion-fab-button href="{{ path('admin_note_new') }}">
			<ion-icon name="add"></ion-icon>
		</ion-fab-button>
	</ion-fab>
{% endblock %}
