{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Notes' | trans }}{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="Notes" 
        subtitle="Gérez les notes personnelles prises par les étudiants sur les leçons"
        addPath="{{ path('admin_note_new') }}"
        addLabel="Nouvelle Note"
    />

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <twig:Table>
            <twig:Table:Head>
                <twig:Table:Row>
                    <twig:Table:Header class="w-16">Id</twig:Table:Header>
                    <twig:Table:Header>{{ 'Auteur' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Leçon' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Contenu' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Date' | trans }}</twig:Table:Header>
                    <twig:Table:Header class="text-right">{{ 'Actions' | trans }}</twig:Table:Header>
                </twig:Table:Row>
            </twig:Table:Head>
            <twig:Table:Body>
                {% for note in notes %}
                    <twig:Table:Row class="hover:bg-slate-50/50 transition-colors group">
                        <twig:Table:Cell class="font-medium text-slate-500 w-16">#{{ note.id }}</twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="flex items-center gap-2">
                                <twig:Avatar:Text name="{{ note.user.fullname }}" class="scale-75 origin-left" />
                                <span class="text-sm font-semibold text-slate-900">{{ note.user.fullname }}</span>
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <span class="text-xs text-slate-600 font-medium bg-slate-50 px-2 py-1 rounded border border-slate-100 italic">{{ note.lesson.title }}</span>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="text-xs text-slate-500 line-clamp-1 max-w-xs group-hover:line-clamp-none transition-all">
                                {{ note.content }}
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <span class="text-[10px] text-slate-400 font-mono">
                                {{ note.createdAt|date('d/m/Y H:i') }}
                            </span>
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                <twig:Button as="a" href="{{ path('admin_note_show', {'id': note.id}) }}" variant="ghost" size="icon-sm" title="{{ 'Voir' | trans }}">
                                    <twig:ux:icon name="lucide:eye" class="w-4 h-4" />
                                </twig:Button>
                                <twig:Button as="a" href="{{ path('admin_note_edit', {'id': note.id}) }}" variant="outline" size="icon-sm" title="{{ 'Modifier' | trans }}">
                                    <twig:ux:icon name="lucide:pencil" class="w-4 h-4 text-slate-600" />
                                </twig:Button>
                            </div>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% else %}
                    <twig:Table:Row>
                        <twig:Table:Cell colspan="6" class="py-12 text-center text-slate-400">
                            {{ 'Aucune note trouvée' | trans }}
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>
    </div>

    <twig:Pagination
        currentPage="{{ currentPage }}"
        totalPages="{{ totalPages }}"
        routeName="admin_note_index"
    />
{% endblock %}
