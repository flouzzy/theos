{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{'Notes' | trans}}
{% endblock %}

{% block content %}
	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>{{'Author' | trans}}</th>
				<th>{{'Lesson' | trans}}</th>
				<th>{{'Content' | trans}}</th>
				<th>{{'Created at' | trans}}</th>
				<th>{{'Updated at' | trans}}</th>
				<th>*</th>
			</tr>
		</thead>
		<tbody>
			{% for note in notes %}
				<tr>
					<td>{{ note.id }}</td>
					<td>{{ note.user.firstname }}</td>
					<td>{{ note.lesson.title }}</td>
					<td>{{ note.content }}</td>
					<td>{{ note.createdAt ? note.createdAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>{{ note.updatedAt ? note.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>
						<a href="{{ path('admin_note_show', {'id': note.id}) }}">show</a>
						<a href="{{ path('admin_note_edit', {'id': note.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">{{'No item found' | trans}}</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
	<ion-fab slot="fixed" vertical="bottom" horizontal="end">
		<ion-fab-button href="{{ path('admin_note_new') }}">
			<ion-icon name="add"></ion-icon>
		</ion-fab-button>
	</ion-fab>
{% endblock %}
