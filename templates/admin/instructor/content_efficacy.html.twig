{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Efficacité du Contenu' | trans }} - {{ course.title }}{% endblock %}

{% block content %}
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="flex items-start gap-5">
            <div class="mt-1">
                <twig:Button as="a" href="{{ path('admin_analytics_course_select') }}" variant="outline" size="icon" class="rounded-xl shadow-sm hover:bg-white hover:text-primary transition-all">
                    <twig:ux:icon name="lucide:chevron-left" class="w-5 h-5" />
                </twig:Button>
            </div>
            <div>
                <nav class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">
                    <span class="text-primary/70">{{ 'Analytics' | trans }}</span>
                    <twig:ux:icon name="lucide:chevron-right" class="w-3 h-3" />
                    <span class="text-primary/70">{{ course.title }}</span>
                </nav>
                <h1 class="text-4xl font-black text-slate-900 leading-tight">
                    {{ 'Efficacité du Contenu' | trans }}
                </h1>
                <p class="text-slate-500 font-medium mt-1">
                    {{ 'Performance des leçons basée sur les notes moyennes des quiz.' | trans }}
                </p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                    <th class="px-8 py-5 text-xs font-bold text-slate-500 uppercase tracking-widest">{{ 'Leçon' | trans }}</th>
                    <th class="px-8 py-5 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">{{ 'Complétions' | trans }}</th>
                    <th class="px-8 py-5 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">{{ 'Note Moyenne' | trans }}</th>
                    <th class="px-8 py-5 text-xs font-bold text-slate-500 uppercase tracking-widest">{{ 'Efficacité' | trans }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for item in efficacyData %}
                    <tr class="hover:bg-slate-50/50 transition-colors group">
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-4">
                                <div class="h-10 w-10 bg-emerald-50 text-emerald-600 rounded-lg flex items-center justify-center group-hover:scale-110 transition-transform">
                                    <twig:ux:icon name="lucide:file-text" class="w-5 h-5" />
                                </div>
                                <div>
                                    <p class="font-bold text-slate-900">{{ item.lesson.title }}</p>
                                    <p class="text-xs text-slate-500 font-medium">{{ item.module.title }}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <span class="text-sm font-bold text-slate-700">{{ item.completionCount }}</span>
                        </td>
                        <td class="px-8 py-5">
                            <div class="flex items-center justify-center gap-4">
                                <div class="w-full max-w-[100px] h-2 bg-slate-100 rounded-full overflow-hidden">
                                    <div class="h-full {% if item.avgScore >= 15 %}bg-green-500{% elseif item.avgScore >= 10 %}bg-yellow-500{% elseif item.avgScore > 0 %}bg-red-500{% else %}bg-slate-300{% endif %}" style="width: {{ (item.avgScore / 20) * 100 }}%"></div>
                                </div>
                                <span class="text-sm font-black text-slate-700 min-w-[2.5rem]">{{ item.avgScore }}/20</span>
                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold tracking-tight
                                {% if item.status == 'Excellent' %}bg-green-100 text-green-700{% elseif item.status == 'Bon' %}bg-emerald-100 text-emerald-700{% elseif item.status == 'Moyen' %}bg-yellow-100 text-yellow-700{% elseif item.status == 'Faible' %}bg-red-100 text-red-700{% else %}bg-slate-100 text-slate-700{% endif %}">
                                {{ item.status }}
                            </span>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="px-8 py-20 text-center">
                            <twig:ux:icon name="lucide:database" class="w-12 h-12 text-slate-300 mx-auto mb-4" />
                            <p class="text-slate-500 font-medium">{{ 'Aucune donnée d\'efficacité disponible pour ce cours.' | trans }}</p>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
