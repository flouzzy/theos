{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Étudiants à Risque' | trans }} - {{ cohort.name }}{% endblock %}

{% block content %}
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="flex items-start gap-5">
            <div class="mt-1">
                <twig:Button as="a" href="{{ path('admin_analytics_cohort_select') }}" variant="outline" size="icon" class="rounded-xl shadow-sm hover:bg-white hover:text-primary transition-all">
                    <twig:ux:icon name="lucide:chevron-left" class="w-5 h-5" />
                </twig:Button>
            </div>
            <div>
                <nav class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">
                    <span class="text-primary/70">{{ 'Analytics' | trans }}</span>
                    <twig:ux:icon name="lucide:chevron-right" class="w-3 h-3" />
                    <span class="text-primary/70">{{ cohort.name }}</span>
                </nav>
                <h1 class="text-4xl font-black text-slate-900 leading-tight">
                    {{ 'Étudiants à Risque' | trans }}
                </h1>
                <p class="text-slate-500 font-medium mt-1">
                    {{ 'Analyse basée sur l\'inactivité, les notes et la progression.' | trans }}
                </p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                    <th class="px-8 py-5 text-xs font-bold text-slate-500 uppercase tracking-widest">{{ 'Étudiant' | trans }}</th>
                    <th class="px-8 py-5 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">{{ 'Score de Risque' | trans }}</th>
                    <th class="px-8 py-5 text-xs font-bold text-slate-500 uppercase tracking-widest">{{ 'Statut' | trans }}</th>
                    <th class="px-8 py-5 text-xs font-bold text-slate-500 uppercase tracking-widest text-right">{{ 'Dernière Activité' | trans }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for item in students %}
                    <tr class="hover:bg-slate-50/50 transition-colors group">
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-4">
                                <div class="h-10 w-10 bg-slate-100 rounded-full flex items-center justify-center text-slate-500 font-bold group-hover:scale-110 transition-transform">
                                    {{ item.user.firstname|first }}{{ item.user.lastname|first }}
                                </div>
                                <div>
                                    <p class="font-bold text-slate-900">{{ item.user.fullname }}</p>
                                    <p class="text-xs text-slate-500 font-medium">{{ item.user.email }}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <div class="flex items-center justify-center gap-4">
                                <div class="w-full max-w-[100px] h-2 bg-slate-100 rounded-full overflow-hidden">
                                    <div class="h-full {% if item.riskScore >= 80 %}bg-red-500{% elseif item.riskScore >= 50 %}bg-orange-500{% else %}bg-yellow-500{% endif %}" style="width: {{ item.riskScore }}%"></div>
                                </div>
                                <span class="text-sm font-black text-slate-700 min-w-[2.5rem]">{{ item.riskScore }}%</span>
                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold tracking-tight
                                {% if item.status == 'Critique' %}bg-red-100 text-red-700{% elseif item.status == 'Élevé' %}bg-orange-100 text-orange-700{% elseif item.status == 'Modéré' %}bg-yellow-100 text-yellow-700{% else %}bg-green-100 text-green-700{% endif %}">
                                {{ item.status }}
                            </span>
                        </td>
                        <td class="px-8 py-5 text-right">
                            <span class="text-sm font-semibold text-slate-600">
                                {{ item.user.lastConnectionAt ? item.user.lastConnectionAt|date('d/m/Y') : 'Jamais' }}
                            </span>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="px-8 py-20 text-center">
                            <twig:ux:icon name="lucide:smile" class="w-12 h-12 text-slate-300 mx-auto mb-4" />
                            <p class="text-slate-500 font-medium">{{ 'Tous les étudiants semblent engagés !' | trans }}</p>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
