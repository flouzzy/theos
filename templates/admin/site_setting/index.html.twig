{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{'Paramètres Généraux' | trans}}
{% endblock %}

{% block content %}
	<div class="container mx-auto py-10">
		<div class="flex justify-between items-center mb-6">
			<h1 class="text-2xl font-bold tracking-tight">{{ 'Paramètres Généraux'|trans }}</h1>
		</div>

		<div class="rounded-md border bg-card">
			<twig:Table>
				<twig:Table:Header>
					<twig:Table:Row>
						<twig:Table:Head>{{ 'Clé'|trans }}</twig:Table:Head>
						<twig:Table:Head>{{ 'Description'|trans }}</twig:Table:Head>
						<twig:Table:Head>{{ 'Valeur'|trans }}</twig:Table:Head>
						<twig:Table:Head class="text-right">{{ 'Actions'|trans }}</twig:Table:Head>
					</twig:Table:Row>
				</twig:Table:Header>
				<twig:Table:Body>
					{% for setting in settings %}
						<twig:Table:Row>
							<twig:Table:Cell class="font-medium">
								<span class="bg-muted px-2 py-1 rounded text-xs font-mono">{{ setting.name }}</span>
							</twig:Table:Cell>
							<twig:Table:Cell class="text-muted-foreground text-sm">
								{{ setting.description }}
							</twig:Table:Cell>
							<twig:Table:Cell class="text-sm">
								{{ setting.value|striptags|u.truncate(50, '...') }}
							</twig:Table:Cell>
							<twig:Table:Cell class="text-right">
								<div class="flex justify-end gap-2">
									<twig:Button variant="ghost" size="sm" asChild>
										<a href="{{ path('admin_setting_edit', {id: setting.id}) }}">
											<twig:ux:icon name="lucide:pencil" class="h-4 w-4" />
										</a>
									</twig:Button>
								</div>
							</twig:Table:Cell>
						</twig:Table:Row>
					{% else %}
						<twig:Table:Row>
							<twig:Table:Cell colspan="4" class="h-24 text-center text-muted-foreground">
								{{ 'Aucun paramètre trouvé.'|trans }}
							</twig:Table:Cell>
						</twig:Table:Row>
					{% endfor %}
				</twig:Table:Body>
			</twig:Table>
		</div>
	</div>
{% endblock %}
