{% extends 'admin/layout.html.twig' %}

{% block title %}
    {{ 'Cohorts' | trans }}
{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="Promotions" 
        subtitle="Gérez les promotions et les accès aux cours"
        addPath="{{ path('admin_cohort_new') }}"
        addLabel="Nouvelle Promotion"
    />

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <twig:Table>
            <twig:Table:Head>
                <twig:Table:Row>
                    <twig:Table:Header class="w-16">Id</twig:Table:Header>
                    <twig:Table:Header>{{ 'Titre' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Année' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Statut' | trans }}</twig:Table:Header>
                    <twig:Table:Header>{{ 'Créé le' | trans }}</twig:Table:Header>
                    <twig:Table:Header class="text-right">{{ 'Actions' | trans }}</twig:Table:Header>
                </twig:Table:Row>
            </twig:Table:Head>
            <twig:Table:Body>
                {% for cohort in cohorts %}
                    <twig:Table:Row class="hover:bg-slate-50/50 transition-colors">
                        <twig:Table:Cell class="font-medium text-slate-500 w-16">#{{ cohort.id }}</twig:Table:Cell>
                        <twig:Table:Cell>
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-400 overflow-hidden shadow-sm">
                                    {% if cohort.image %}
                                        <img src="{{ asset(cohort.image) }}" alt="" class="w-full h-full object-cover">
                                    {% else %}
                                        <twig:ux:icon name="lucide:users" class="w-5 h-5" />
                                    {% endif %}
                                </div>
                                <div class="font-semibold text-slate-900">{{ cohort.title }}</div>
                            </div>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <span class="px-2.5 py-1 rounded-md bg-slate-50 text-slate-600 border border-slate-200 text-xs font-bold font-mono">
                                {{ cohort.year }}
                            </span>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            {% if cohort.status == 'published' %}
                                <twig:Badge variant="default" class="bg-emerald-50 text-emerald-700 border-emerald-100 shadow-none text-[10px] font-bold uppercase">
                                    {{ 'Publié' | trans }}
                                </twig:Badge>
                            {% else %}
                                <twig:Badge variant="outline" class="bg-slate-50 text-slate-500 border-slate-200 shadow-none text-[10px] font-bold uppercase">
                                    {{ 'Brouillon' | trans }}
                                </twig:Badge>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            <span class="text-slate-400 text-[10px]">
                                {{ cohort.createdAt ? cohort.createdAt|date('d/m/Y') : '-' }}
                            </span>
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                <twig:Button as="a" href="{{ path('admin_cohort_show', {'id': cohort.id}) }}" variant="ghost" size="icon-sm" title="{{ 'Voir' | trans }}">
                                    <twig:ux:icon name="lucide:eye" class="w-4 h-4" />
                                </twig:Button>
                                <twig:Button as="a" href="{{ path('admin_cohort_edit', {'id': cohort.id}) }}" variant="outline" size="icon-sm" title="{{ 'Modifier' | trans }}">
                                    <twig:ux:icon name="lucide:pencil" class="w-4 h-4 text-slate-600" />
                                </twig:Button>
                            </div>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% else %}
                    <twig:Table:Row>
                        <twig:Table:Cell colspan="6" class="py-12 text-center text-slate-400">
                            {{ 'Aucun enregistrement trouvé' | trans }}
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>
    </div>
{% endblock %}
