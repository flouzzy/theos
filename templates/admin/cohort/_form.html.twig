{{ form_start(form, {'attr': {'class': 'divide-y divide-slate-100'}}) }}
    
    {# Section 1 : Informations Générales #}
    <div class="pb-10">
        <div class="flex items-center gap-2 mb-6">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600">
                <twig:ux:icon name="lucide:graduation-cap" class="w-4 h-4" />
            </div>
            <h2 class="text-lg font-bold text-slate-800">{{ 'Détails de la Promotion' | trans }}</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="md:col-span-2 space-y-2">
                {{ form_label(form.title, 'Nom de la promotion'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                {{ form_widget(form.title, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-medium', 'placeholder': 'Ex: Promotion 2026'}}) }}
                {{ form_errors(form.title) }}
            </div>
            <div class="space-y-2">
                {{ form_label(form.year, 'Année'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                {{ form_widget(form.year, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-medium', 'placeholder': '2026'}}) }}
                {{ form_errors(form.year) }}
            </div>
        </div>
    </div>

    {# Section 2 : Description & Statut #}
    <div class="py-10">
        <div class="flex items-center gap-2 mb-6">
            <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center text-amber-600">
                <twig:ux:icon name="lucide:align-left" class="w-4 h-4" />
            </div>
            <h2 class="text-lg font-bold text-slate-800">{{ 'Description' | trans }}</h2>
        </div>
        
        <div class="grid grid-cols-1 gap-8">
            <div class="space-y-2">
                {{ form_label(form.description, 'Description'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-700 leading-relaxed', 'rows': 4, 'placeholder': 'Présentation de la promotion...'}}) }}
                {{ form_errors(form.description) }}
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    {{ form_label(form.status, 'Statut'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                    {{ form_widget(form.status, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-medium'}}) }}
                    {{ form_errors(form.status) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.image, 'Image de couverture (URL)'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                    <div class="relative">
                        <twig:ux:icon name="lucide:image" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" />
                        {{ form_widget(form.image, {'attr': {'class': 'w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-mono text-sm'}}) }}
                    </div>
                    {{ form_errors(form.image) }}
                </div>
            </div>
        </div>
    </div>

    {# Actions #}
    <div class="pt-10 flex items-center justify-end gap-4">
        <twig:Button as="a" href="{{ path('admin_cohort_index') }}" variant="ghost" class="text-slate-500 hover:bg-slate-100">
            {{ 'Annuler' | trans }}
        </twig:Button>
        <twig:Button type="submit" variant="default" class="px-8 py-3 shadow-lg shadow-primary/20 hover:scale-105 transition-all">
            <twig:ux:icon name="lucide:save" class="w-5 h-5 mr-2" />
            {{ button_label|default('Enregistrer')|trans }}
        </twig:Button>
    </div>
{{ form_end(form) }}
