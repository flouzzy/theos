{% extends 'admin/layout.html.twig' %}

{% block menuBackButton %}
	<ion-button href="{{path('admin_cohort_index')}}">
		<ion-icon name="arrow-back-outline"></ion-icon>
		{{'Back' | trans}}
	</ion-button>
{% endblock %}

{% block title %}
	{{cohort.title}}
	|
	{{'Cohort' | trans}}
{% endblock %}

{% block content %}
	<h1>Cohort</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ cohort.id }}</td>
			</tr>
			<tr>
				<th>Title</th>
				<td>{{ cohort.title }}</td>
			</tr>
			<tr>
				<th>Description</th>
				<td>{{ cohort.description }}</td>
			</tr>
			<tr>
				<th>Image</th>
				<td>{{ cohort.image }}</td>
			</tr>
			<tr>
				<th>Year</th>
				<td>{{ cohort.year }}</td>
			</tr>
			<tr>
				<th>Status</th>
				<td>{{ cohort.status }}</td>
			</tr>
			<tr>
				<th>CreatedAt</th>
				<td>{{ cohort.createdAt ? cohort.createdAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
			<tr>
				<th>UpdatedAt</th>
				<td>{{ cohort.updatedAt ? cohort.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('admin_cohort_index') }}">back to list</a>

	<a href="{{ path('admin_cohort_edit', {'id': cohort.id}) }}">edit</a>

	{{ include('admin/cohort/_delete_form.html.twig') }}
{% endblock %}
