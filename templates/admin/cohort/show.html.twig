{% extends 'admin/layout.html.twig' %}

{% block title %}{{ cohort.title }}{% endblock %}

{% block content %}
    <twig:AdminHeader 
        title="{{ cohort.title }}" 
        subtitle="{{ 'Détails de la promotion' | trans }}"
        backPath="{{ path('admin_cohort_index') }}"
    />

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
            {# Image & Banner #}
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="h-48 bg-slate-100 relative">
                    {% if cohort.image %}
                        <img src="{{ asset(cohort.image) }}" alt="" class="w-full h-full object-cover">
                    {% else %}
                        <div class="w-full h-full flex items-center justify-center text-slate-300">
                            <twig:ux:icon name="lucide:image" class="w-12 h-12" />
                        </div>
                    {% endif %}
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold text-slate-900 mb-2">{{ cohort.title }}</h3>
                    <p class="text-slate-600 leading-relaxed">{{ cohort.description|default('Aucune description.'|trans) }}</p>
                </div>
            </div>

            {# Additional Info #}
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <h3 class="font-bold text-slate-800">{{ 'Informations Système' | trans }}</h3>
                </div>
                <div class="p-6">
                    <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'ID' | trans }}</dt>
                            <dd class="mt-1 text-sm text-slate-900 font-mono">#{{ cohort.id }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'Statut' | trans }}</dt>
                            <dd class="mt-1">
                                <twig:Badge variant="{{ cohort.status == 'published' ? 'default' : 'outline' }}">
                                    {{ cohort.status | trans }}
                                </twig:Badge>
                            </dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'Date de création' | trans }}</dt>
                            <dd class="mt-1 text-sm text-slate-900">{{ cohort.createdAt ? cohort.createdAt|date('d/m/Y H:i') : '-' }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-slate-500">{{ 'Dernière mise à jour' | trans }}</dt>
                            <dd class="mt-1 text-sm text-slate-900">{{ cohort.updatedAt ? cohort.updatedAt|date('d/m/Y H:i') : '-' }}</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>

        <div class="space-y-8">
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <div class="text-center mb-6">
                    <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center text-slate-500 mx-auto mb-4">
                        <twig:ux:icon name="lucide:calendar" class="w-8 h-8" />
                    </div>
                    <div class="text-3xl font-bold text-slate-900">{{ cohort.year }}</div>
                    <div class="text-sm text-slate-500 uppercase font-bold tracking-wider">{{ 'Année Scolaire' | trans }}</div>
                </div>
                
                <div class="space-y-3">
                    <twig:Button as="a" href="{{ path('admin_cohort_edit', {'id': cohort.id}) }}" variant="default" class="w-full">
                        <twig:ux:icon name="lucide:pencil" class="w-4 h-4 mr-2" />
                        {{ 'Modifier' | trans }}
                    </twig:Button>
                </div>
            </div>

            <div class="bg-red-50 rounded-xl p-6 border border-red-100">
                <h3 class="text-red-900 font-bold mb-2">{{ 'Zone de danger' | trans }}</h3>
                <p class="text-red-700 text-sm mb-4">{{ 'Supprimer définitivement cette promotion.' | trans }}</p>
                {{ include('admin/cohort/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
