{{ form_start(form, {'attr': {'class': 'divide-y divide-slate-100', 'novalidate': 'novalidate'}}) }}
    
    <div x-data="{ imageUrl: '{{ form.vars.value.image ? asset(form.vars.value.image) : '' }}' }" class="pb-10">
        <div class="flex items-center gap-2 mb-6">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600">
                <twig:ux:icon name="lucide:book-open" class="w-4 h-4" />
            </div>
            <h2 class="text-lg font-bold text-slate-800">{{ 'Détails du Cours' | trans }}</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-8">
                <div class="space-y-2">
                    {{ form_label(form.title, 'Titre du cours'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                    {{ form_widget(form.title, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-medium', 'placeholder': 'Ex: Théologie Systématique'}}) }}
                    {{ form_errors(form.title) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.description, 'Description complète'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-700 leading-relaxed', 'rows': 5, 'placeholder': 'Présentez le programme de ce cours...'}}) }}
                    {{ form_errors(form.description) }}
                </div>
                <div class="space-y-2">
                    {{ form_label(form.status, 'Visibilité'|trans, {'label_attr': {'class': 'text-xs font-bold text-slate-400 uppercase tracking-wider'}}) }}
                    {{ form_widget(form.status, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all text-slate-900 font-medium'}}) }}
                    {{ form_errors(form.status) }}
                </div>
            </div>

            <div class="space-y-4">
                <label class="text-xs font-bold text-slate-400 uppercase tracking-wider">{{ 'Image de couverture' | trans }}</label>
                
                {# Aperçu dynamique & Upload #}
                <div class="relative w-full aspect-video rounded-2xl overflow-hidden border-2 border-dashed border-slate-200 bg-slate-50 hover:border-primary/50 transition-colors group">
                    {# Image Preview #}
                    <div x-show="imageUrl" style="display: none;" class="absolute inset-0 z-10">
                        <img :src="imageUrl" alt="Aperçu" class="w-full h-full object-cover">
                        <button @click.prevent="imageUrl = ''; $refs.fileInput.value = ''" type="button" class="absolute top-3 right-3 bg-white/90 text-red-600 p-2 rounded-xl shadow-sm hover:scale-105 transition-all">
                            <twig:ux:icon name="lucide:trash-2" class="w-4 h-4" />
                        </button>
                    </div>
                    
                    {# Input Empty State #}
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 group-hover:text-primary transition-colors">
                        <twig:ux:icon name="lucide:image-plus" class="w-8 h-8 mb-2" />
                        <span class="text-xs font-medium">{{ 'Cliquez ou glissez une image' | trans }}</span>
                    </div>

                    {{ form_widget(form.imageFile, {
                        'attr': {
                            'class': 'absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20',
                            'x-ref': 'fileInput',
                            '@change': "
                                const file = $event.target.files[0];
                                if (file) {
                                    const reader = new FileReader();
                                    reader.onload = (e) => { imageUrl = e.target.result; };
                                    reader.readAsDataURL(file);
                                }
                            "
                        }
                    }) }}
                </div>
                {{ form_errors(form.imageFile) }}
            </div>
        </div>
    </div>

    {# Section 1 : Informations Générales #}
    <div class="pb-10">
        <div class="flex items-center gap-2 mb-6">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600">
                <twig:ux:icon name="lucide:book-open" class="w-4 h-4" />
            </div>
            <h2 class="text-lg font-bold text-slate-800">{{ 'Détails du Cours' | trans }}</h2>
        </div>

    {# Actions #}
    <div class="pt-10 flex items-center justify-end gap-4">
        <twig:Button as="a" href="{{ path('admin_course_index') }}" variant="ghost" class="text-slate-500 hover:bg-slate-100">
            {{ 'Annuler' | trans }}
        </twig:Button>
        <twig:Button type="submit" variant="default" class="px-8 py-3 shadow-lg shadow-primary/20 hover:scale-105 transition-all">
            <twig:ux:icon name="lucide:save" class="w-5 h-5 mr-2" />
            {{ button_label|default('Enregistrer')|trans }}
        </twig:Button>
    </div>
{{ form_end(form) }}
