{% extends 'admin/layout.html.twig' %}

{% block title %}
	{{'Courses' | trans}}
{% endblock %}

	<div class="container mx-auto py-10">
		<div class="flex justify-between items-center mb-6">
			<h1 class="text-2xl font-bold tracking-tight">{{ 'Courses'|trans }}</h1>
			<twig:Button asChild>
				<a href="{{ path('admin_course_new') }}">
					<twig:ux:icon name="lucide:plus" class="mr-2 h-4 w-4" />
					{{ 'New Course'|trans }}
				</a>
			</twig:Button>
		</div>

		<div class="rounded-md border">
			<twig:Table>
				<twig:Table:Header>
					<twig:Table:Row>
						<twig:Table:Head>{{ 'Title'|trans }}</twig:Table:Head>
						<twig:Table:Head>{{ 'Description'|trans }}</twig:Table:Head>
						<twig:Table:Head class="text-right">{{ 'Actions'|trans }}</twig:Table:Head>
					</twig:Table:Row>
				</twig:Table:Header>
				<twig:Table:Body>
					{% for course in courses %}
						<twig:Table:Row>
							<twig:Table:Cell class="font-medium">
								{{ course.title }}
							</twig:Table:Cell>
							<twig:Table:Cell>
								{{ course.description|striptags|u.truncate(50, '...') }}
							</twig:Table:Cell>
							<twig:Table:Cell class="text-right">
								<div class="flex justify-end gap-2">
									<twig:Button variant="ghost" size="sm" asChild>
										<a href="{{ path('admin_course_show', {id: course.id}) }}">
											<twig:ux:icon name="lucide:eye" class="h-4 w-4" />
										</a>
									</twig:Button>
									<twig:Button variant="ghost" size="sm" asChild>
										<a href="{{ path('admin_course_edit', {id: course.id}) }}">
											<twig:ux:icon name="lucide:pencil" class="h-4 w-4" />
										</a>
									</twig:Button>
								</div>
							</twig:Table:Cell>
						</twig:Table:Row>
					{% else %}
						<twig:Table:Row>
							<twig:Table:Cell colspan="3" class="h-24 text-center">
								{{ 'No courses found.'|trans }}
							</twig:Table:Cell>
						</twig:Table:Row>
					{% endfor %}
				</twig:Table:Body>
			</twig:Table>
		</div>
	</div>
