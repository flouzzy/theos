{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'Modifier le Cours' | trans }}{% endblock %}

{% block content %}
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="flex items-start gap-5">
            <div class="mt-1">
                <twig:Button as="a" href="{{ path('admin_course_index') }}" variant="outline" size="icon" class="rounded-xl shadow-sm hover:bg-white hover:text-primary transition-all">
                    <twig:ux:icon name="lucide:chevron-left" class="w-5 h-5" />
                </twig:Button>
            </div>
            <div>
                <nav class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">
                    <span>{{ 'Administration' | trans }}</span>
                    <twig:ux:icon name="lucide:chevron-right" class="w-3 h-3" />
                    <a href="{{ path('admin_course_index') }}" class="hover:text-primary transition-colors">{{ 'Cours' | trans }}</a>
                </nav>
                <h1 class="text-4xl font-black text-slate-900 leading-tight">
                    {{ 'Modifier le Cours' | trans }}
                </h1>
                <p class="text-slate-500 font-medium mt-1">
                    {{ course.title }} — <span class="text-xs font-mono bg-slate-100 px-2 py-0.5 rounded text-slate-600">{{ course.modules|length }} {{ 'modules'|trans }}</span>
                </p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <twig:Button as="a" href="{{ path('course_show', {'slug': course.slug}) }}" target="_blank" variant="ghost" class="text-slate-600 hover:text-primary transition-all">
                <twig:ux:icon name="lucide:external-link" class="w-4 h-4 mr-2" />
                {{ 'Voir le cours' | trans }}
            </twig:Button>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-8 max-w-[1600px] mx-auto">
        <div class="xl:col-span-3">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="p-8">
                    {{ include('admin/course/_form.html.twig', {'button_label': 'Mettre à jour le cours'}) }}
                </div>
            </div>
        </div>

        <div class="space-y-8">
            {# Course Preview #}
            {% if course.imageName %}
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                    <img src="{{ asset('uploads/images/courses/' ~ course.imageName) }}" alt="{{ course.title }}" class="w-full h-48 object-cover">
                    <div class="p-4 border-t border-slate-50">
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-1">{{ 'Image actuelle' | trans }}</p>
                    </div>
                </div>
            {% endif %}

            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                    <twig:ux:icon name="lucide:bar-chart-3" class="w-4 h-4 text-primary" />
                    {{ 'Structure' | trans }}
                </h3>
                <div class="space-y-4 text-sm">
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <span class="text-slate-500">{{ 'Modules' | trans }}</span>
                        <span class="text-slate-900 font-bold">{{ course.modules|length }}</span>
                    </div>
                    {% set total_lessons = 0 %}
                    {% for module in course.modules %}
                        {% set total_lessons = total_lessons + module.lessons|length %}
                    {% endfor %}
                    <div class="flex justify-between py-2 border-b border-slate-50">
                        <span class="text-slate-500">{{ 'Leçons' | trans }}</span>
                        <span class="text-slate-900 font-bold">{{ total_lessons }}</span>
                    </div>
                </div>
            </div>

            <div class="bg-red-50 rounded-2xl p-6 border border-red-100">
                <h3 class="text-red-900 font-bold mb-2 flex items-center gap-2">
                    <twig:ux:icon name="lucide:alert-triangle" class="w-4 h-4 text-red-600" />
                    {{ 'Zone de danger' | trans }}
                </h3>
                <p class="text-red-700 text-xs mb-4">{{ 'La suppression d\'un cours effacera également tous les modules et leçons associés.' | trans }}</p>
                {{ include('admin/course/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
