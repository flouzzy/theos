<form method="post" action="{{ path('admin_course_delete', {'id': course.id}) }}" onsubmit="return confirm('{{'Êtes-vous sûr de vouloir supprimer cet élément ?' | trans}}');">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
	<twig:Button variant="destructive">
        <twig:ux:icon name="lucide:trash-2" class="w-4 h-4 mr-2" />
        {{ 'Supprimer' | trans }}
    </twig:Button>
</form>
