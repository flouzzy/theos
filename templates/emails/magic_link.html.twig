{% extends 'email.html.twig' %}

{% block content %}
    <spacer size="16"></spacer>
    <h1>{{ 'Bonjour' | trans }} {{ user.firstname }} ! 👋</h1>
    <p class="lead">{{ 'Tu as demandé un lien de connexion magique pour accéder à ton compte.' | trans }}</p>
    
    <spacer size="16"></spacer>

    <center>
        <button href="{{ url }}" class="primary">{{ 'Se connecter maintenant' | trans }}</button>
    </center>

    <spacer size="24"></spacer>

    <p style="font-size: 12px; color: #64748b;">
        {{ 'Ce lien est valable pendant 15 minutes. Si tu n\'es pas à l\'origine de cette demande, tu peux ignorer cet email.' | trans }}
    </p>

    <spacer size="16"></spacer>
    
    <p>{{ 'À bientôt sur la plateforme,' | trans }}<br><strong>{{ 'L\'équipe du Rocher Académie' | trans }}</strong></p>
{% endblock %}
