<div class="bg-muted/50 rounded-lg p-3 text-sm border border-border/50 group">
    <div class="flex justify-between items-center mb-1 text-xs text-muted-foreground">
        <span>{{ note.createdAt | date('d/m/Y H:i') }}</span>
        
        <form action="{{ path('note_like', {id: note.id}) }}" method="POST" class="inline">
            <input type="hidden" name="_token" value="{{ csrf_token('like_note' ~ note.id) }}">
            <button type="submit" class="flex items-center gap-1 hover:text-primary transition-colors {{ app.user in note.likes ? 'text-primary' : '' }}">
                <twig:ux:icon name="{{ app.user in note.likes ? 'lucide:heart' : 'lucide:heart' }}" class="w-3 h-3 {{ app.user in note.likes ? 'fill-current' : '' }}" />
                <span class="font-bold">{{ note.likes|length }}</span>
            </button>
        </form>
    </div>
    <div class="text-foreground/90 whitespace-pre-wrap">
        {{ note.content }}
    </div>
</div>
