{% extends 'appWithBottomTabs.html.twig' %}

{% block title %}{{ 'Mes Évaluations' | trans }}{% endblock %}
{% block page_title %}{{ 'Évaluations' | trans }}{% endblock %}

{% block content %}
<div class="space-y-8">
    
    {# Stats Overview #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-card border border-border rounded-3xl p-6 shadow-sm flex flex-col justify-center relative overflow-hidden group">
             <div class="relative z-10 flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-indigo-100 text-indigo-600 flex items-center justify-center">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                </div>
                <div>
                    <h2 class="text-3xl font-bold flex items-baseline gap-1">
                        {{ stats.average }}
                        <span class="text-sm font-normal text-muted-foreground">/ 20</span>
                    </h2>
                    <p class="text-muted-foreground text-sm font-medium">{{ 'Moyenne générale' | trans }}</p>
                </div>
             </div>
        </div>

        <div class="bg-card border border-border rounded-3xl p-6 shadow-sm flex flex-col justify-center">
             <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-green-100 text-green-600 flex items-center justify-center">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                 <div>
                    <h3 class="text-2xl font-bold">{{ stats.completed }}</h3>
                    <p class="text-muted-foreground text-sm">{{ 'Évaluations terminées' | trans }}</p>
                 </div>
             </div>
        </div>

        <div class="bg-card border border-border rounded-3xl p-6 shadow-sm flex flex-col justify-center">
             <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-yellow-100 text-yellow-600 flex items-center justify-center">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                </div>
                 <div>
                    <h3 class="text-2xl font-bold">{{ stats.best_grade }}</h3>
                    <p class="text-muted-foreground text-sm">{{ 'Meilleur grade' | trans }}</p>
                 </div>
             </div>
        </div>
    </div>

    {# Recent Evaluations List #}
    <div>
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            🗒️ {{ 'Historique' | trans }}
        </h2>
        <div class="space-y-4">
            {% for eval in evaluations %}
                <div class="bg-card border border-border rounded-2xl p-4 flex flex-col md:flex-row md:items-center gap-4 hover:shadow-md transition-shadow">
                    
                    {# Score Badge #}
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div class="w-16 h-16 rounded-2xl flex flex-col items-center justify-center font-bold text-white shadow-sm
                            {% if eval.grade starts with 'A' %} bg-green-500
                            {% elseif eval.grade starts with 'B' %} bg-blue-500
                            {% else %} bg-orange-500 {% endif %}">
                            <span class="text-2xl">{{ eval.grade }}</span>
                        </div>
                    </div>

                    {# Info #}
                    <div class="flex-1 min-w-0">
                         <div class="flex items-center gap-2 mb-1">
                            <span class="bg-muted px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider text-muted-foreground">
                                {{ eval.course }}
                            </span>
                             <span class="text-xs text-muted-foreground">• {{ eval.date|date('d M Y') }}</span>
                         </div>
                         <h3 class="text-lg font-bold truncate">{{ eval.title }}</h3>
                         <div class="flex items-center gap-4 mt-2 text-sm text-muted-foreground">
                             <span class="flex items-center gap-1">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                {{ eval.duration }}
                             </span>
                             <span class="font-medium text-foreground">
                                 Score: {{ eval.score }}/{{ eval.total }}
                             </span>
                         </div>
                    </div>

                    {# Action #}
                    <div class="flex-shrink-0">
                        <button class="btn btn-outline w-full md:w-auto text-xs">
                            {{ 'Revoir' | trans }}
                        </button>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}
