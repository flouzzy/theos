{% extends 'app.html.twig' %}

{% block title %}Tableau de bord{% endblock %}
{% block page_title %}{{ 'Tableau de bord' | trans }}{% endblock %}

{% block content %}
<div class="space-y-6">
    
    {# Welcome Header #}
    {# Welcome Header #}
    <div class="bg-card rounded-xl p-8 border border-border flex flex-col md:flex-row items-center justify-between gap-6 shadow-sm">
        <div class="space-y-4 text-center md:text-left">
            <div>
                <h1 class="text-3xl font-bold flex items-center justify-center md:justify-start gap-2 text-foreground">
                    {{ 'Bonjour,'|trans }} {{ app.user.fullname }} <span class="animate-wave origin-bottom-right">👋</span>
                </h1>
                
                <div class="flex flex-col md:flex-row items-center gap-2 mt-2">
                    {% if cohort %}
                        <p class="text-muted-foreground font-medium text-lg">
                            {{ cohort.title }}
                        </p>
                    {% endif %}
                    
                    {% if app.user.cohorts|length > 1 %}
                        <select onchange="window.location.href=this.value" class="text-xs bg-secondary text-secondary-foreground border-none rounded px-2 py-1 cursor-pointer focus:ring-1 focus:ring-primary outline-none">
                            <option value="" disabled selected>{{ 'Changer de promo' | trans }}</option>
                            {% for c in app.user.cohorts %}
                                <option value="{{ path('cohort_switch', {id: c.id}) }}" {{ cohort and cohort.id == c.id ? 'selected' : '' }}>
                                    {{ c.title }}
                                </option>
                            {% endfor %}
                        </select>
                    {% endif %}
                </div>

                {% if cohort %}
                    <a href="{{ path('cohort_chat', {id: cohort.id}) }}" class="text-sm text-primary hover:underline flex items-center gap-1 mt-1 mb-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                        </svg>
                        {{ 'Accéder à la discussion de groupe' | trans }}
                    </a>
                {% endif %}
                <p class="text-muted-foreground">{{ 'Prêt à continuer votre apprentissage ?' | trans }}</p>
            </div>
            
            {% if lastLesson %}
                <a href="{{ path('lesson_show', {lessonId: lastLesson.id, moduleSlug: lastLesson.module.slug, courseSlug: lastLesson.module.courses.first.slug}) }}" class="group relative inline-flex items-center gap-3 overflow-hidden rounded-xl bg-primary px-8 py-4 font-bold text-primary-foreground transition-transform hover:scale-105 active:scale-95">
                    <span>{{ 'Reprendre :' | trans }} {{ lastLesson.title }}</span>
                    <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                </a>
            {% elseif myCourses|length > 0 %}
                {% set firstCourse = myCourses|first %}
                <a href="{{ path('course_show', {slug: firstCourse.course.slug}) }}" class="group relative inline-flex items-center gap-3 overflow-hidden rounded-xl bg-primary px-8 py-4 font-bold text-primary-foreground transition-transform hover:scale-105 active:scale-95">
                    <span>{{ 'Commencer :' | trans }} {{ firstCourse.course.title }}</span>
                    <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                </a>
            {% endif %}
        </div>
        {# Abstract decoration #}
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/5 blur-3xl"></div>
    </div>

    {# 2. Stats Row (3 Columns) #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {# Hours #}
        <twig:StatCard value="{{ stats.hours }}h" label="{{ 'Heures d\'apprentissage' | trans }}" icon="⏱" class="flex-row items-center gap-4 text-left p-6" />

        {# Courses #}
        <twig:StatCard value="{{ stats.completed }}" label="{{ 'Cours complétés' | trans }}" icon="🎓" class="flex-row items-center gap-4 text-left p-6" />

        {# Streak #}
        <twig:StatCard value="{{ app.user.streak ?? 0 }} {{ 'Jours' | trans }}" label="{{ 'Série en cours' | trans }}" icon="🔥" class="flex-row items-center gap-4 text-left p-6 text-orange-500" />
    </div>

    {# Subscription Status #}
    <div class="bg-card rounded-xl p-6 border border-border flex flex-col md:flex-row items-center justify-between gap-4 shadow-sm">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
            </div>
            <div>
                <h3 class="font-bold font-serif">{{ 'Mon Abonnement' | trans }}</h3>
                <p class="text-sm text-muted-foreground">
                    {% if app.user.subscriptionStatus == 'active' %}
                        {{ 'Statut : Actif' | trans }} (Plan : {{ app.user.subscriptionPlan }})
                    {% elseif app.user.subscriptionStatus == 'past_due' %}
                        <span class="text-destructive">{{ 'Paiement en attente' | trans }}</span>
                    {% else %}
                        {{ 'Passez au niveau supérieur pour débloquer toutes les fonctionnalités.' | trans }}
                    {% endif %}
                </p>
            </div>
        </div>
        <div>
            {% if app.user.subscriptionStatus != 'active' %}
                <a href="{{ path('app_subscription_checkout', {priceId: 'price_monthly_id'}) }}" class="btn btn-primary btn-sm">
                    {{ 'S\'abonner (Mensuel)' | trans }}
                </a>
            {% else %}
                <span class="text-xs font-semibold px-2 py-1 bg-green-100 text-green-700 rounded-full">Pro User</span>
            {% endif %}
        </div>
    </div>

    {# 3. My Courses Section (Grid) #}
    <div>
        <h2 class="text-2xl font-serif font-bold mb-6 flex items-center gap-2">
            {{ 'Mes Cours' | trans }}
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for item in myCourses %}
                {% set course = item.course %}
                {% set progress = item.progress %}
                
                <a href="{{ path('course_show', {slug: course.slug}) }}" class="group block h-full">
                    <div class="h-full bg-card rounded-2xl border border-border shadow-sm transition-all hover:shadow-lg hover:-translate-y-1 overflow-hidden flex flex-col">
                        {# Header Image (AspectRatio 16/9) #}
                        <div class="relative aspect-video w-full overflow-hidden bg-muted">
                            {% if course.image %}
                                <img src="{{ asset(course.image) }}" alt="{{ course.title }}" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105">
                            {% else %}
                                <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200">
                                    <svg class="h-10 w-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                    </svg>
                                </div>
                            {% endif %}
                            
                            {# Badge for progress #}
                            <div class="absolute top-3 right-3">
                                <span class="inline-flex items-center rounded-full bg-white/90 backdrop-blur-sm px-2.5 py-0.5 text-xs font-semibold text-foreground shadow-sm">
                                    {{ progress }}%
                                </span>
                            </div>
                        </div>

                        {# Content #}
                        <div class="p-5 flex-1 flex flex-col">
                            <h3 class="font-serif text-lg font-bold leading-tight mb-2 group-hover:text-primary transition-colors">
                                {{ course.title }}
                            </h3>
                            <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
                                {{ course.description|striptags|u.truncate(100, '...') ?: 'Apprenez avec les experts du Rocher.' }}
                            </p>
                            
                            <div class="mt-auto space-y-3">
                                {# Progress Bar #}
                                <div class="space-y-1">
                                    <div class="flex justify-between text-xs font-medium">
                                        <span class="text-muted-foreground">{{ progress }}% {{ 'complété' | trans }}</span>
                                    </div>
                                    <div class="h-2 w-full overflow-hidden rounded-full bg-muted">
                                        <div class="h-full bg-primary transition-all duration-500" style="width: {{ progress }}%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            {% else %}
                <div class="col-span-full py-12 text-center border-2 border-dashed border-border rounded-3xl">
                    <p class="text-muted-foreground mb-4">{{ 'Vous n\'avez pas encore commencé de cours.' | trans }}</p>
                    <a href="{{ path('course_index') }}" class="btn btn-outline">
                        {{ 'Explorer le catalogue' | trans }}
                    </a>
                </div>
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}
