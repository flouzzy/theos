{% extends 'app.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block page_title %}{{ 'Tableau de bord' | trans }}{% endblock %}

{% block content %}
<div class="space-y-8">
    
    {# Stats Section #}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-card border border-border rounded-xl p-4 flex flex-col items-center justify-center text-center hover:bg-muted/20 transition-colors">
            <span class="text-3xl font-bold text-primary">{{ stats.ongoing }}</span>
            <span class="text-sm text-muted-foreground">{{ 'Cours en cours' | trans }}</span>
        </div>
        <div class="bg-card border border-border rounded-xl p-4 flex flex-col items-center justify-center text-center hover:bg-muted/20 transition-colors">
            <span class="text-3xl font-bold text-primary">{{ stats.progress }}%</span>
            <span class="text-sm text-muted-foreground">{{ 'Progression globale' | trans }}</span>
        </div>
        <div class="bg-card border border-border rounded-xl p-4 flex flex-col items-center justify-center text-center hover:bg-muted/20 transition-colors">
            <span class="text-3xl font-bold text-primary">{{ stats.hours }}h</span>
            <span class="text-sm text-muted-foreground">{{ 'Heures de cours' | trans }}</span>
        </div>
        <div class="bg-card border border-border rounded-xl p-4 flex flex-col items-center justify-center text-center hover:bg-muted/20 transition-colors">
            <span class="text-3xl font-bold text-primary">{{ stats.completed }}</span>
            <span class="text-sm text-muted-foreground">{{ 'Cours terminés' | trans }}</span>
        </div>
    </div>

    {# Main Content Grid #}
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
        
        {# Left Column: Courses & Badges (2/3 width) #}
        <div class="xl:col-span-2 space-y-8">
            
            {# Courses Section #}
            <div class="space-y-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-xl font-bold">{{ 'Mes cours en cours' | trans }}</h2>
                    <a href="{{ path('course_index') }}" class="text-sm text-primary font-medium hover:underline">{{ 'Voir tout' | trans }}</a>
                </div>

                <div class="space-y-4">
                    {% for item in myCourses %}
                        {% set course = item.course %}
                        {% set progress = item.progress %}
                            {# Course Card #}
                            <div class="bg-card rounded-xl border border-border p-4 flex gap-4 transition-all hover:shadow-md card-hover group">
                                {# Course Image/Thumbnail #}
                                <div class="w-24 h-24 sm:w-32 sm:h-24 flex-shrink-0 bg-primary/10 rounded-lg overflow-hidden relative">
                                    {% if course.media %}
                                        <img src="{{ course.media.url }}" alt="{{ course.title }}" class="w-full h-full object-cover">
                                    {% else %}
                                        {# Placeholder #}
                                        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/80 to-primary text-white">
                                            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                            </svg>
                                        </div>
                                    {% endif %}
                                </div>

                                {# Info #}
                                <div class="flex-1 flex flex-col justify-between py-1">
                                    <div>
                                        <div class="flex justify-between items-start">
                                            <h3 class="font-bold text-lg leading-tight group-hover:text-primary transition-colors">
                                                <a href="{{ path('course_show', {slug: course.slug}) }}">
                                                    {{ course.title }}
                                                </a>
                                            </h3>
                                            <span class="text-xs font-semibold text-primary bg-primary/5 px-2 py-1 rounded">
                                                {{ progress }}%
                                            </span>
                                        </div>
                                    </div>

                                    {# Progress Bar #}
                                    <div class="mt-3">
                                        <div class="flex justify-between text-xs mb-1.5">
                                            <span class="text-muted-foreground">{{ 'Progression' }}</span>
                                        </div>
                                        <div class="h-1.5 w-full bg-secondary/30 rounded-full overflow-hidden">
                                            <div class="h-full bg-primary rounded-full" style="width: {{ progress }}%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                    {% else %}
                        <div class="bg-card rounded-xl border border-border p-8 text-center">
                            <div class="inline-flex h-12 w-12 rounded-full bg-muted items-center justify-center mb-4">
                                <svg class="h-6 w-6 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                </svg>
                            </div>
                            <h3 class="text-lg font-medium">{{ 'Aucun cours en cours' | trans }}</h3>
                            <p class="text-muted-foreground text-sm mt-1 mb-4">{{ 'Inscrivez-vous à une formation pour commencer.' | trans }}</p>
                            <a href="{{ path('course_index') }}" class="btn btn-primary">{{ 'Explorer le catalogue' | trans }}</a>
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# Badges Section (Moved Here) #}
            <div class="space-y-4">
                <h2 class="text-xl font-bold flex items-center gap-2">
                    <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    {{ 'Badges & Achievements' | trans }}
                </h2>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    {# Badges Mockup items - optimized grid for 2/3 width #}
                    <div class="bg-card rounded-xl border border-border p-4 flex gap-3 items-center hover:bg-muted/30 transition-colors">
                        <div class="h-12 w-12 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                            </svg>
                        </div>
                        <div class="min-w-0">
                            <h4 class="font-bold text-sm truncate">Premier cours</h4>
                            <p class="text-xs text-muted-foreground truncate">Terminé !</p>
                        </div>
                    </div>

                    <div class="bg-card rounded-xl border border-border p-4 flex gap-3 items-center hover:bg-muted/30 transition-colors">
                        <div class="h-12 w-12 rounded-full bg-green-100 text-green-600 flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <div class="min-w-0">
                            <h4 class="font-bold text-sm truncate">Série de 7 jours</h4>
                            <p class="text-xs text-muted-foreground truncate">7 jours consécutifs</p>
                        </div>
                    </div>
                    
                    <div class="bg-card rounded-xl border border-border p-4 flex gap-3 items-center hover:bg-muted/30 transition-colors">
                        <div class="h-12 w-12 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                        </div>
                        <div class="min-w-0">
                            <h4 class="font-bold text-sm truncate">Éclair</h4>
                            <p class="text-xs text-muted-foreground truncate">5 leçons en 1h</p>
                        </div>
                    </div>

                    <div class="bg-card rounded-xl border border-dashed border-border p-4 flex gap-3 items-center opacity-60">
                        <div class="h-12 w-12 rounded-full bg-muted flex items-center justify-center text-muted-foreground flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </div>
                        <div class="min-w-0">
                            <h4 class="font-bold text-sm truncate">Expert React</h4>
                            <p class="text-xs text-muted-foreground truncate">Verrouillé</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        {# Right Column (1/3 width) #}
        <div class="space-y-6">
            
            {# Upcoming Events #}
            <div class="space-y-4">
                <h2 class="text-xl font-bold flex items-center gap-2">
                    <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    {{ 'Événements à venir' | trans }}
                </h2>

                <div class="bg-card rounded-xl border border-border p-4 space-y-4">
                    {% for event in events %}
                        <div class="flex gap-3 items-start">
                            <div class="flex-shrink-0 w-12 h-12 bg-primary text-white rounded-lg flex flex-col items-center justify-center leading-none">
                                <span class="text-xs font-medium">{{ event.startAt|date('d') }}</span>
                                <span class="text-[10px] uppercase font-bold">{{ event.startAt|date('M') }}</span>
                            </div>
                            <div>
                                <h4 class="font-semibold text-sm">{{ event.title }}</h4>
                                <p class="text-xs text-muted-foreground mt-0.5">{{ event.startAt|date('H:i') }} • {{ event.location }}</p>
                            </div>
                        </div>
                        {% if not loop.last %}<hr class="border-border">{% endif %}
                    {% else %}
                        <p class="text-sm text-muted-foreground text-center py-4">{{ 'Aucun événement à venir.' | trans }}</p>
                    {% endfor %}
                </div>
            </div>

            {# Quick Actions (Moved Here) #}
            <div class="space-y-4">
                <h2 class="text-xl font-bold">{{ 'Actions rapides' | trans }}</h2>
                <div class="grid grid-cols-1 gap-3">
                    <a href="{{ path('note_index') }}" class="bg-card border border-border rounded-xl p-4 flex items-center gap-4 hover:border-primary/50 transition-colors group">
                        <div class="w-10 h-10 rounded-full bg-primary/5 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                            </svg>
                        </div>
                        <span class="font-semibold text-sm">{{ 'Consulter mes notes' | trans }}</span>
                    </a>
                    
                    <a href="{{ path('notification_index') }}" class="bg-card border border-border rounded-xl p-4 flex items-center gap-4 hover:border-primary/50 transition-colors group">
                        <div class="w-10 h-10 rounded-full bg-primary/5 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                            </svg>
                        </div>
                        <span class="font-semibold text-sm">{{ 'Voir les notifications' | trans }}</span>
                    </a>
                    
                    <a href="{{ path('profile_index') }}" class="bg-card border border-border rounded-xl p-4 flex items-center gap-4 hover:border-primary/50 transition-colors group">
                        <div class="w-10 h-10 rounded-full bg-primary/5 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <span class="font-semibold text-sm">{{ 'Mon profil' | trans }}</span>
                    </a>
                </div>
            </div>

        </div>

    </div>
</div>
{% endblock %}
