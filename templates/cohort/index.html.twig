{% extends 'app.html.twig' %}

{% block title %}Tableau de bord{% endblock %}
{% block page_title %}{{ 'Tableau de bord' | trans }}{% endblock %}

{% block content %}
<div class="space-y-6">
    
    {# Welcome Header #}
    {# Welcome Header #}
    <div class="bg-card rounded-xl p-8 border border-border flex flex-col md:flex-row items-center justify-between gap-6 shadow-sm">
        <div class="space-y-4 text-center md:text-left">
            <div>
                <h1 class="text-3xl font-bold flex items-center justify-center md:justify-start gap-2 text-foreground">
                    {{ 'Bonjour,'|trans }} {{ app.user.fullname }} <span class="animate-wave origin-bottom-right">👋</span>
                </h1>
                <p class="text-muted-foreground font-medium text-lg">
                    Promo {{ app.user.cohorts.first.title|default('2024') }}
                </p>
                {% if app.user.cohorts.first %}
                    <a href="{{ path('cohort_chat', {id: app.user.cohorts.first.id}) }}" class="text-sm text-primary hover:underline flex items-center gap-1 mt-1 mb-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                        </svg>
                        {{ 'Accéder à la discussion de groupe' | trans }}
                    </a>
                {% endif %}
                <p class="text-slate-300">{{ 'Prêt à continuer votre apprentissage ?' | trans }}</p>
            </div>
            
            {% if myCourses|length > 0 %}
                {% set lastCourse = myCourses|first %}
                <a href="{{ path('course_show', {slug: lastCourse.course.slug}) }}" class="group relative inline-flex items-center gap-3 overflow-hidden rounded-xl bg-primary px-8 py-4 font-bold text-primary-foreground transition-transform hover:scale-105 active:scale-95">
                    <span>{{ 'Reprendre :' | trans }} {{ lastCourse.course.title }}</span>
                    <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                </a>
            {% endif %}
        </div>
        {# Abstract decoration #}
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/5 blur-3xl"></div>
    </div>

    {# 2. Stats Row (3 Columns) #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {# Hours #}
        <div class="bg-card rounded-2xl border border-border p-6 shadow-sm flex items-center gap-4">
            <div class="h-12 w-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-muted-foreground">{{ 'Heures d\'apprentissage' | trans }}</p>
                <p class="text-2xl font-bold font-serif">{{ stats.hours }}h</p>
            </div>
        </div>

        {# Courses #}
        <div class="bg-card rounded-2xl border border-border p-6 shadow-sm flex items-center gap-4">
            <div class="h-12 w-12 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-muted-foreground">{{ 'Cours complétés' | trans }}</p>
                <p class="text-2xl font-bold font-serif">{{ stats.completed }}</p>
            </div>
        </div>

        {# Streak #}
        <div class="bg-card rounded-2xl border border-border p-6 shadow-sm flex items-center gap-4">
            <div class="h-12 w-12 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center">
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.54.5c2.041 0 3.41-.5 3.41-.512a3 3 0 00-.83 2.132z" clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-muted-foreground">{{ 'Série en cours' | trans }}</p>
                <p class="text-2xl font-bold font-serif text-orange-500">3 {{ 'Jours' | trans }}</p>
            </div>
        </div>
    </div>

    {# 3. My Courses Section (Grid) #}
    <div>
        <h2 class="text-2xl font-serif font-bold mb-6 flex items-center gap-2">
            {{ 'Mes Cours' | trans }}
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for item in myCourses %}
                {% set course = item.course %}
                {% set progress = item.progress %}
                
                <a href="{{ path('course_show', {slug: course.slug}) }}" class="group block h-full">
                    <div class="h-full bg-card rounded-2xl border border-border shadow-sm transition-all hover:shadow-lg hover:-translate-y-1 overflow-hidden flex flex-col">
                        {# Header Image (AspectRatio 16/9) #}
                        <div class="relative aspect-video w-full overflow-hidden bg-muted">
                            {% if course.image %}
                                <img src="{{ asset(course.image) }}" alt="{{ course.title }}" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105">
                            {% else %}
                                <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200">
                                    <svg class="h-10 w-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                    </svg>
                                </div>
                            {% endif %}
                            
                            {# Badge for progress #}
                            <div class="absolute top-3 right-3">
                                <span class="inline-flex items-center rounded-full bg-white/90 backdrop-blur-sm px-2.5 py-0.5 text-xs font-semibold text-foreground shadow-sm">
                                    {{ progress }}%
                                </span>
                            </div>
                        </div>

                        {# Content #}
                        <div class="p-5 flex-1 flex flex-col">
                            <h3 class="font-serif text-lg font-bold leading-tight mb-2 group-hover:text-primary transition-colors">
                                {{ course.title }}
                            </h3>
                            <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
                                {{ course.description|striptags|u.truncate(100, '...') ?: 'Apprenez avec les experts du Rocher.' }}
                            </p>
                            
                            <div class="mt-auto space-y-3">
                                {# Progress Bar #}
                                <div class="space-y-1">
                                    <div class="flex justify-between text-xs font-medium">
                                        <span class="text-muted-foreground">{{ progress }}% {{ 'complété' | trans }}</span>
                                    </div>
                                    <div class="h-2 w-full overflow-hidden rounded-full bg-muted">
                                        <div class="h-full bg-primary transition-all duration-500" style="width: {{ progress }}%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            {% else %}
                <div class="col-span-full py-12 text-center border-2 border-dashed border-border rounded-3xl">
                    <p class="text-muted-foreground mb-4">{{ 'Vous n\'avez pas encore commencé de cours.' | trans }}</p>
                    <a href="{{ path('course_index') }}" class="btn btn-outline">
                        {{ 'Explorer le catalogue' | trans }}
                    </a>
                </div>
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}
