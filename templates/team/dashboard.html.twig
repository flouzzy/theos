{% extends 'app.html.twig' %}

{% block title %}Gestion d'équipe{% endblock %}
{% block page_title %}{{ 'Gestion d\'Équipe' | trans }}{% endblock %}

{% block content %}
<div class="space-y-8">
    
    {% if teamsData is empty %}
        <div class="bg-card rounded-2xl p-12 text-center border-2 border-dashed border-border shadow-sm">
            <h2 class="text-2xl font-serif font-bold mb-4">{{ 'Aucune équipe trouvée' | trans }}</h2>
            <p class="text-muted-foreground mb-6">{{ 'Vous n\'avez pas encore créé d\'équipe. Contactez l\'administrateur pour activer votre rôle de Manager.' | trans }}</p>
        </div>
    {% else %}
        {% for data in teamsData %}
            {% set team = data.team %}
            <div class="bg-card rounded-2xl border border-border overflow-hidden shadow-sm">
                <div class="p-6 border-b border-border bg-muted/30 flex flex-col md:flex-row justify-between items-center gap-4">
                    <div>
                        <h2 class="text-xl font-serif font-bold text-foreground">{{ team.name }}</h2>
                        <p class="text-sm text-muted-foreground">{{ team.members|length }} {{ 'membres actifs' | trans }}</p>
                    </div>
                    
                    <form action="{{ path('team_add_member', {id: team.id}) }}" method="POST" class="flex gap-2 w-full md:w-auto">
                        <input type="email" name="email" placeholder="Email du nouveau membre" required
                               class="flex-1 md:w-64 bg-background border border-input rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary outline-none">
                        <button type="submit" class="btn btn-primary btn-sm">
                            {{ 'Ajouter' | trans }}
                        </button>
                    </form>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-xs uppercase tracking-wider text-muted-foreground bg-muted/50">
                                <th class="px-6 py-4 font-semibold">{{ 'Membre' | trans }}</th>
                                <th class="px-6 py-4 font-semibold">{{ 'Progression Globale' | trans }}</th>
                                <th class="px-6 py-4 font-semibold text-right">{{ 'Actions' | trans }}</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border">
                            {% for memberData in data.members %}
                                {% set member = memberData.user %}
                                <tr class="hover:bg-muted/30 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center font-bold text-primary">
                                                {{ member.fullname|slice(0, 1) }}
                                            </div>
                                            <div>
                                                <div class="font-bold text-foreground">{{ member.fullname }}</div>
                                                <div class="text-xs text-muted-foreground">{{ member.email }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="flex-1 h-2 bg-muted rounded-full overflow-hidden min-w-[100px]">
                                                <div class="h-full bg-primary" style="width: {{ memberData.progress }}%"></div>
                                            </div>
                                            <span class="text-sm font-semibold">{{ memberData.progress }}%</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <a href="{{ path('team_remove_member', {id: team.id, userId: member.id}) }}" 
                                           class="text-destructive hover:underline text-sm font-medium"
                                           onclick="return confirm('Êtes-vous sûr de vouloir retirer ce membre ?')">
                                            {{ 'Retirer' | trans }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                            
                            {% if team.members is empty %}
                                <tr>
                                    <td colspan="3" class="px-6 py-12 text-center text-muted-foreground italic">
                                        {{ 'Aucun membre dans cette équipe pour le moment.' | trans }}
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endfor %}
    {% endif %}

</div>
{% endblock %}
