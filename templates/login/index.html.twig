{% extends 'landing.html.twig' %}

{% block title %}
	{{'Sign in' | trans}}
{% endblock %}

{% block content %}
    <div class="container mx-auto p-4 flex justify-center items-center min-h-[calc(100vh-200px)]">
        <twig:Card class="w-full max-w-4xl overflow-hidden">
            <div class="grid grid-cols-1 md:grid-cols-12">
                <div class="md:col-span-5 bg-muted h-64 md:h-auto bg-cover bg-center hidden md:block" style="background-image: url('{{ asset('images/landing-1.png') }}')">
                    {# Optional: Placeholder image or background #}
                </div>
                <div class="md:col-span-7 p-6 md:p-8">
                    <div class="text-center mb-6">
                        <h1 class="text-2xl font-bold">{{'Sign in' | trans}}</h1>
                    </div>

                    {% if error %}
                        <div class="bg-destructive/15 text-destructive text-sm p-3 rounded-md mb-6 text-center">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form action="{{ path('login') }}" method="post" class="space-y-4">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        
                        <div class="space-y-2">
                            <twig:Label for="username">{{ 'Email' | trans }}</twig:Label>
                            <twig:Input type="text" id="username" name="_username" value="{{ last_username }}" required autocomplete="email" autofocus />
                        </div>

                        <div class="space-y-2">
                            <twig:Label for="password">{{ 'Password' | trans }}</twig:Label>
                            <twig:Input type="password" id="password" name="_password" required autocomplete="current-password" />
                        </div>

                        <div class="pt-4 text-center">
                            <twig:Button type="submit" class="w-full md:w-auto">
                                {{'Sign in' | trans}}
                            </twig:Button>
                        </div>
                    </form>

                    <div class="mt-8 text-center text-sm text-muted-foreground space-y-2">
                        <p>
                            {{ "Don't have an account yet ?" | trans }}
                            <a href="{{ path('register') }}" class="text-primary hover:underline font-medium">{{ 'Sign up' | trans }}</a>
                        </p>
                        <p>
                            {{ "Forgotten password ?" | trans }}
                            <a href="{{ path('forgot_password_request') }}" class="text-primary hover:underline font-medium">{{ 'Reset your password' | trans }}</a>
                        </p>
                    </div>
                </div>
            </div>
        </twig:Card>
    </div>
{% endblock %}
