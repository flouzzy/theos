{% extends 'landing.html.twig' %}

{% block title %}
	{{'Sign in' | trans}}
{% endblock %}

{% block content %}
	<ion-grid>
		<ion-row class="ion-justify-content-center">
			<ion-col size="12" size-sm="6">
				{% if error %}
					<div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
				{% endif %}

				<form action="{{ path('login') }}" method="post">
					<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
					<ion-list>
						<ion-list-header>
							<ion-label class="ion-text-center">
								<h1>
									{{block('title')}}
								</h1>
							</ion-label>
						</ion-list-header>
						<ion-item>
							<ion-input label="{{'Email' | trans}}" type="text" id="username" name="_username" value="{{ last_username }}"></ion-input>
						</ion-item>
						<ion-item>
							<ion-input label="{{'Password'| trans}}" type="password" id="password" name="_password"></ion-input>
						</ion-item>
						<ion-item lines="none">
							<ion-button type="submit" color="success">
								{{block('title')}}
							</ion-button>
						</ion-item>
					</ion-list>
				</form>
			</ion-col>
		</ion-row>
	</ion-grid>
{% endblock %}
