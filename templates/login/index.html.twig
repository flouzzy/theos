{% extends 'landing.html.twig' %}

{% block title %}
    {{ 'Sign in' | trans }}
{% endblock %}

{% block content %}
    <div class="container mx-auto p-4 flex flex-col justify-center items-center min-h-[calc(100vh-100px)]">
        <div class="w-full max-w-md">
            {# Logo and Header #}
            <div class="text-center mb-8">
                <div class="inline-flex h-14 w-14 rounded-xl bg-primary items-center justify-center text-white font-bold text-2xl mb-4">
                    📚
                </div>
                <h1 class="text-3xl font-bold mb-2">{{ 'Sign in' | trans }}</h1>
                <p class="text-muted-foreground">{{ 'Access your learning space' | trans }}</p>
            </div>

            {# Main Form Card #}
            {% include "partials/_flash.html.twig" %}

            {% if app.request.server.get('APP_DEMO_MODE') == 'true' %}
            <div class="mb-6 p-4 rounded-xl bg-amber-50 border-2 border-amber-200 shadow-sm">
                <h3 class="text-sm font-bold text-amber-800 mb-2 flex items-center gap-2">
                    <twig:ux:icon name="lucide:sparkles" class="w-4 h-4" />
                    Accès Démo
                </h3>
                <div class="grid grid-cols-1 gap-4 text-xs">
                    <div class="bg-white/50 p-2 rounded border border-amber-100">
                        <span class="block font-semibold text-amber-900 uppercase">Apprenant</span>
                        <code>demo@theos.lerocher.fr / demo</code>
                    </div>
                    <div class="bg-white/50 p-2 rounded border border-amber-100">
                        <span class="block font-semibold text-amber-900 uppercase">Admin</span>
                        <code>admin@theos.lerocher.fr / admin</code>
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="bg-white rounded-xl shadow-sm border border-border p-8">
                {% if error %}
                    <div class="mb-6 p-4 rounded-lg bg-destructive/10 text-destructive border border-destructive/20">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="mb-6 p-4 rounded-lg bg-success/10 text-success border border-success/20">
                        {{ 'You are logged in as' | trans }} {{ app.user.userIdentifier }}. 
                        <a href="{{ path('_logout_main') }}" class="font-semibold underline">{{ 'Logout' | trans }}</a>
                    </div>
                {% endif %}

                <form method="post">
                    {# Email Field with Icon #}
                    <div class="mb-4">
                        <label for="inputEmail" class="block text-sm font-medium mb-2">{{ 'Email' }}</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <input 
                                type="email" 
                                value="{{ last_username }}" 
                                name="_username" 
                                id="inputEmail" 
                                class="w-full pl-10 pr-3 py-3 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                                autocomplete="email" 
                                placeholder="votre@email.fr"
                                required 
                                autofocus
                            >
                        </div>
                    </div>

                    {# Password Field with Icon #}
                    <div class="mb-4">
                        <label for="inputPassword" class="block text-sm font-medium mb-2">{{ 'Password' | trans }}</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                </svg>
                            </div>
                            <input 
                                type="password" 
                                name="_password" 
                                id="inputPassword" 
                                class="w-full pl-10 pr-3 py-3 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                                autocomplete="current-password" 
                                placeholder="••••••••"
                                required
                            >
                        </div>
                    </div>

                    {# Remember Me and Forgot Password #}
                    <div class="flex items-center justify-between mb-6">
                        <div class="flex items-center">
                            <input type="checkbox" name="_remember_me" id="remember_me" class="h-4 w-4 rounded border-input text-primary focus:ring-primary">
                            <label for="remember_me" class="ml-2 text-sm text-muted-foreground">
                                {{ 'Remember me' | trans }}
                            </label>
                        </div>
                        <a href="{{ path('forgot_password_request') }}" class="text-sm text-primary hover:underline font-semibold">
                            {{ 'Forgot password?' | trans }}
                        </a>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    {# Submit Button #}
                    <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-primary-foreground font-semibold py-3 rounded-lg transition-colors">
                        {{ 'Sign in' | trans }}
                    </button>
                </form>

                {# SSO Section 
                <div class="mt-6">
                    <div class="relative flex items-center mb-6">
                        <div class="flex-grow border-t border-border"></div>
                        <span class="flex-shrink mx-4 text-xs text-muted-foreground uppercase tracking-wider font-bold">{{ 'or continue with' | trans }}</span>
                        <div class="flex-grow border-t border-border"></div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <a href="{{ path('connect_google_start') }}" class="flex items-center justify-center gap-2 py-3 px-4 border border-border rounded-lg hover:bg-slate-50 transition-colors text-sm font-semibold">
                            <twig:ux:icon name="logos:google-icon" class="w-5 h-5" />
                            Google
                        </a>
                        <a href="{{ path('connect_linkedin_start') }}" class="flex items-center justify-center gap-2 py-3 px-4 border border-border rounded-lg hover:bg-slate-50 transition-colors text-sm font-semibold">
                            <twig:ux:icon name="logos:linkedin-icon" class="w-5 h-5" />
                            LinkedIn
                        </a>
                    </div>
                </div>
                #}

                {# Sign Up Link #}
                <div class="mt-8 pt-6 border-t border-border text-center text-sm text-muted-foreground">
                    <p>
                        {{ 'No account yet?' | trans }}
                        <a href="{{ path('register') }}" class="text-primary hover:underline font-semibold">{{ 'Sign up' | trans }}</a>
                    </p>
                </div>

                {# Magic Link Section #}
                <div class="mt-6 pt-6 border-t border-border" x-data="{ showMagic: false }">
                    <button @click="showMagic = !showMagic" type="button" class="text-xs text-muted-foreground hover:text-primary transition-colors flex items-center justify-center w-full gap-2">
                        <twig:ux:icon name="lucide:wand-2" class="w-3 h-3" />
                        {{ 'Sign in without password (Magic Link)' | trans }}
                    </button>

                    <form x-show="showMagic" x-cloak action="{{ path('request_magic_link') }}" method="post" class="mt-4 animate-in fade-in slide-in-from-top-2">
                        <div class="flex gap-2">
                            <input type="email" name="email" placeholder="ton@email.com" class="flex-1 px-3 py-2 border border-input rounded-lg text-sm focus:ring-1 focus:ring-primary outline-none" required>
                            <button type="submit" class="btn btn-primary btn-sm rounded-lg px-4">
                                {{ 'Envoyer' | trans }}
                            </button>
                        </div>
                        <p class="text-[10px] text-slate-400 mt-2 text-center italic">{{ 'A temporary link will be sent to your email.' | trans }}</p>
                    </form>
                </div>
                </div>

                {# Security Notice #}
                <div class="mt-6 pt-6 border-t border-border">
                    <div class="flex items-start gap-2 text-xs text-muted-foreground">
                        <svg class="h-4 w-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </div>

            {# Security Notice #}
            <div class="mt-6 pt-6 border-t border-border">
                <div class="flex items-start gap-2 text-xs text-muted-foreground">
                    <svg class="h-4 w-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    <p>
                        {{ 'Always check the URL and the small security icon, use admin@example.fr to sign in or create your account.' | trans }}
                    </p>
                </div>
            </div>

            {# Back to Home Link #}
            <div class="text-center py-4">
                <a href="{{ path('home') }}" class="text-sm text-muted-foreground hover:text-foreground inline-flex items-center gap-1">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    {{ 'Back to home' | trans }}
                </a>
            </div>
        </div>
    </div>
{% endblock %}
