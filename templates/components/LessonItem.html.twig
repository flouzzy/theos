<div {{ attributes }}>
    {% if this.isLocked %}
        <div class="flex items-center justify-between p-4 opacity-60 cursor-not-allowed">
    {% else %}
        <a href="{{ path('lesson_show', {lessonId: this.lesson.id, moduleSlug: this.module.slug, courseSlug: this.course.slug}) }}"
           class="flex items-center justify-between p-4 hover:bg-muted/40 transition-colors group">
    {% endif %}

        <div class="flex items-center gap-4">
            {# Status Icon / Toggle #}
            <div class="flex-shrink-0">
                {% if this.isCompleted %}
                    <button
                        data-action="click->live#action"
                        data-live-action-param="toggleCompletion"
                        class="text-primary hover:text-primary/80 transition-colors flex items-center justify-center"
                        onclick="event.preventDefault(); event.stopPropagation();"
                        title="{{ 'Marquer comme non lu' | trans }}"
                    >
                        <twig:ux:icon name="lucide:check-circle" class="w-6 h-6" />
                    </button>
                {% elseif this.isLocked %}
                    <div class="text-muted-foreground flex items-center justify-center">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </div>
                {% else %}
                    <button
                        data-action="click->live#action"
                        data-live-action-param="toggleCompletion"
                        class="text-muted-foreground hover:text-primary transition-colors flex items-center justify-center"
                        onclick="event.preventDefault(); event.stopPropagation();"
                        title="{{ 'Marquer comme lu' | trans }}"
                    >
                        <twig:ux:icon name="lucide:circle" class="w-6 h-6" />
                    </button>
                {% endif %}
            </div>

            <div>
                <h4 class="text-sm font-medium group-hover:text-primary transition-colors">{{ this.lesson.title }}</h4>
            </div>
        </div>

        {# Actions #}
        <div class="flex items-center gap-4 text-xs text-muted-foreground">
            {% if not this.isLocked %}
                <button
                    data-action="live#action"
                    data-live-action-param="toggleNeedsReview"
                    class="p-1.5 rounded-lg transition-colors {{ this.needsReview ? 'text-yellow-500 bg-yellow-500/10' : 'text-muted-foreground/40 hover:bg-muted' }}"
                    onclick="event.preventDefault(); event.stopPropagation();"
                    title="{{ 'Review needed' | trans }}"
                >
                    <twig:ux:icon name="lucide:bookmark" class="w-4 h-4 {{ this.needsReview ? 'fill-current' : '' }}" />
                </button>

                <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            {% endif %}
        </div>

    {% if this.isLocked %}
        </div>
    {% else %}
        </a>
    {% endif %}
</div>
