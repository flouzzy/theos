{% if totalPages > 1 %}
    <div class="mt-8 flex items-center justify-between">
        <div class="text-sm text-slate-500">
            {{ 'Page %current% sur %total%'|trans({'%current%': currentPage, '%total%': totalPages}) }}
        </div>
        <div class="flex items-center gap-2">
            {% if currentPage > 1 %}
                <twig:Button as="a" href="{{ path(routeName, routeParams|merge({page: currentPage - 1})) }}" variant="outline" size="sm">
                    <twig:ux:icon name="lucide:chevron-left" class="w-4 h-4 mr-1" />
                    {{ 'Previous' | trans }}
                </twig:Button>
            {% endif %}

            {% if currentPage < totalPages %}
                <twig:Button as="a" href="{{ path(routeName, routeParams|merge({page: currentPage + 1})) }}" variant="outline" size="sm">
                    {{ 'Next' | trans }}
                    <twig:ux:icon name="lucide:chevron-right" class="w-4 h-4 ml-1" />
                </twig:Button>
            {% endif %}
        </div>
    </div>
{% endif %}
