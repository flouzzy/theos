<div {{ attributes }}>
    {% block fallback %}
        {% if this is not defined %}
            <div class="mt-12 pt-8 border-t border-gray-100 dark:border-slate-800 animate-pulse">
                <div class="h-8 w-64 bg-muted rounded-lg mb-6"></div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="h-48 bg-muted rounded-2xl"></div>
                    <div class="h-48 bg-muted rounded-2xl"></div>
                    <div class="h-48 bg-muted rounded-2xl"></div>
                </div>
            </div>
        {% endif %}
    {% endblock %}
    {% set recommendations = this.recommendations %}
    {% if recommendations|length > 0 %}
        <div class="mt-12 pt-8 border-t border-gray-100 dark:border-slate-800">
            <h3 class="text-xl font-serif font-bold text-gray-900 dark:text-white mb-6">{{ 'Go deeper (Suggested by AI)' | trans }}</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {% for rec in recommendations %}
                    {% set recModule = rec.module %}
                    {% set recCourse = recModule ? recModule.course : null %}
                    {% if recCourse %}
                        <a href="{{ path('lesson_show', {courseSlug: recCourse.slug, moduleSlug: recModule.slug, lessonId: rec.id}) }}" class="group bg-white dark:bg-slate-900 border border-gray-100 dark:border-slate-800 rounded-2xl p-4 shadow-sm hover:shadow-md transition-all duration-300">
                            <div class="aspect-video bg-gray-50 dark:bg-slate-800 rounded-xl mb-4 overflow-hidden relative">
                                {% if rec.videoUrl %}
                                    <div class="absolute inset-0 flex items-center justify-center bg-black/5 group-hover:bg-black/0 transition-colors">
                                        <svg class="w-10 h-10 text-white opacity-80 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                    </div>
                                {% endif %}
                            </div>
                            <h4 class="font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors line-clamp-2 mb-2">{{ rec.title }}</h4>
                            <p class="text-xs text-gray-500 dark:text-slate-400 font-medium uppercase tracking-wider">{{ recModule.title }}</p>
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>
