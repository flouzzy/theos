<div {{ attributes.defaults({class: 'bg-card border border-border rounded-2xl overflow-hidden flex flex-col hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group'}) }}>
    {# Card Image #}
    <div class="relative h-56 bg-muted">
        {% if this.course.image %}
            <img src="{{ asset(this.course.image) }}" alt="{{ this.course.title }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
        {% else %}
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-indigo-900 to-primary text-white">
                 <span class="text-4xl font-bold opacity-20">{{ this.course.title|first|upper }}</span>
            </div>
        {% endif %}

        {% if this.isSubscribed %}
            <span class="absolute top-4 right-4 bg-success text-success-foreground text-xs font-bold px-3 py-1.5 rounded-full shadow-md backdrop-blur-md bg-success/90">
                {{ 'Inscrit' | trans }}
            </span>
        {% endif %}
    </div>

    {# Card Content #}
    <div class="p-6 flex-1 flex flex-col">
        {% set activeCohort = active_cohort() %}
        {% if activeCohort %}
            <div class="mb-4">
                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-primary/10 text-primary">
                    {{ activeCohort.title }}
                </span>
            </div>
        {% endif %}

        <h3 class="font-bold text-xl mb-3 line-clamp-1 group-hover:text-primary transition-colors">
            <a href="{{ path('course_show', {slug: this.course.slug}) }}">
                {{ this.course.title }}
            </a>
        </h3>

        <p class="text-muted-foreground text-sm mb-6 line-clamp-2 leading-relaxed">
            {{ this.course.description }}
        </p>

        <div class="mt-auto pt-5 flex items-center justify-between text-sm text-muted-foreground border-t border-border/50">
            <div class="flex items-center gap-2">
               <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
               </svg>
               <span>{{ this.course.modules|length }} {{ 'modules' | trans }}</span>
            </div>
        </div>

        <div class="mt-5">
            <a href="{{ path('course_show', {slug: this.course.slug}) }}" class="flex w-full items-center justify-center rounded-xl bg-primary px-4 py-3 text-sm font-bold text-white shadow-sm hover:bg-primary/90 hover:shadow-md transition-all active:scale-95">
                {% if this.isSubscribed %}
                    {{ 'Continue' | trans }}
                {% else %}
                    {{ 'View course' | trans }}
                {% endif %}
            </a>
        </div>
    </div>
</div>
