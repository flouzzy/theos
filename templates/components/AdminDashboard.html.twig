<div{{ attributes }} class="p-6">
    {% set dashboard = this %}
    <h1 class="text-3xl font-bold text-center mb-8">{{ 'Dashboard'|trans }}</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {# Users Card #}
        <a href="{{ path('admin_user_index') }}" class="block transition-transform hover:scale-105">
            <twig:Card class="h-full text-center hover:bg-muted/50 transition-colors">
                <twig:Card:Header>
                    <twig:Card:Title class="text-xl">{{ 'Verified users'|trans }}</twig:Card:Title>
                    <twig:Card:Description>
                        {# Icon placeholder - standard User icon #}
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mt-2 h-8 w-8 text-primary"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </twig:Card:Description>
                </twig:Card:Header>
                <twig:Card:Content>
                    <p class="text-4xl font-bold text-primary">{{ dashboard.usersTotal }}</p>
                </twig:Card:Content>
            </twig:Card>
        </a>

        {# Courses Card #}
        <a href="{{ path('admin_completion_index', {_fragment:'completion-course'}) }}" class="block transition-transform hover:scale-105">
            <twig:Card class="h-full text-center hover:bg-muted/50 transition-colors">
                <twig:Card:Header>
                    <twig:Card:Title class="text-xl">{{ 'Completed courses'|trans }}</twig:Card:Title>
                    <twig:Card:Description>
                         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mt-2 h-8 w-8 text-primary"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
                    </twig:Card:Description>
                </twig:Card:Header>
                <twig:Card:Content>
                    <p class="text-4xl font-bold text-primary">{{ dashboard.coursesTotal }}</p>
                </twig:Card:Content>
            </twig:Card>
        </a>

        {# Modules Card #}
        <a href="{{ path('admin_completion_index', {_fragment:'completion-module'}) }}" class="block transition-transform hover:scale-105">
            <twig:Card class="h-full text-center hover:bg-muted/50 transition-colors">
                 <twig:Card:Header>
                    <twig:Card:Title class="text-xl">{{ 'Completed modules'|trans }}</twig:Card:Title>
                    <twig:Card:Description>
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mt-2 h-8 w-8 text-primary"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
                    </twig:Card:Description>
                </twig:Card:Header>
                <twig:Card:Content>
                     <p class="text-4xl font-bold text-primary">{{ dashboard.modulesTotal }}</p>
                </twig:Card:Content>
            </twig:Card>
        </a>

        {# Lessons Card #}
        <a href="{{ path('admin_completion_index', {_fragment:'completion-lesson'}) }}" class="block transition-transform hover:scale-105">
            <twig:Card class="h-full text-center hover:bg-muted/50 transition-colors">
                <twig:Card:Header>
                    <twig:Card:Title class="text-xl">{{ 'Completed lessons'|trans }}</twig:Card:Title>
                    <twig:Card:Description>
                         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mt-2 h-8 w-8 text-primary"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="M8 15l4 3 4-3"/></svg>
                    </twig:Card:Description>
                </twig:Card:Header>
                <twig:Card:Content>
                     <p class="text-4xl font-bold text-primary">{{ dashboard.lessonsTotal }}</p>
                </twig:Card:Content>
            </twig:Card>
        </a>
    </div>
</div>
