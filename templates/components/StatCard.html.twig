<div class="stat-card {{ class|default('') }}">
    <div class="stat-value">{{ value }}</div>
    <div class="stat-label flex items-center justify-center gap-1">
        {% block icon %}
            {% if icon|default(false) %}
                <span class="text-indigo-600 dark:text-indigo-400">{{ icon }}</span>
            {% endif %}
        {% endblock %}
        {{ label }}
    </div>
</div>
