<div {{ attributes }}
    data-controller="chat"
    data-chat-topic-value="cohort-chat-{{ cohort.id }}"
>
    <div class="flex flex-col h-[500px] bg-card border border-border rounded-xl">
        {# Header #}
        <div class="px-6 py-4 border-b border-border flex items-center justify-between">
            <div>
                <h3 class="font-bold">{{ cohort.title }} Chat</h3>
                <p class="text-xs text-muted-foreground">{{ cohort.users|count }} {{ 'membres'|trans }}</p>
            </div>
            <div class="flex items-center gap-2">
                 <span class="relative flex h-3 w-3">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                </span>
                <span class="text-xs font-medium text-green-600 dark:text-green-400">En direct</span>
            </div>
        </div>

        {# Messages area #}
        <div 
            class="flex-1 overflow-y-auto p-6 space-y-4"
            data-chat-target="messages"
            id="chat-messages-container"
        >
            {% for message in this.messages %}
                <div class="flex flex-col {{ app.user.id == message.author.id ? 'items-end' : 'items-start' }}">
                    <div class="flex items-center gap-2 mb-1">
                        {% if app.user.id != message.author.id %}
                            <span class="text-xs font-bold">{{ message.author.fullname }}</span>
                        {% endif %}
                        <span class="text-[10px] text-muted-foreground">{{ message.createdAt|date('H:i') }}</span>
                    </div>
                    <div class="px-4 py-2 rounded-2xl max-w-[80%] text-sm {{ app.user.id == message.author.id ? 'bg-primary text-primary-foreground rounded-tr-none' : 'bg-muted text-foreground rounded-tl-none' }}">
                        {{ message.content }}
                    </div>
                </div>
            {% else %}
                <div class="h-full flex items-center justify-center text-muted-foreground text-sm">
                    {{ 'Soyez le premier à envoyer un message !'|trans }}
                </div>
            {% endfor %}
        </div>

        {# Footer #}
        <div class="p-4 border-t border-border">
            <form 
                data-action="live#action:prevent" 
                data-live-action-param="sendMessage" 
                class="flex gap-2"
            >
                <input 
                    type="text" 
                    data-model="content"
                    placeholder="{{ 'Écrivez votre message...'|trans }}" 
                    class="flex-1 rounded-md border border-input bg-background px-4 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                    required
                >
                <button 
                    type="submit" 
                    class="bg-primary text-primary-foreground px-4 py-2 rounded-md hover:bg-primary/90 transition-colors flex items-center justify-center"
                >
                    <svg class="h-5 w-5 rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                </button>
            </form>
        </div>
    </div>
</div>
