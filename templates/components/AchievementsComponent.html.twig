<div {{ attributes }}>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {% for achievement in this.achievements %}
            <div class="flex flex-col items-center p-6 border border-border rounded-lg bg-background text-center hover:bg-muted/30 transition-colors">
                <div class="w-16 h-16 mb-4 flex items-center justify-center">
                    <span class="text-4xl">{{ achievement.icon }}</span>
                </div>
                <h4 class="font-bold text-sm mb-1">{{ achievement.title | trans }}</h4>
                {% if achievement.date %}
                    <span class="text-xs text-muted-foreground">📅 {{ achievement.date | date('d M Y') }}</span>
                {% endif %}
            </div>
        {% else %}
            <div class="col-span-3 text-center py-8 text-muted-foreground italic">
                {{ 'Aucune réalisation pour le moment. Continuez d\'apprendre !' | trans }}
            </div>
        {% endfor %}
    </div>
</div>
