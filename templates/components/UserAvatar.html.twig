<div class="relative group inline-block {{ wrapperClass|default('') }}">
    <div class="{{ class|default('w-10 h-10') }} rounded-full overflow-hidden border border-border bg-muted flex-shrink-0 relative shadow-sm">
        {% if user and user.activeFrame %}
            <div class="absolute inset-0 rounded-full z-10 {{ user.activeFrame.cssClass }} pointer-events-none ring-inset"></div>
        {% endif %}
        {% if user and user.image %}
            <img src="{{ asset(user.image) }}" alt="{{ user.fullname|default('Utilisateur') }}" class="w-full h-full object-cover">
        {% elseif user %}
            <div class="w-full h-full flex items-center justify-center font-bold text-muted-foreground bg-primary/5 text-primary">
                {{ user.firstname|default('')|first|upper }}{{ user.lastname|default('')|first|upper }}
            </div>
        {% else %}
            <div class="w-full h-full flex items-center justify-center bg-muted text-muted-foreground">
                <twig:ux:icon name="lucide:user" class="w-1/2 h-1/2" />
            </div>
        {% endif %}
    </div>
    {% if showBadge|default(false) %}
        <div class="absolute -bottom-1 -right-1 bg-background text-foreground text-xs w-5 h-5 rounded-full flex items-center justify-center font-bold border border-border shadow-sm">
            {{ badgeContent|default('') }}
        </div>
    {% endif %}
    {% if showName|default(false) and user %}
        <span class="sr-only">{{ user.fullname|default('Inconnu') }}</span>
    {% endif %}
</div>
