<div{{ attributes.defaults({ 'class': 'flex flex-col items-center justify-center py-12 px-4 text-center rounded-2xl border-2 border-dashed border-muted bg-muted/10' }) }}>
    {% if icon is defined and icon %}
        <div class="w-16 h-16 mb-4 rounded-full bg-muted/50 flex items-center justify-center text-muted-foreground">
            <twig:ux:icon name="{{ icon }}" class="w-8 h-8" />
        </div>
    {% endif %}
    
    <h3 class="text-lg font-heading font-semibold text-foreground">{{ title }}</h3>
    
    {% if description is defined and description %}
        <p class="text-sm text-muted-foreground mt-2 max-w-sm mx-auto">{{ description }}</p>
    {% endif %}
    
    {% if block('action') is defined %}
        <div class="mt-6">
            {% block action %}{% endblock %}
        </div>
    {% elseif actionUrl is defined and actionLabel is defined %}
        <div class="mt-6">
            <twig:Button asChild>
                <a href="{{ actionUrl }}">{{ actionLabel }}</a>
            </twig:Button>
        </div>
    {% endif %}
</div>
