<div {{ attributes }}>
    {% set notes = this.notes %}

    {# Inline Add Form (only when inside a lesson context) #}
    {% if this.lessonId %}
        <div class="bg-card border border-border rounded-xl p-4 shadow-sm mb-6">
            <div class="flex items-center gap-2 mb-3">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <h3 class="font-semibold text-sm">{{ 'Prendre une note' | trans }}</h3>
            </div>

            <textarea
                data-model="newNoteContent"
                rows="2"
                placeholder="{{ 'Écrivez votre note ici...' | trans }}"
                class="w-full bg-muted/30 border border-border rounded-lg p-3 text-sm resize-none focus:border-primary outline-none transition-colors"
            >{{ this.newNoteContent }}</textarea>

            <div class="flex justify-end mt-2">
                <button
                    data-action="click->live#action"
                    data-live-action-param="addNote"
                    class="px-4 py-1.5 bg-primary text-primary-foreground rounded-lg text-sm font-medium hover:opacity-90 transition-opacity"
                >
                    {{ 'Ajouter' | trans }}
                </button>
            </div>
        </div>
    {% endif %}

    {# Notes List #}
    {% if notes is empty %}
        <div class="py-8 text-center text-muted-foreground">
            <div class="w-12 h-12 bg-yellow-100 text-yellow-500 rounded-full flex items-center justify-center mb-3 mx-auto">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
            </div>
            <p class="text-sm">{{ 'Aucune note pour le moment' | trans }}</p>
        </div>
    {% else %}
        <div class="space-y-3">
            {% for note in notes %}
                <div class="bg-yellow-50 border border-yellow-100 rounded-xl p-4 relative group">
                    <div class="flex items-start justify-between gap-2">
                        <div class="flex-1">
                            {% if note.lesson is defined and note.lesson %}
                                <a href="{{ path('lesson_show', {courseSlug: note.lesson.module.course.slug, moduleSlug: note.lesson.module.slug, lessonId: note.lesson.id}) }}" class="text-xs font-bold text-yellow-700 uppercase tracking-wider mb-2 flex items-center gap-1 hover:text-primary transition-colors group/link">
                                    <span class="w-1.5 h-1.5 rounded-full bg-yellow-500 group-hover/link:bg-primary transition-colors"></span>
                                    {{ note.lesson.title }}
                                    <svg class="w-3 h-3 opacity-0 group-hover/link:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                    </svg>
                                </a>
                            {% endif %}
                            <p class="text-gray-800 text-sm leading-relaxed">{{ note.content }}</p>
                            <span class="text-xs text-yellow-600 mt-2 block">
                                {{ note.createdAt|date('d M Y') }}
                            </span>
                        </div>
                        <button
                            data-action="click->live#action"
                            data-live-action-param="deleteNote"
                            data-live-id-param="{{ note.id }}"
                            class="opacity-0 group-hover:opacity-100 transition-opacity p-1 text-red-400 hover:text-red-600 rounded"
                            title="{{ 'Supprimer' | trans }}"
                        >
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
