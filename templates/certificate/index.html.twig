{% extends 'base.html.twig' %}

{% block title %}{{ 'Certificate of Completion' | trans }} - {{ course.title }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-muted flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 print:bg-white print:p-0">
    <div class="max-w-4xl w-full space-y-8 bg-card p-10 rounded-xl shadow-lg border border-border print:shadow-none print:border-none">

        <!-- Header -->
        <div class="text-center space-y-2">
            <h1 class="text-4xl font-heading font-bold text-primary print:text-black">{{ app_name }}</h1>
            <p class="text-muted-foreground print:text-gray-600">{{ 'Certificate of Completion' | trans }}</p>
        </div>

        <div class="border-t-2 border-primary/20 my-8 print:border-black/20"></div>

        <!-- Content -->
        <div class="text-center space-y-6">
            <p class="text-lg text-foreground/80">{{ 'This is to certify that' | trans }}</p>

            <h2 class="text-3xl font-bold text-foreground print:text-black">
                {{ user.fullname }}
            </h2>

            <p class="text-lg text-foreground/80">{{ 'has successfully completed the course' | trans }}</p>

            <h3 class="text-2xl font-bold text-primary print:text-black">
                {{ course.title }}
            </h3>

            <p class="text-sm text-muted-foreground mt-8 print:text-gray-500">
                {{ 'Completed on' | trans }} {{ completionDate|date("d/m/Y") }}
            </p>
        </div>

        <div class="border-t-2 border-primary/20 my-8 print:border-black/20"></div>

        <!-- Signature Area (Placeholder) -->
        <div class="flex justify-between items-end mt-12 px-8">
            <div class="text-center">
                <div class="h-16 flex items-end justify-center mb-2">
                    <span class="font-serif italic text-2xl text-primary print:text-black">{{ app_company }}</span>
                </div>
                <div class="border-t border-foreground/30 w-48 mx-auto"></div>
                <p class="text-xs text-muted-foreground mt-1">{{ 'Instructor' | trans }}</p>
            </div>

            <div class="text-center">
                 <div class="h-16 flex items-end justify-center mb-2">
                    <!-- Logo placeholder -->
                    <div class="text-xl font-bold text-foreground/50">{{ app_short_name }}</div>
                </div>
                <div class="border-t border-foreground/30 w-48 mx-auto"></div>
                <p class="text-xs text-muted-foreground mt-1">{{ app_name }}</p>
            </div>
        </div>

        <!-- Actions -->
        <div class="mt-8 text-center print:hidden">
            <button onclick="window.print()" class="bg-primary text-primary-foreground hover:bg-primary/90 px-6 py-2 rounded-lg font-medium transition-colors cursor-pointer">
                {{ 'Download / Print Certificate' | trans }}
            </button>
             <a href="{{ path('course_show', {slug: course.slug}) }}" class="ml-4 text-sm text-muted-foreground hover:text-foreground underline">
                {{ 'Back to Course' | trans }}
            </a>
        </div>
    </div>
</div>
{% endblock %}
