{% extends 'landing.html.twig' %}

{% block title %}
	{{ 'Sign up' | trans }}
{% endblock %}

{% block content %}
    <div class="container mx-auto p-4 flex flex-col justify-center items-center min-h-[calc(100vh-100px)]">
        <div class="w-full max-w-md">
            {# Logo and Header #}
            <div class="text-center mb-8">
                <div class="inline-flex h-14 w-14 rounded-xl bg-primary items-center justify-center text-white font-bold text-2xl mb-4">
                    📚
                </div>
                <h1 class="text-3xl font-bold mb-2">{{ 'Sign up' | trans }}</h1>
                <p class="text-muted-foreground">{{ 'Create your account and start learning' | trans }}</p>
                
                <div class="mt-6 space-y-3">
                    <a href="{{ path('connect_google_start') }}" class="btn btn-outline w-full justify-center gap-2">
                        <twig:ux:icon name="logos:google-icon" class="w-5 h-5" />
                        {{ 'Sign up with Google' | trans }}
                    </a>
                </div>
            </div>

            {# Main Form Card #}
            <div class="bg-white rounded-xl shadow-sm border border-border p-8">
                {% if app.session.flashbag.peekAll() is not empty %}
                    <div class="mb-6">
                        {% for label, messages in app.session.flashbag.all() %}
                            {% for message in messages %}
                                <div class="p-4 rounded-lg bg-{{ label == 'success' ? 'success' : 'destructive' }}/10 text-{{ label == 'success' ? 'success' : 'destructive' }} border border-{{ label == 'success' ? 'success' : 'destructive' }}/20">
                                    {{ message | trans }}
                                </div>
                            {% endfor %}
                        {% endfor %}
                    </div>
                {% endif %}

                {% if app.session.flashbag.peekAll() is not empty %}
                         {% for flash_error in app.flashes('verify_email_error') %}
                            <div class="bg-destructive/15 text-destructive text-sm p-3 rounded-md mb-6 text-center" role="alert">{{ flash_error }}</div>
                        {% endfor %}
                    {% endif %}

                    {{ form_start(registrationForm, {'attr' : {'novalidate':'novalidate', 'class': 'space-y-4'}}) }}
                        
                        <div class="grid grid-cols-2 gap-4">
                             <div class="space-y-2">
                                {{ form_label(registrationForm.firstname) }}
                                {{ form_widget(registrationForm.firstname) }}
                                {{ form_errors(registrationForm.firstname) }}
                            </div>
                             <div class="space-y-2">
                                {{ form_label(registrationForm.lastname) }}
                                {{ form_widget(registrationForm.lastname) }}
                                {{ form_errors(registrationForm.lastname) }}
                            </div>
                        </div>


                        <div class="space-y-2">
                             {{ form_label(registrationForm.email) }}
                             {{ form_widget(registrationForm.email) }}
                             {% if registrationForm.email.vars.errors|length > 0 %}
                                <div class="flex items-start gap-2 p-3 rounded-lg bg-destructive/15 border border-destructive/50 text-destructive">
                                    <svg class="h-5 w-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                    </svg>
                                    <div class="text-sm font-medium">
                                        {{ form_errors(registrationForm.email) }}
                                    </div>
                                </div>
                             {% endif %}
                        </div>

                        <div class="space-y-2">
                             {{ form_label(registrationForm.plainPassword) }}
                            {{ form_widget(registrationForm.plainPassword) }}
                            {% if registrationForm.plainPassword.vars.errors|length > 0 %}
                                <div class="flex items-start gap-2 p-3 rounded-lg bg-destructive/15 border border-destructive/50 text-destructive">
                                    <svg class="h-5 w-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                    </svg>
                                    <div class="text-sm font-medium">
                                        {{ form_errors(registrationForm.plainPassword) }}
                                    </div>
                                </div>
                            {% endif %}
                        </div>

                        <div class="flex items-start space-x-2 pt-2">
                             {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'mt-1'}}) }}
                             <div class="grid gap-1.5 leading-none">
                                <label for="{{ registrationForm.agreeTerms.vars.id }}" class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70">
                                    {{ 'I have read and accept' | trans }} <a target="_blank" href="{{ path('page_show', {slug:'cgu'}) }}" class="text-primary hover:underline">{{ "the Terms of Use"|trans }}</a>
                                </label>
                                <div class="text-destructive text-sm">
                                    {{ form_errors(registrationForm.agreeTerms) }}
                                </div>
                             </div>
                        </div>

                        <div class="pt-6">
                            <twig:Button type="submit" class="w-full bg-primary hover:bg-primary/90 text-primary-foreground font-semibold py-3 rounded-lg">
                                {{ 'Create my account' | trans }}
                            </twig:Button>
                        </div>
                    {{ form_end(registrationForm) }}

                    <div class="mt-6 text-center text-sm text-muted-foreground">
                        <p>
                            {{ 'Already have an account ?' | trans }}
                            <a href="{{ path('login') }}" class="text-primary hover:underline font-semibold">{{ 'Sign in' | trans }}</a>
                        </p>
                    </div>
                </div>
            {# Back to Home Link - Inside the container #}
            <div class="text-center mt-6">
                <a href="{{ path('home') }}" class="text-sm text-muted-foreground hover:text-foreground inline-flex items-center gap-1">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    {{ 'Back to home' | trans }}
                </a>
            </div>
        </div>
    </div>
{% endblock %}
