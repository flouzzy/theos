{% extends "email.html.twig" %}
{% block content %}
	<h1>
		{{ user.firstname }},
		{{'Please confirm your email' | trans | lower}}
	</h1>

	<p>
		{{'Please confirm your email address by clicking the following link' | trans}}:
		<br><br>
		<button href="{{ signedUrl }}" class="small-expanded">
			{{'Confirm my Email' | trans}}
		</button>
	</p>
	<p>
		{{'Or copy the following url into your browser' | trans}}
		<a href="{{ signedUrl }}">
			{{ signedUrl }}
		</a>
	</p>
	<p>
		{{'This link will expire in' | trans}}
		{{ '1 hour' | trans }}.
	</p>
	<p>
		{{'Thank you' | trans}}!
	</p>
{% endblock %}
