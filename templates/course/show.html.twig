{% extends 'app.html.twig' %}

{% block title %}{{ course.title }}{% endblock %}

{% block page_title %}{{ 'Détails du cours' | trans }}{% endblock %}

{% block content %}
<div class="space-y-8 max-w-5xl mx-auto">
    
    {# Back Link #}
    <a href="{{ path('course_index') }}" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        {{ 'Retour aux cours' | trans }}
    </a>

    {# Course Header Card #}
    <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
        {# Cover Image #}
        <div class="h-48 md:h-64 relative bg-muted">
            {% if course.media %}
                <img src="{{ course.media.url }}" alt="{{ course.title }}" class="w-full h-full object-cover">
                 <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            {% else %}
                 <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-indigo-900 to-primary text-white">
                     <span class="text-6xl font-bold opacity-20">CODE</span>
                </div>
            {% endif %}
        </div>

        <div class="p-6 md:p-8">
            <h1 class="text-3xl font-bold mb-2">{{ course.title }}</h1>
            <p class="text-muted-foreground mb-6 max-w-2xl">{{ course.description }}</p>

            {# Stats & Progress #}
            <div class="flex flex-col md:flex-row md:items-center gap-6 text-sm">
                
                {# Lessons Completed Count #}
                <div class="flex items-center gap-2 text-success font-medium">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>{{ completedLessonIds|length }} / {{ course.lessons|length }} {{ 'leçons complétées' | trans }}</span>
                </div>

                {# Duration (Placeholder for now, could be dynamic) #}
                <div class="flex items-center gap-2 text-muted-foreground">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>4h {{ 'de contenu' | trans }}</span>
                </div>
            </div>
        </div>
    </div>

    {# Modules List #}
    <div class="space-y-6">
        {% for module in course.modules|sort((a, b) => a.itemOrder <=> b.itemOrder) %}
            <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
                {# Module Header #}
                <div class="bg-muted/30 px-6 py-4 border-b border-border flex justify-between items-center">
                    <h3 class="font-bold text-lg">{{ module.title }}</h3>
                    <span class="text-xs text-muted-foreground font-medium">
                         {{ module.lessons|length }}
                    </span>
                </div>
                
                 {# Progress Bar for Module (Optional - sticking to simpler list for now per mockup) #}
                 <div class="h-1 w-full bg-border">
                    <div class="h-full bg-primary" style="width: 50%"></div> {# Mocked 50% #}
                 </div>

                {# Lessons List #}
                <div class="divide-y divide-border">
                    {% for lesson in module.lessons|sort((a, b) => a.itemOrder <=> b.itemOrder) %}
                        {% set isCompleted = lesson.id in completedLessonIds %}
                        {% set isLocked = not isSubscribed and lesson.itemOrder > 1 %} {# Simple logic: lock if not subscribed #}

                        <a href="{{ path('lesson_show', {slug: lesson.slug, moduleSlug: module.slug, courseSlug: course.slug}) }}" 
                           class="flex items-center justify-between p-4 hover:bg-muted/40 transition-colors group {{ isLocked ? 'opacity-60 pointer-events-none' : '' }}">
                            
                            <div class="flex items-center gap-4">
                                {# Status Icon #}
                                <div class="flex-shrink-0">
                                    {% if isCompleted %}
                                        <div class="w-6 h-6 rounded-full bg-success text-white flex items-center justify-center">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                            </svg>
                                        </div>
                                    {% elseif isLocked %}
                                         <div class="w-6 h-6 rounded-full border-2 border-muted-foreground text-muted-foreground flex items-center justify-center">
                                             <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                            </svg>
                                        </div>
                                    {% else %}
                                        <div class="w-6 h-6 rounded-full border-2 border-muted-foreground group-hover:border-primary transition-colors"></div>
                                    {% endif %}
                                </div>

                                <div>
                                    <h4 class="text-sm font-medium group-hover:text-primary transition-colors">{{ lesson.title }}</h4>
                                </div>
                            </div>

                            {# Duration / Arrow #}
                            <div class="flex items-center gap-4 text-xs text-muted-foreground">
                                <span>15 min</span>
                                {% if not isLocked %}
                                    <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                {% endif %}
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
