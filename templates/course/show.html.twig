{% extends 'app.html.twig' %}

{% block title %}{{ course.title|trans }}{% endblock %}

{% block page_title %}{{ 'Détails du cours' | trans }}{% endblock %}

{% block content %}
<div class="space-y-8 max-w-5xl mx-auto">
    
    {# Back Link #}
    <a href="{{ path('course_index') }}" class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        {{ 'Retour aux cours' | trans }}
    </a>

    {# Course Header Card #}
    <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
        {# Cover Image #}
        <div class="h-48 md:h-64 relative bg-muted">
            {% if course.image %}
                <img src="{{ asset(course.image) }}" alt="{{ course.title }}" class="w-full h-full object-cover">
                 <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            {% else %}
                 <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-indigo-900 to-primary text-white">
                     <span class="text-6xl font-bold opacity-20">CODE</span>
                </div>
            {% endif %}
        </div>

        <div class="p-6 md:p-8">
            <h1 class="text-3xl font-bold mb-2">{{ course.title|trans }}</h1>
            <p class="text-muted-foreground mb-6 max-w-2xl">{{ course.description }}</p>

            {# Stats & Progress #}
            <div class="flex flex-col md:flex-row md:items-center gap-6 text-sm">
                
                {# Lessons Completed Count #}
                <div class="flex items-center gap-2 text-success font-medium">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>{{ completedLessonIds|length }} / {{ course.lessons|length }} {{ 'leçons complétées' | trans }}</span>
                </div>

                {# Duration (Placeholder for now, could be dynamic) #}
                <div class="flex items-center gap-2 text-muted-foreground">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>4h {{ 'de contenu' | trans }}</span>
                </div>

                {# Certificate #}
                {% if isCompleted %}
                    <a href="{{ path('certificate_show', {id: course.id}) }}" class="flex items-center gap-2 text-primary font-medium hover:underline" target="_blank">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>{{ 'Télécharger le certificat' | trans }}</span>
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

    {# Modules List #}
    <div class="space-y-6">
        {% for module in course.modules|sort((a, b) => a.itemOrder <=> b.itemOrder) %}
            <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
                {# Module Header #}
                <div class="bg-muted/30 px-6 py-4 border-b border-border flex justify-between items-center">
                    <h3 class="font-bold text-lg">{{ module.title }}</h3>
                    <span class="text-xs text-muted-foreground font-medium">
                         {{ module.lessons|length }}
                    </span>
                </div>
                
                 {# Progress Bar for Module (Optional - sticking to simpler list for now per mockup) #}
                 <div class="h-1 w-full bg-border">
                    <div class="h-full bg-primary" style="width: 50%"></div> {# Mocked 50% #}
                 </div>

                {# Lessons List #}
                <div class="divide-y divide-border">
                    {% for lesson in module.sortedLessons %}
                        {% set isLessonCompleted = lesson.id in completedLessonIds %}
                        {% set isLessonLocked = false %}

                        {{ component('LessonItem', {
                            lesson: lesson,
                            module: module,
                            course: course,
                            isCompleted: isLessonCompleted,
                            isLocked: isLessonLocked
                        }) }}
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
