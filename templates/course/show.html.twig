{% extends 'ionic.html.twig' %}

{% block title %}
	{{course.title}}
{% endblock %}

{% block content %}
	{% include "course/_item_signup.html.twig" %}
	{% include "course/_item.html.twig" %}
	{% include "course/_item_signup.html.twig" %}

	{% block menuBackButton %}
		<ion-button href="{{path('course_index')}}">
			<ion-icon name="arrow-back-outline"></ion-icon>
			{{'Back' | trans}}
		</ion-button>
	{% endblock %}

	{% block menuHeaderButtons %}
		<ion-buttons slot="end">
			{% if is_granted('ROLE_ADMIN') %}
				<ion-button href="{{path('admin_course_edit', {id:course.id})}}" target="_blank">
					<ion-icon name="create-outline"></ion-icon>
				</ion-button>
			{% endif %}
		</ion-buttons>
	{% endblock %}
{% endblock %}
