{# Modules #}
{% for module in course.modules %}
	<ion-card>
		<ion-card-header>
			<ion-card-title>{{module.title}}</ion-card-title>
		</ion-card-header>
		<ion-card-content>
			{{module.description}}
			{% include "course/_item_module_list.html.twig" %}
		</ion-card-content>
	</ion-card>
{% endfor %}
