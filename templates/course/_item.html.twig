<ion-grid>
	<ion-row>
		<ion-col size="12" size-sm="3">
			{% include "course/_item_teacher.html.twig" %}
		</ion-col>
		<ion-col size="12" size-sm="9">
			<ion-card>
				<img alt="{{'Course poster' | trans}}" src="{{asset(course.image)}}"/>
				<ion-card-header>
					<ion-card-title>{{course.title}}</ion-card-title>
				</ion-card-header>
				<ion-card-content>
					{{course.description}}
				</ion-card-content>
			</ion-card>
			{% include "course/_item_details.html.twig" %}
		</ion-col>
	</ion-row>
</ion-grid>
