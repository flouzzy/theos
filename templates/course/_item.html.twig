<ion-grid>
	<ion-row>
		<ion-col size="12" size-sm="3">
			<ion-card>
				<img alt="{{'Course poster' | trans}}" src="{{asset(course.author.image)}}"/>
				<ion-card-header>
					<ion-card-title>{{'Your teacher' | trans}}</ion-card-title>
					<ion-card-subtitle>
						{{course.author.fullname}}
					</ion-card-subtitle>
				</ion-card-header>
				<ion-card-content>
					{{course.author.bio}}
				</ion-card-content>
			</ion-card>
		</ion-col>
		<ion-col size="12" size-sm="9">
			<ion-card>
				<img alt="{{'Course poster' | trans}}" src="{{asset(course.image)}}"/>
				<ion-card-header>
					<ion-card-title>{{course.title}}</ion-card-title>
				</ion-card-header>
				<ion-card-content>
					{{course.description}}
				</ion-card-content>
			</ion-card>
		</ion-col>
	</ion-row>
</ion-grid>
