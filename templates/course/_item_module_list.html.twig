<ion-list>
	{% for lesson in module.lessons|sort((a, b) => a.itemOrder <=> b.itemOrder) %}
		<ion-item {% if lesson.status == 'published' %} href="{{path('lesson_show', {courseSlug:course.slug, moduleSlug:module.slug, lessonId:lesson.id})}}" {% endif %}>
			{% if lesson.status == 'published' %}
				{% set completedIcon = lesson.id in completedLessonIds ? 'checkmark-circle': 'ellipse' %}
				<ion-icon slot="start" name="{{completedIcon}}-outline" color="app"></ion-icon>
			{% endif %}
			<ion-label>
				{{lesson.title}}
				{% if lesson.status != 'published' %}
					<ion-chip color="danger">
						{{'Coming soon' | trans}}
					</ion-chip>
				{% endif %}
			</ion-label>
			{% if lesson.status == 'published' %}
				{% set buttonTitle = isSubscribed ? 'Start' : 'Preview' %}
				<ion-button slot="end" color="app" class="ion-hide-sm-down">
					{{buttonTitle | trans}}
				</ion-button>
			{% endif %}
		</ion-item>
	{% endfor %}
</ion-list>
