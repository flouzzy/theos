<ion-card>
	<ion-img class="ion-hide-sm-down" alt="{{'Course poster' | trans}}" src="{{asset(course.author.image)}}"></ion-img>
	<ion-card-header>
		<ion-card-title>{{'Your teacher' | trans}}</ion-card-title>
		<ion-card-subtitle>
			{{course.author.fullname}}
		</ion-card-subtitle>
	</ion-card-header>
	<ion-card-content>
		{{course.author.bio | sanitize_html}}
	</ion-card-content>
</ion-card>
