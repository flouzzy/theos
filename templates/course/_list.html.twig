<ion-grid>
	<ion-row>
		{% for course in courses %}
			<ion-col size="12" size-sm="4">
				<ion-card>
					<ion-item href="{{path('course_show', {slug:course.slug})}}">
						<img alt="{{'Course poster' | trans}}" src="{{asset(course.image)}}"/>
						<ion-card-header>
							<ion-card-title>{{course.title}}</ion-card-title>
							<ion-card-subtitle>
								{{'By' | trans}}
								{{course.author.firstname}}
							</ion-card-subtitle>
						</ion-card-header>

						<ion-card-content>
							{{course.description|u.truncate(200, '...')}}
						</ion-card-content>
					</ion-item>
				</ion-card>
			</ion-col>
		{% endfor %}
	</ion-row>
</ion-grid>
