<ion-grid>
	<ion-row>
		{% for course in courses %}
			<ion-col size="12" size-sm="4">
				<ion-item {% if course.status == 'published' %} href="{{path('course_show', {slug:course.slug})}}" {% endif %} lines="none">
					<ion-card>
						<img alt="{{'Course poster' | trans}}" src="{{asset(course.image)}}"/>
						<ion-card-header>
							<ion-card-title>{{course.title|u.truncate(40, '...')}}</ion-card-title>
							<ion-card-subtitle>
								{{'By' | trans}}
								{{course.author.firstname}}
							</ion-card-subtitle>
						</ion-card-header>

						<ion-card-content>
							{% set truncatContent = course.status == 'progress' ? 50 :200  %}
							{{course.description|u.truncate(truncatContent, '...')}}
							{% if course.status == 'progress' %}
								<ion-chip color="danger">
									{{'Coming soon' | trans}}
								</ion-chip>
							{% endif %}
						</ion-card-content>
					</ion-card>
				</ion-item>
			</ion-col>
		{% else %}
			<ion-col size="12" class="ion-text-center">
				{{'No course available' | trans}}
			</ion-col>
			<ion-col size="12" class="ion-text-center">
				<ion-button color="success" href="{{path('course_index')}}">{{'Start now' | trans}}</ion-button>
			</ion-col>
		{% endfor %}
	</ion-row>
</ion-grid>
