{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen bg-background" x-data="{ mobileMenuOpen: false }">
    
    {# Desktop Sidebar - Fixed Left #}
    <aside class="hidden lg:fixed lg:inset-y-0 lg:flex lg:w-64 lg:flex-col bg-white border-r border-border">
        <div class="flex grow flex-col gap-y-5 overflow-y-auto px-6">
            {# Logo #}
            <div class="flex h-16 shrink-0 items-center gap-2">
                <div class="h-10 w-10 rounded-lg bg-primary flex items-center justify-center text-white font-bold text-lg">
                    📚
                </div>
                <div>
                    <span class="text-base font-semibold">Le Rocher</span><br>
                    <span class="text-sm text-muted-foreground">Académie</span>
                </div>
            </div>
            
            {# Navigation #}
            <nav class="flex flex-1 flex-col gap-1">
                {% include 'partials/_menu.html.twig' %}
            </nav>
            
            {# User Profile Footer #}
            <div class="mt-auto pb-4">
                {% if app.user %}
                    <div class="flex items-center gap-3 px-3 py-2 border-t border-border pt-4">
                        <div class="h-10 w-10 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-semibold">
                            {{ app.user.firstname|first }}{{ app.user.lastname|first }}
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold truncate">{{ app.user.firstname }} {{ app.user.lastname }}</p>
                            <p class="text-xs text-muted-foreground truncate">Promo 2024</p>
                        </div>
                    </div>
                    <a href="{{ path('_logout_main') }}" class="mt-2 flex items-center gap-2 px-3 py-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        <span>{{ 'Déconnexion' | trans }}</span>
                    </a>
                {% endif %}
            </div>
        </div>
    </aside>

    {# Mobile Menu Overlay #}
    <div x-show="mobileMenuOpen" 
         x-transition:enter="transition-opacity ease-linear duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition-opacity ease-linear duration-300"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @click="mobileMenuOpen = false"
         class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 lg:hidden"
         style="display: none;">
    </div>

    {# Mobile Slide-out Menu #}
    <aside x-show="mobileMenuOpen"
           x-transition:enter="transition ease-in-out duration-300 transform"
           x-transition:enter-start="-translate-x-full"
           x-transition:enter-end="translate-x-0"
           x-transition:leave="transition ease-in-out duration-300 transform"
           x-transition:leave-start="translate-x-0"
           x-transition:leave-end="-translate-x-full"
           @click.away="mobileMenuOpen = false"
           class="fixed inset-y-0 left-0 z-50 w-80 bg-white shadow-xl lg:hidden overflow-y-auto"
           style="display: none;">
        
        <div class="flex flex-col h-full">
            {# Header with Close Button #}
            <div class="flex items-center justify-between p-4 border-b border-border">
                <div class="flex items-center gap-2">
                    <div class="h-10 w-10 rounded-lg bg-primary flex items-center justify-center text-white font-bold text-lg">
                        📚
                    </div>
                    <div>
                        <span class="text-base font-semibold">Le Rocher</span><br>
                        <span class="text-sm text-muted-foreground">Académie</span>
                    </div>
                </div>
                <button @click="mobileMenuOpen = false" class="p-2 hover:bg-muted rounded-lg">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            
            {# Navigation Items #}
            <nav class="flex-1 px-4 py-6 space-y-1">
                {% include 'partials/_menu.html.twig' %}
            </nav>
            
            {# User Profile Footer #}
            {% if app.user %}
                <div class="border-t border-border p-4">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="h-12 w-12 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-semibold text-lg">
                            {{ app.user.firstname|first }}{{ app.user.lastname|first }}
                        </div>
                        <div>
                            <p class="font-semibold">{{ app.user.firstname }} {{ app.user.lastname }}</p>
                            <p class="text-sm text-muted-foreground">Promo 2024</p>
                        </div>
                    </div>
                    <a href="{{ path('_logout_main') }}" class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        <span>{{ 'Déconnexion' | trans }}</span>
                    </a>
                </div>
            {% endif %}
        </div>
    </aside>

    {# Main Content Area #}
    <div class="lg:pl-64">
        {# Top Bar (Mobile) #}
        <div class="sticky top-0 z-30 flex h-14 items-center gap-x-4 border-b border-border bg-white px-4 shadow-sm lg:hidden">
            <button @click="mobileMenuOpen = true" class="p-2 hover:bg-muted rounded-lg -ml-2">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
            <span class="text-base font-semibold">Le Rocher Académie</span>
        </div>

        {# Page Content #}
        <main class="py-6 px-4 lg:px-8">
            {% include "partials/_flash.html.twig" %}
            {% include "partials/_warning.html.twig" %}
            {% block content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
