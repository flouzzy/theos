{% extends "base.html.twig" %}

{% block body %}
<div class="flex h-screen bg-background text-foreground overflow-hidden">
    {# Mobile Menu Overlay #}
    <div x-data="{ sidebarOpen: false }">
        {# Backdrop #}
        <div 
            x-show="sidebarOpen"
            @click="sidebarOpen = false"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 lg:hidden"
        ></div>

        {# Sidebar - Desktop & Mobile Slide-out #}
        <aside 
            :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'"
            class="fixed lg:static inset-y-0 left-0 z-50 w-72 flex flex-col border-r bg-card transform transition-transform duration-300 ease-in-out lg:translate-x-0"
        >
            {# Logo & Close Button #}
            <div class="p-4 border-b h-16 flex items-center justify-between">
                <div class="flex items-center">
                    <img src="{{ asset('images/logo.svg') }}" alt="Logo le rocher Academie" class="h-10 w-auto">
                    <span class="ml-3 font-bold text-lg">Académie</span>
                </div>
                <button 
                    @click="sidebarOpen = false"
                    class="lg:hidden text-muted-foreground hover:text-foreground transition-colors"
                >
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            {# Navigation Menu #}
            <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-1 scrollbar-thin scrollbar-thumb-muted">
                {% block menu %}
                    {% include "partials/_menu.html.twig" %}
                {% endblock %}
            </nav>

            {# Sidebar Footer - User Profile #}
            <div class="p-4 border-t">
                {% block menuFooter %}
                    {% if app.user %}
                        <div class="flex items-center space-x-3 px-2 py-2 rounded-lg hover:bg-muted/50 transition-colors">
                            <div class="flex-shrink-0">
                                <div class="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-semibold">
                                    {{ app.user.firstname[:1] }}{{ app.user.lastname[:1] }}
                                </div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium truncate">
                                    {{ app.user.firstname }} {{ app.user.lastname }}
                                </p>
                                <p class="text-xs text-muted-foreground truncate">
                                    {{ app.user.email }}
                                </p>
                            </div>
                        </div>
                    {% endif %}
                {% endblock %}
            </div>
        </aside>

        {# Main Content Area #}
        <div class="flex-1 flex flex-col overflow-hidden">
            {# Top Header Bar #}
            <header class="h-16 flex items-center justify-between px-4 lg:px-6 border-b bg-card">
                {# Mobile Menu Button #}
                <button 
                    @click="sidebarOpen = true"
                    class="lg:hidden text-muted-foreground hover:text-foreground transition-colors p-2 -ml-2"
                >
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"  d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>

                {# Page Title #}
                <h1 class="text-xl font-semibold truncate flex-1 lg:ml-0">
                    {% block pageTitle %}
                        {{ block('title') }}
                    {% endblock %}
                </h1>

                {# Header Actions #}
                <div class="flex items-center space-x-2">
                    {% block menuHeaderButtons %}
                        {% include "notification/_notification_icon.html.twig" %}
                        {% include "profile/_header_icon.html.twig" %}
                    {% endblock %}
                </div>
            </header>

            {# Main Content Scroll Area #}
            <main class="flex-1 overflow-x-hidden overflow-y-auto bg-muted/20 p-4 lg:p-6">
                {% include "partials/_flash.html.twig" %}
                {% include "partials/_warning.html.twig" %}
                
                <turbo-frame id="frame_app" data-turbo-action="advance">
                    {% block content %}{% endblock %}
                </turbo-frame>
            </main>

            {# Footer #}
            <footer class="p-4 text-center text-sm text-muted-foreground border-t bg-card">
                {{'now' | date('Y')}} &copy; Le Rocher Académie. {{'All rights reserved' | trans}}.
            </footer>
        </div>
    </div>

    {# Alpine.js for mobile menu toggle #}
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
</div>
{% endblock %}
