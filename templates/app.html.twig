{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen bg-background {{ app.user ? 'pb-16 lg:pb-0' : '' }}" x-data="{ mobileMenuOpen: false, moreMenuOpen: false, desktopSidebarOpen: true }">
    
    {# Desktop Sidebar - Fixed Left #}
    <aside id="desktop-sidebar" data-turbo-permanent="true" class="hidden lg:fixed lg:inset-y-0 lg:left-0 lg:top-0 lg:bottom-0 lg:flex lg:flex-col lg:w-64 bg-sidebar border-r border-border transition-all duration-300 z-40"
           :class="desktopSidebarOpen ? 'lg:w-64' : 'lg:w-20'">
        <div class="flex grow flex-col gap-y-5 overflow-y-auto px-6 py-6" :class="!desktopSidebarOpen && 'px-3'">
            {# Logo #}
            <div class="flex h-16 shrink-0 items-center justify-between">
                <div class="flex items-center gap-3 overflow-hidden">
                    {% set activeCohort = active_cohort() %}
                    {% set logoUrl = (activeCohort and activeCohort.logoPath) ? asset(activeCohort.logoPath) : asset('images/logo.png') %}
                    <img src="{{ logoUrl }}" alt="Logo" class="h-16 w-auto shrink-0 transition-all duration-300" :class="!desktopSidebarOpen && 'scale-75 origin-left'" />
                </div>
                <button @click="desktopSidebarOpen = !desktopSidebarOpen" class="hidden lg:flex p-1.5 rounded-lg text-muted-foreground hover:bg-muted hover:text-foreground transition-colors">
                    <svg class="w-5 h-5 transition-transform duration-300" :class="!desktopSidebarOpen && 'rotate-180'" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                    </svg>
                </button>
            </div>

            {# Navigation #}
            {% include 'partials/_sidebar_navigation.html.twig' %}

            {# User Profile Footer #}
            <div class="mt-auto pb-4">
                {% if app.user %}
                    <a href="{{ path('profile_index') }}" class="flex items-center gap-3 px-3 py-2 border-t border-border pt-4 overflow-hidden hover:bg-muted/50 transition-colors rounded-xl mx-2 cursor-pointer group">
                        <div class="h-10 w-10 shrink-0 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-semibold shadow-sm group-hover:scale-105 transition-transform">
                            {{ app.user.firstname|first }}{{ app.user.lastname|first }}
                        </div>
                        <div class="flex-1 min-w-0 transition-opacity duration-200" :class="!desktopSidebarOpen && 'opacity-0 w-0'">
                            <p class="text-sm font-semibold truncate">{{ app.user.firstname }} {{ app.user.lastname }}</p>
                            {% set activeCohort = active_cohort() %}
                            {% if activeCohort %}
                                <p class="text-xs text-muted-foreground truncate">{{ activeCohort.title }}</p>
                            {% endif %}

                        </div>
                    </a>
                    <a href="{{ path('offline') }}" class="mt-2 flex items-center gap-2 px-3 py-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
                        <twig:ux:icon name="lucide:download-cloud" class="h-4 w-4 shrink-0" />
                        <span :class="!desktopSidebarOpen && 'hidden'">{{ 'Mode Hors-ligne' | trans }}</span>
                    </a>
                    <a href="{{ path('_logout_main') }}" class="mt-2 flex items-center gap-2 px-3 py-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
                        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        <span :class="!desktopSidebarOpen && 'hidden'">{{ 'Déconnexion' | trans }}</span>
                    </a>
                {% endif %}
            </div>
        </div>
    </aside>

    {# Mobile Menu Overlay #}
    <div x-show="mobileMenuOpen" 
         x-transition:enter="transition-opacity ease-linear duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition-opacity ease-linear duration-300"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @click="mobileMenuOpen = false"
         class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 lg:hidden"
         style="display: none;">
    </div>

    {# Mobile Slide-out Menu #}
    <aside x-show="mobileMenuOpen"
           x-transition:enter="transition ease-in-out duration-300 transform"
           x-transition:enter-start="-translate-x-full"
           x-transition:enter-end="translate-x-0"
           x-transition:leave="transition ease-in-out duration-300 transform"
           x-transition:leave-start="translate-x-0"
           x-transition:leave-end="-translate-x-full"
           @click.away="mobileMenuOpen = false"
           class="fixed inset-y-0 left-0 z-[60] w-80 bg-sidebar shadow-xl lg:hidden overflow-y-auto"
           style="display: none;">
        
        <div class="flex flex-col h-full">
            {# Header with Close Button #}
            <div class="flex items-center justify-between p-4 border-b border-border">
                <div class="flex items-center gap-2 overflow-hidden">
                    <img src="{{ asset('images/logo.png') }}" alt="Le Rocher Académie" class="h-16 w-auto shrink-0" />
                </div>
                <button @click="mobileMenuOpen = false" class="p-2 hover:bg-muted rounded-lg">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            
            {# Navigation Items #}
            <div class="flex-1 px-4 py-6">
                {% set desktopSidebarOpen = true %}
                {% include 'partials/_sidebar_navigation.html.twig' %}
            </div>
            
            {# User Profile Footer #}
            {% if app.user %}
                <div class="border-t border-border p-4">
                    <a href="{{ path('profile_index') }}" class="flex items-center gap-3 mb-3 hover:bg-muted/50 p-2 -mx-2 rounded-xl transition-colors cursor-pointer group">
                        <div class="h-12 w-12 shrink-0 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-semibold text-lg group-hover:scale-105 transition-transform">
                            {{ app.user.firstname|first }}{{ app.user.lastname|first }}
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold truncate">{{ app.user.firstname }} {{ app.user.lastname }}</p>
                            {% if activeCohort %}
                                <p class="text-sm text-muted-foreground truncate">{{ activeCohort.title }}</p>
                            {% endif %}
                        </div>
                    </a>
                    <a href="{{ path('_logout_main') }}" class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        <span>{{ 'Déconnexion' | trans }}</span>
                    </a>
                </div>
            {% endif %}
        </div>
    </aside>

    {# Mobile More Menu Drawer #}
    <div x-show="moreMenuOpen" 
         class="fixed inset-0 z-[70] lg:hidden"
         x-cloak
         style="display: none;">
         
         {# Backdrop #}
         <div x-transition:enter="transition-opacity ease-linear duration-300"
              x-transition:enter-start="opacity-0"
              x-transition:enter-end="opacity-100"
              x-transition:leave="transition-opacity ease-linear duration-300"
              x-transition:leave-start="opacity-100"
              x-transition:leave-end="opacity-0"
              @click="moreMenuOpen = false"
              class="absolute inset-0 bg-black/60 backdrop-blur-sm">
         </div>

         {# Drawer #}
         <div x-transition:enter="transition ease-out duration-300 transform"
              x-transition:enter-start="translate-y-full"
              x-transition:enter-end="translate-y-0"
              x-transition:leave="transition ease-in duration-300 transform"
              x-transition:leave-start="translate-y-0"
              x-transition:leave-end="translate-y-full"
              class="absolute bottom-0 left-0 right-0 bg-background rounded-t-3xl shadow-2xl max-h-[85vh] overflow-y-auto w-full">
              
              <div class="p-6 space-y-6">
                   {# Handle #}
                   <div class="w-12 h-1.5 bg-muted-foreground/20 rounded-full mx-auto mb-2"></div>
                   
                   <div class="text-center mb-6">
                        <h2 class="text-xl font-bold">{{ 'Menu Principal' | trans }}</h2>
                   </div>

                   <div class="grid grid-cols-2 gap-4">
                        {# Leaderboard #}
                        <a href="{{ path('leaderboard_index') }}" class="bg-indigo-50 hover:bg-indigo-100 border-2 border-indigo-100 dark:border-indigo-900/50 p-4 rounded-2xl flex flex-col items-center gap-3 transition-colors">
                            <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                                </svg>
                            </div>
                            <span class="font-bold text-gray-700">{{ 'Classement' | trans }}</span>
                        </a>

                        {# Notifications #}
                        <a href="{{ path('notification_index') }}" class="bg-green-50 hover:bg-green-100 border-2 border-green-100 dark:border-green-900/50 p-4 rounded-2xl flex flex-col items-center gap-3 transition-colors relative">
                            <div class="w-12 h-12 bg-green-100 text-green-600 rounded-full flex items-center justify-center">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                                </svg>
                            </div>
                            <span class="font-bold text-gray-700">{{ 'Notifications' | trans }}</span>
                        </a>

                        {# Coach IA #}
                        {% if coach_enabled() %}
                        <a href="{{ path('coach_index') }}" class="bg-purple-50 hover:bg-purple-100 border-2 border-purple-100 dark:border-purple-900/50 p-4 rounded-2xl flex flex-col items-center gap-3 transition-colors">
                            <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-full flex items-center justify-center">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                                </svg>
                            </div>
                            <span class="font-bold text-gray-700">{{ 'Coach IA' | trans }}</span>
                        </a>
                        {% endif %}

                        {# Profil #}
                        <a href="{{ path('profile_index') }}" class="bg-blue-50 hover:bg-blue-100 border-2 border-blue-100 p-4 rounded-2xl flex flex-col items-center gap-3 transition-colors">
                            <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                            </div>
                            <span class="font-bold text-gray-700">{{ 'Profil' | trans }}</span>
                        </a>

                        {# Admin #}
                        {% if is_granted('ROLE_ADMIN') %}
                         <a href="{{ path('admin') }}" class="bg-gray-50 hover:bg-gray-100 border-2 border-gray-100 dark:border-gray-800 p-4 rounded-2xl flex flex-col items-center gap-3 transition-colors col-span-2">
                            <div class="w-8 h-8 bg-gray-200 text-gray-700 rounded-full flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </div>
                            <span class="font-bold text-gray-700">{{ 'Admin' | trans }}</span>
                        </a>
                        {% endif %}
                   </div>
                   
                   <div class="mt-8 pt-4 border-t border-border">
                        <button @click="moreMenuOpen = false" class="w-full btn bg-muted text-foreground font-bold rounded-xl py-3">
                            {{ 'Fermer' | trans }}
                        </button>
                   </div>
              </div>
         </div>
    </div>

    {# Main Content Area #}
    <div class="lg:pl-64 transition-all duration-300 flex flex-col min-h-screen" 
         :class="desktopSidebarOpen ? 'lg:pl-64' : 'lg:pl-20'">
        
        {# Unified Header #}
        <header class="sticky top-0 z-30 flex h-16 items-center gap-x-4 border-b border-border bg-background/80 backdrop-blur-md px-4 lg:px-8 shadow-sm transition-all duration-300">
            {# Mobile Menu Toggle #}
            <button @click="mobileMenuOpen = true" class="p-2 hover:bg-muted rounded-lg -ml-2 lg:hidden">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>

            {# Page Title #}
            <div class="flex-1 min-w-0">
                <h1 class="text-base lg:text-lg font-bold truncate">
                    {% block page_title %}{{ block('title') }}{% endblock %}
                </h1>
            </div>

            {# Right: Actions & Stats #}
            <div class="flex items-center gap-3">
                 {% block toolbar_right %}
                    {# Language Switcher #}
                    <div class="relative" x-data="{ open: false }">
                        <button @click="open = !open" class="flex items-center gap-1.5 p-2 hover:bg-muted rounded-full transition-colors text-muted-foreground hover:text-foreground">
                            <twig:ux:icon name="lucide:languages" class="w-5 h-5" />
                            <span class="text-xs font-bold uppercase">{{ app.request.locale }}</span>
                        </button>
                        <div x-show="open" @click.away="open = false" 
                             class="absolute right-0 mt-2 w-32 bg-background border border-border rounded-xl shadow-xl z-50 py-1 overflow-hidden"
                             x-transition:enter="transition ease-out duration-100"
                             x-transition:enter-start="transform opacity-0 scale-95"
                             x-transition:enter-end="transform opacity-100 scale-100"
                             style="display: none;"
                        >
                            <a href="{{ path('app_change_locale', {locale: 'fr'}) }}" class="block px-4 py-2 text-sm hover:bg-muted transition-colors {{ app.request.locale == 'fr' ? 'font-bold text-primary' : '' }}">Français</a>
                            <a href="{{ path('app_change_locale', {locale: 'en'}) }}" class="block px-4 py-2 text-sm hover:bg-muted transition-colors {{ app.request.locale == 'en' ? 'font-bold text-primary' : '' }}">English</a>
                        </div>
                    </div>

                    {% if app.user %}
                        <twig:StreakBadge streak="{{ app.user.streak }}" size="sm" showValue="true" class="bg-muted px-2.5 py-1 rounded-full ring-1 ring-border" />
                    {% endif %}
                 {% endblock %}
            </div>
        </header>

        {# Page Content #}
        <main class="py-6 px-4 lg:px-8 flex-1">
            <div class="max-w-7xl mx-auto">
                {% include "partials/_flash.html.twig" %}
                {% include "partials/_warning.html.twig" %}
                {% block content %}{% endblock %}
            </div>
        </main>
    </div>

    {# Mobile Bottom Navigation (Fixed) #}
    {% if app.user %}
    <nav id="mobile-bottom-nav" data-turbo-permanent="true" class="fixed bottom-0 left-0 right-0 z-[60] bg-background/95 backdrop-blur-md border-t border-border lg:hidden pb-safe shadow-[0_-4px_10px_rgba(0,0,0,0.05)]">
        <div class="flex justify-around items-center h-16 px-1">
            {# Tab 1: Accueil #}
            <a href="{{ path('cohort_index') }}" class="tab-item {{ app.request.attributes.get('_route') == 'cohort_index' ? 'text-primary' : 'text-muted-foreground' }} flex-1 flex flex-col items-center justify-center gap-1 group">
                <div class="p-1.5 rounded-xl transition-all {{ app.request.attributes.get('_route') == 'cohort_index' ? 'bg-primary/10' : 'group-active:bg-muted' }}">
                    <svg class="h-6 w-6" fill="{{ app.request.attributes.get('_route') == 'cohort_index' ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                </div>
                <span class="text-[10px] font-bold">{{ 'Accueil' | trans }}</span>
            </a>
            
            {# Tab 2: Cours #}
            <a href="{{ path('course_index') }}" class="tab-item {{ app.request.attributes.get('_route') starts with 'course' ? 'text-primary' : 'text-muted-foreground' }} flex-1 flex flex-col items-center justify-center gap-1 group">
                <div class="p-1.5 rounded-xl transition-all {{ app.request.attributes.get('_route') starts with 'course' ? 'bg-primary/10' : 'group-active:bg-muted' }}">
                   <svg class="h-6 w-6" fill="{{ app.request.attributes.get('_route') starts with 'course' ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                </div>
                <span class="text-[10px] font-bold">{{ 'Cours' | trans }}</span>
            </a>
            
            {# Tab 3: Bloc-notes #}
            <a href="{{ path('note_index') }}" class="tab-item {{ app.request.attributes.get('_route') == 'note_index' ? 'text-primary' : 'text-muted-foreground' }} flex-1 flex flex-col items-center justify-center gap-1 group">
                <div class="p-1.5 rounded-xl transition-all {{ app.request.attributes.get('_route') == 'note_index' ? 'bg-primary/10' : 'group-active:bg-muted' }}">
                    <svg class="h-6 w-6" fill="{{ app.request.attributes.get('_route') == 'note_index' ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </div>
                <span class="text-[10px] font-bold">{{ 'Bloc-notes' | trans }}</span>
            </a>

            {# Tab 4: Evaluations #}
            <a href="{{ path('evaluation_index') }}" class="tab-item {{ app.request.attributes.get('_route') == 'evaluation_index' ? 'text-primary' : 'text-muted-foreground' }} flex-1 flex flex-col items-center justify-center gap-1 group">
                <div class="p-1.5 rounded-xl transition-all {{ app.request.attributes.get('_route') == 'evaluation_index' ? 'bg-primary/10' : 'group-active:bg-muted' }}">
                    <svg class="h-6 w-6" fill="{{ app.request.attributes.get('_route') == 'evaluation_index' ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                </div>
                <span class="text-[10px] font-bold">{{ 'Évaluations' | trans }}</span>
            </a>
            
            {# Tab 5: Plus (Opens drawer) #}
            <button @click="moreMenuOpen = true" class="tab-item flex-1 flex flex-col items-center justify-center gap-1 group text-muted-foreground hover:text-foreground">
                <div class="p-1.5 rounded-xl transition-all group-active:bg-muted">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </div>
                <span class="text-[10px] font-bold">{{ 'Plus' | trans }}</span>
            </button>
        </div>
    </nav>
    {% endif %}
</div>
{% endblock %}
