{% extends 'app.html.twig' %}

{% block title %}{{ 'Mon profil' | trans }}{% endblock %}

{% block content %}
<div class="space-y-8 max-w-5xl mx-auto">
    
    {# Title #}
    <h1 class="text-2xl font-bold">{{ 'Mon profil' | trans }}</h1>

    {# Profile Header #}
    <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
        {# Cover Line / Gradient #}
        <div class="h-24 sm:h-32 bg-gradient-to-r from-indigo-500 to-purple-600"></div>
        
        <div class="px-6 pb-6 relative">
            <div class="flex flex-col sm:flex-row items-center sm:items-end -mt-12 sm:-mt-16 mb-6 gap-4">
                {# Avatar #}
                <div class="relative group">
                    <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-full border-4 border-card overflow-hidden bg-muted shadow-md">
                        {% if app.user.image %}
                            <img src="{{ asset(app.user.image) }}" alt="{{ app.user.fullname }}" class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center bg-primary/10 text-primary text-2xl font-bold">
                                {{ app.user.firstname|first }}{{ app.user.lastname|first }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="flex-1 text-center sm:text-left mb-2 pt-2">
                    <h2 class="text-2xl font-bold">{{ app.user.fullname }}</h2>
                    <p class="text-muted-foreground">Promo {{ app.user.cohorts.first.title|default('2024') }}</p>
                </div>

                <div class="mb-4 pt-10 sm:pt-0">
                    <button class="inline-flex items-center justify-center rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium shadow-sm hover:bg-muted transition-colors gap-2">
                        <svg class="h-4 w-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                        {{ 'Modifier' | trans }}
                    </button>
                </div>
            </div>

            {# User Info Grid #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4 border-t border-border">
                <div>
                     <label class="flex items-center gap-2 text-xs text-muted-foreground uppercase font-semibold mb-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        {{ 'Nom complet' | trans }}
                     </label>
                     <p class="font-medium text-foreground">{{ app.user.fullname }}</p>
                </div>
                <div>
                     <label class="flex items-center gap-2 text-xs text-muted-foreground uppercase font-semibold mb-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        {{ 'Email' | trans }}
                     </label>
                     <p class="font-medium text-foreground">{{ app.user.email }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Stats Grid #}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-card border border-border rounded-xl p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-3xl font-bold text-indigo-600 mb-1">{{ stats.enrolled }}</div>
            <div class="text-xs text-muted-foreground font-medium uppercase">{{ 'Cours suivis' | trans }}</div>
        </div>
        <div class="bg-card border border-border rounded-xl p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-3xl font-bold text-indigo-600 mb-1">{{ stats.completed }}</div>
            <div class="text-xs text-muted-foreground font-medium uppercase">{{ 'Cours terminés' | trans }}</div>
        </div>
        <div class="bg-card border border-border rounded-xl p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-3xl font-bold text-indigo-600 mb-1">{{ stats.hours }}h</div>
            <div class="text-xs text-muted-foreground font-medium uppercase">{{ 'Heures d\'apprentissage' | trans }}</div>
        </div>
        <div class="bg-card border border-border rounded-xl p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-3xl font-bold text-indigo-600 mb-1">{{ stats.notes }}</div>
            <div class="text-xs text-muted-foreground font-medium uppercase">{{ 'Notes prises' | trans }}</div>
        </div>
        <div class="bg-card border border-border rounded-xl p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-3xl font-bold text-indigo-600 mb-1">{{ stats.xp }}</div>
            <div class="text-xs text-muted-foreground font-medium uppercase">XP</div>
        </div>
        <div class="bg-card border border-border rounded-xl p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-3xl font-bold text-indigo-600 mb-1">🔥 {{ stats.streak }}</div>
            <div class="text-xs text-muted-foreground font-medium uppercase">{{ 'Série' | trans }}</div>
        </div>
    </div>

    {# Achievements #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
            {{ 'Réalisations' | trans }}
        </h3>
        <div class="bg-card border border-border rounded-xl p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {% for badge in badges %}
                    <div class="flex flex-col items-center p-4 border border-border rounded-lg bg-background text-center">
                        <div class="w-12 h-12 mb-3 text-2xl flex items-center justify-center">
                            {# Assuming badge has icon or image #}
                            🏆
                        </div>
                        <h4 class="font-bold text-sm">{{ badge.name }}</h4>
                        <p class="text-xs text-muted-foreground">{{ badge.description }}</p>
                        <span class="text-[10px] text-muted-foreground mt-2">
                             📅 {{ 'Obtenu le' | trans }} {{ 'now'|date('d M Y') }} {# Mock date for now if not in pivot #}
                        </span>
                    </div>
                {% else %}
                    {# Mock Badges based on image #}
                     <div class="flex flex-col items-center p-6 border border-border rounded-lg bg-background text-center hover:bg-muted/30 transition-colors">
                        <div class="w-16 h-16 mb-4 flex items-center justify-center">
                             <span class="text-4xl">🎓</span>
                        </div>
                        <h4 class="font-bold text-sm mb-1">{{ 'Premier cours complété' | trans }}</h4>
                         <span class="text-xs text-muted-foreground">📅 15 Nov 2024</span>
                    </div>

                    <div class="flex flex-col items-center p-6 border border-border rounded-lg bg-background text-center hover:bg-muted/30 transition-colors">
                        <div class="w-16 h-16 mb-4 flex items-center justify-center">
                             <span class="text-4xl">⭐</span>
                        </div>
                        <h4 class="font-bold text-sm mb-1">{{ '5 cours terminés' | trans }}</h4>
                         <span class="text-xs text-muted-foreground">📅 20 Nov 2024</span>
                    </div>

                    <div class="flex flex-col items-center p-6 border border-border rounded-lg bg-background text-center hover:bg-muted/30 transition-colors">
                        <div class="w-16 h-16 mb-4 flex items-center justify-center">
                             <span class="text-4xl">🔥</span>
                        </div>
                        <h4 class="font-bold text-sm mb-1">{{ '20h d\'apprentissage' | trans }}</h4>
                         <span class="text-xs text-muted-foreground">📅 01 Dec 2024</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Skills #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            {{ 'Compétences' | trans }}
        </h3>
        <div class="bg-card border border-border rounded-xl p-6">
            <div class="flex flex-wrap gap-2 mb-4">
                {% for skill in app.user.skills %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300">
                        {{ skill.name }}
                    </span>
                {% else %}
                     <p class="text-sm text-muted-foreground">{{ 'Aucune compétence listée.' | trans }}</p>
                {% endfor %}
            </div>

            <details>
                <summary class="text-sm text-primary cursor-pointer hover:underline list-none font-medium">
                    + {{ 'Ajouter une compétence' | trans }}
                </summary>
                <form action="{{ path('profile_add_skill') }}" method="POST" class="mt-3 flex gap-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('add_skill') }}">
                    <input type="text" name="name" placeholder="Ex: Symfony, Gestion de projet..." required class="flex-1 rounded-md border border-input bg-background px-3 py-2 text-sm">
                    <button type="submit" class="bg-primary text-primary-foreground px-4 py-2 rounded-md text-sm">{{ 'Ajouter' | trans }}</button>
                </form>
            </details>
        </div>
    </div>

    {# Portfolio #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {{ 'Portfolio' | trans }}
        </h3>
        <div class="bg-card border border-border rounded-xl p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                 {% for project in app.user.portfolioProjects %}
                    <div class="border border-border rounded-lg overflow-hidden relative group">
                        {% if project.image %}
                             <img src="{{ asset(project.image) }}" alt="{{ project.title }}" class="w-full h-32 object-cover">
                        {% endif %}
                        <div class="p-4">
                            <h4 class="font-bold mb-1">{{ project.title }}</h4>
                            <p class="text-xs text-muted-foreground mb-3">{{ project.description }}</p>
                            {% if project.url %}
                                <a href="{{ project.url }}" target="_blank" class="text-sm text-primary hover:underline">{{ 'Voir le projet' | trans }}</a>
                            {% endif %}
                        </div>
                    </div>
                 {% else %}
                     <div class="col-span-2 text-center py-8 text-muted-foreground">
                         {{ 'Aucun projet dans le portfolio.' | trans }}
                     </div>
                 {% endfor %}
            </div>

            <details>
                <summary class="text-sm text-primary cursor-pointer hover:underline list-none font-medium">
                    + {{ 'Ajouter un projet' | trans }}
                </summary>
                <form action="{{ path('profile_add_portfolio') }}" method="POST" class="mt-4 space-y-3 bg-muted/30 p-4 rounded-lg">
                    <input type="hidden" name="_token" value="{{ csrf_token('add_portfolio') }}">
                    <div>
                        <label class="block text-xs font-medium mb-1">{{ 'Titre' | trans }}</label>
                        <input type="text" name="title" required class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1">{{ 'Description' | trans }}</label>
                        <textarea name="description" rows="2" class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm"></textarea>
                    </div>
                     <div>
                        <label class="block text-xs font-medium mb-1">{{ 'URL (Optionnel)' | trans }}</label>
                        <input type="url" name="url" class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm">
                    </div>
                    <button type="submit" class="bg-primary text-primary-foreground px-4 py-2 rounded-md text-sm w-full">{{ 'Ajouter au portfolio' | trans }}</button>
                </form>
            </details>
        </div>
    </div>

    {# Settings: Security #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            {{ 'Sécurité' | trans }}
        </h3>
        <p class="text-sm text-muted-foreground mb-4">{{ 'Gérez votre mot de passe et options de sécurité' | trans }}</p>
        
        <div class="bg-card border border-border rounded-xl p-6 space-y-6">
            <div>
                <label class="block text-sm font-medium mb-2">{{ 'Mot de passe actuel' | trans }}</label>
                <div class="relative">
                    <input type="password" value="********" readonly class="w-full rounded-md border border-input bg-muted/50 px-3 py-2 text-sm text-muted-foreground" disabled>
                     <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-muted-foreground">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                    </div>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                     <label class="block text-sm font-medium mb-2">{{ 'Nouveau mot de passe' | trans }}</label>
                     <input type="password" placeholder="........" class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                </div>
                <div>
                     <label class="block text-sm font-medium mb-2">{{ 'Confirmer le mot de passe' | trans }}</label>
                     <input type="password" placeholder="........" class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                </div>
            </div>

            <div class="flex items-center justify-between pt-2 border-t border-border">
                <div class="flex flex-col">
                    <span class="text-sm font-medium">{{ 'Authentification à deux facteurs' | trans }}</span>
                    <span class="text-xs text-muted-foreground">{{ 'Ajoutez une couche de sécurité supplémentaire' | trans }}</span>
                </div>
                <button class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-muted transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2" role="switch" aria-checked="false">
                    <span aria-hidden="true" class="translate-x-0 pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"></span>
                </button>
            </div>
        </div>
    </div>

    {# Notifications #}
    <div>
         <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            {{ 'Notifications' | trans }}
        </h3>
        <p class="text-sm text-muted-foreground mb-4">{{ 'Choisissez comment vous souhaitez être notifié' | trans }}</p>

        <div class="bg-card border border-border rounded-xl px-6 py-2 divide-y divide-border">
             {% for item in ['Notifications par email', 'Notifications push', 'Rappels de leçons', 'Résumé hebdomadaire'] %}
                <div class="flex items-center justify-between py-4">
                     <div class="flex flex-col">
                        <span class="text-sm font-medium">{{ item | trans }}</span>
                        <span class="text-xs text-muted-foreground">Description pour {{ item | lower }}</span>
                    </div>
                     <button class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent {{ loop.last ? 'bg-muted' : 'bg-indigo-600' }} transition-colors duration-200 ease-in-out focus:outline-none" role="switch">
                        <span aria-hidden="true" class="{{ loop.last ? 'translate-x-0' : 'translate-x-5' }} pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"></span>
                    </button>
                </div>
             {% endfor %}
        </div>
    </div>
    
     {# Preferences #}
    <div>
         <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {{ 'Préférences' | trans }}
        </h3>
        <p class="text-sm text-muted-foreground mb-4">{{ 'Personnalisez votre expérience d\'apprentissage' | trans }}</p>
        
        <div class="bg-card border border-border rounded-xl p-6">
             <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                 <div>
                      <label class="block text-sm font-medium mb-2">{{ 'Langue' | trans }}</label>
                      <select class="block w-full rounded-md border-input bg-background border px-3 py-2 text-sm focus:ring-2 focus:ring-primary">
                          <option value="fr" selected>Français</option>
                          <option value="en">English</option>
                      </select>
                 </div>
                 <div>
                      <label class="block text-sm font-medium mb-2">{{ 'Fuseau horaire' | trans }}</label>
                      <select class="block w-full rounded-md border-input bg-background border px-3 py-2 text-sm focus:ring-2 focus:ring-primary">
                          <option value="gpt+1" selected>Paris (GMT+1)</option>
                          <option value="utc">UTC</option>
                      </select>
                 </div>
             </div>
        </div>
    </div>

</div>
{% endblock %}
