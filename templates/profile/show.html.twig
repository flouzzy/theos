{% extends 'app.html.twig' %}

{% block title %}{{ 'Mon profil' | trans }}{% endblock %}

{% block content %}
<div class="space-y-8 max-w-5xl mx-auto">
    
    {# Title #}
    <h1 class="text-2xl font-bold">{{ 'Mon profil' | trans }}</h1>

    {# Profile Header #}
    <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
        {# Cover Line / Gradient #}
        <div class="h-24 sm:h-32 bg-gradient-to-r from-indigo-500 to-purple-600"></div>
        
        <div class="px-6 pb-6 relative">
            <div class="flex flex-col sm:flex-row items-center sm:items-end -mt-12 sm:-mt-16 mb-6 gap-4">
                {# Avatar #}
                <div class="relative group">
                    <twig:UserAvatar :user="app.user" class="w-24 h-24 sm:w-32 sm:h-32 shadow-md border-4 border-card" wrapperClass="" />
                </div>

                <div class="flex-1 text-center sm:text-left mb-2 pt-2">
                    <h2 class="text-2xl font-bold">{{ app.user.fullname }}</h2>
                    <p class="text-muted-foreground">Promo {{ app.user.cohorts.first.title|default('2024') }}</p>
                </div>

                <div class="mb-4 pt-10 sm:pt-0">
                    <a href="{{ path('profile_edit') }}" class="btn btn-outline gap-2">
                        <svg class="h-4 w-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                        {{ 'Modifier' | trans }}
                    </a>
                </div>
            </div>

            {# User Info Grid #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4 border-t border-border">
                <div>
                     <label class="flex items-center gap-2 text-xs text-muted-foreground uppercase font-semibold mb-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        {{ 'Nom complet' | trans }}
                     </label>
                     <p class="font-medium text-foreground">{{ app.user.fullname }}</p>
                </div>
                <div>
                     <label class="flex items-center gap-2 text-xs text-muted-foreground uppercase font-semibold mb-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        {{ 'Email' | trans }}
                     </label>
                     <p class="font-medium text-foreground">{{ app.user.email }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Stats Grid #}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <twig:StatCard value="{{ stats.enrolled }}" label="{{ 'Cours suivis' | trans }}" />
        <twig:StatCard value="{{ stats.completed }}" label="{{ 'Cours terminés' | trans }}" />
        <twig:StatCard value="{{ stats.hours }}h" label="{{ 'Heures d\'apprentissage' | trans }}" />
        <twig:StatCard value="{{ stats.notes }}" label="{{ 'Notes prises' | trans }}" />
        <twig:StatCard value="{{ stats.xp }}" label="XP" />
        <twig:StatCard value="{{ stats.streak }}" label="{{ 'Série' | trans }}" icon="🔥" />
    </div>

    {# Achievements #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
            {{ 'Réalisations' | trans }}
        </h3>
        <div class="bg-card border border-border rounded-xl p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {% for badge in badges %}
                    <div class="flex flex-col items-center p-4 border border-border rounded-lg bg-background text-center">
                        <div class="w-12 h-12 mb-3 text-2xl flex items-center justify-center">
                            {# Assuming badge has icon or image #}
                            🏆
                        </div>
                        <h4 class="font-bold text-sm">{{ badge.name }}</h4>
                        <p class="text-xs text-muted-foreground">{{ badge.description }}</p>
                        <span class="text-[10px] text-muted-foreground mt-2">
                             📅 {{ 'Obtenu le' | trans }} {{ 'now'|date('d M Y') }} {# Mock date for now if not in pivot #}
                        </span>
                    </div>
                {% else %}
                    {# Mock Badges based on image #}
                     <div class="flex flex-col items-center p-6 border border-border rounded-lg bg-background text-center hover:bg-muted/30 transition-colors">
                        <div class="w-16 h-16 mb-4 flex items-center justify-center">
                             <span class="text-4xl">🎓</span>
                        </div>
                        <h4 class="font-bold text-sm mb-1">{{ 'Premier cours complété' | trans }}</h4>
                         <span class="text-xs text-muted-foreground">📅 15 Nov 2024</span>
                    </div>

                    <div class="flex flex-col items-center p-6 border border-border rounded-lg bg-background text-center hover:bg-muted/30 transition-colors">
                        <div class="w-16 h-16 mb-4 flex items-center justify-center">
                             <span class="text-4xl">⭐</span>
                        </div>
                        <h4 class="font-bold text-sm mb-1">{{ '5 cours terminés' | trans }}</h4>
                         <span class="text-xs text-muted-foreground">📅 20 Nov 2024</span>
                    </div>

                    <div class="flex flex-col items-center p-6 border border-border rounded-lg bg-background text-center hover:bg-muted/30 transition-colors">
                        <div class="w-16 h-16 mb-4 flex items-center justify-center">
                             <span class="text-4xl">🔥</span>
                        </div>
                        <h4 class="font-bold text-sm mb-1">{{ '20h d\'apprentissage' | trans }}</h4>
                         <span class="text-xs text-muted-foreground">📅 01 Dec 2024</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Skills #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            {{ 'Compétences' | trans }}
        </h3>
        <div class="bg-card border border-border rounded-xl p-6">
            <div class="flex flex-wrap gap-2 mb-4">
                {% for skill in app.user.skills %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300">
                        {{ skill.name }}
                    </span>
                {% else %}
                     <p class="text-sm text-muted-foreground">{{ 'Aucune compétence listée.' | trans }}</p>
                {% endfor %}
            </div>

            <details>
                <summary class="text-sm text-primary cursor-pointer hover:underline list-none font-medium">
                    + {{ 'Ajouter une compétence' | trans }}
                </summary>
                <form action="{{ path('profile_add_skill') }}" method="POST" class="mt-3 flex gap-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('add_skill') }}">
                    <input type="text" name="name" placeholder="Ex: Symfony, Gestion de projet..." required class="flex-1 rounded-md border border-input bg-background px-3 py-2 text-sm">
                    <button type="submit" class="bg-primary text-primary-foreground px-4 py-2 rounded-md text-sm">{{ 'Ajouter' | trans }}</button>
                </form>
            </details>
        </div>
    </div>

    {# Portfolio #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {{ 'Portfolio' | trans }}
        </h3>
        <div class="bg-card border border-border rounded-xl p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                 {% for project in app.user.portfolioProjects %}
                    <div class="border border-border rounded-lg overflow-hidden relative group">
                        {% if project.image %}
                             <img src="{{ asset(project.image) }}" alt="{{ project.title }}" class="w-full h-32 object-cover">
                        {% endif %}
                        <div class="p-4">
                            <h4 class="font-bold mb-1">{{ project.title }}</h4>
                            <p class="text-xs text-muted-foreground mb-3">{{ project.description }}</p>
                            {% if project.url %}
                                <a href="{{ project.url }}" target="_blank" class="text-sm text-primary hover:underline">{{ 'Voir le projet' | trans }}</a>
                            {% endif %}
                        </div>
                    </div>
                 {% else %}
                     <div class="col-span-2 text-center py-8 text-muted-foreground">
                         {{ 'Aucun projet dans le portfolio.' | trans }}
                     </div>
                 {% endfor %}
            </div>

            <details>
                <summary class="text-sm text-primary cursor-pointer hover:underline list-none font-medium">
                    + {{ 'Ajouter un projet' | trans }}
                </summary>
                <form action="{{ path('profile_add_portfolio') }}" method="POST" class="mt-4 space-y-3 bg-muted/30 p-4 rounded-lg">
                    <input type="hidden" name="_token" value="{{ csrf_token('add_portfolio') }}">
                    <div>
                        <label class="block text-xs font-medium mb-1">{{ 'Titre' | trans }}</label>
                        <input type="text" name="title" required class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1">{{ 'Description' | trans }}</label>
                        <textarea name="description" rows="2" class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm"></textarea>
                    </div>
                     <div>
                        <label class="block text-xs font-medium mb-1">{{ 'URL (Optionnel)' | trans }}</label>
                        <input type="url" name="url" class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm">
                    </div>
                    <button type="submit" class="bg-primary text-primary-foreground px-4 py-2 rounded-md text-sm w-full">{{ 'Ajouter au portfolio' | trans }}</button>
                </form>
            </details>
        </div>
    </div>

    {# Fin des onglets affichage profil #}

</div>
{% endblock %}
