{% extends 'app.html.twig' %}

{% block title %}{{ 'My profile' | trans }}{% endblock %}

{% block content %}
<div class="space-y-8 max-w-5xl mx-auto">
    
    {# Title #}
    <h1 class="text-2xl font-bold">{{ 'My profile' | trans }}</h1>

    {# Profile Header #}
    <div class="bg-card border border-border rounded-xl overflow-hidden shadow-sm">
        {# Cover Line / Gradient #}
        <div class="h-24 sm:h-32 bg-gradient-to-r from-indigo-500 to-purple-600"></div>
        
        <div class="px-6 pb-6 relative">
            <div class="flex flex-col sm:flex-row items-center sm:items-end -mt-12 sm:-mt-16 mb-6 gap-4">
                {# Avatar #}
                <div class="relative group">
                    <twig:UserAvatar :user="user" class="w-24 h-24 sm:w-32 sm:h-32 shadow-md border-4 border-card" wrapperClass="" />
                </div>

                <div class="flex-1 text-center sm:text-left mb-2 pt-2">
                    <h2 class="text-2xl font-bold">{{ user.fullname }}</h2>
                    <p class="text-muted-foreground">Promo {{ user.cohorts.first.title|default('2024') }}</p>
                </div>

                {% if app.user and app.user.id == user.id %}
                <div class="mb-4 pt-10 sm:pt-0">
                    <a href="{{ path('profile_edit') }}" class="btn btn-outline gap-2">
                        <svg class="h-4 w-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                        {{ 'Edit' | trans }}
                    </a>
                </div>
                {% endif %}
            </div>

            {# User Info Grid #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4 border-t border-border">
                <div>
                     <label class="flex items-center gap-2 text-xs text-muted-foreground uppercase font-semibold mb-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        {{ 'Fullname' | trans }}
                     </label>
                     <p class="font-medium text-foreground">{{ user.fullname }}</p>
                </div>
                <div>
                     <label class="flex items-center gap-2 text-xs text-muted-foreground uppercase font-semibold mb-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        {{ 'Email' | trans }}
                     </label>
                     <p class="font-medium text-foreground">
                        {% if app.user and app.user.id == user.id %}
                            {{ user.email }}
                        {% else %}
                            ••••••••@••••.••
                        {% endif %}
                     </p>
                </div>
            </div>
        </div>
    </div>

    {# Stats Grid #}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <twig:StatCard value="{{ stats.enrolled }}" label="{{ 'Courses taken' | trans }}" />
        <twig:StatCard value="{{ stats.completed }}" label="{{ 'Courses finished' | trans }}" />
        <twig:StatCard value="{{ stats.hours }}h" label="{{ 'Hours of learning' | trans }}" />
        <twig:StatCard value="{{ stats.notes }}" label="{{ 'Notes prises' | trans }}" />
        <twig:StatCard value="{{ stats.xp }}" label="XP" />
        <twig:StatCard value="{{ stats.streak }}" label="{{ 'Streak' | trans }}">
            <twig:block name="icon">
                <twig:StreakBadge streak="{{ stats.streak }}" size="xs" />
            </twig:block>
        </twig:StatCard>
    </div>

    {# Achievements #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
            {{ 'Achievements' | trans }}
        </h3>
        <div class="bg-card border border-border rounded-xl p-6 min-h-[160px]">
            <twig:AchievementsComponent lazy="true">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 animate-pulse">
                    {% for i in 1..3 %}
                        <div class="flex flex-col items-center p-6 border border-border rounded-lg bg-muted/20">
                            <div class="w-16 h-16 mb-4 bg-muted rounded-full"></div>
                            <div class="h-4 w-24 bg-muted rounded mb-2"></div>
                            <div class="h-3 w-16 bg-muted rounded"></div>
                        </div>
                    {% endfor %}
                </div>
            </twig:AchievementsComponent>
        </div>
    </div>

    {# Skills #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            {{ 'Skills' | trans }}
        </h3>
        <div class="bg-card border border-border rounded-xl p-6">
            <twig:UserSkillsComponent :user="user" />
        </div>
    </div>

    {# Portfolio #}
    <div>
        <h3 class="font-bold text-lg mb-4 flex items-center gap-2 text-foreground">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {{ 'Portfolio' | trans }}
        </h3>
        <div class="bg-card border border-border rounded-xl p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                 {% for project in user.portfolioProjects %}
                    <div class="border border-border rounded-lg overflow-hidden relative group">
                        {% if project.image %}
                             <img src="{{ asset(project.image) }}" alt="{{ project.title }}" class="w-full h-32 object-cover">
                        {% endif %}
                        <div class="p-4">
                            <h4 class="font-bold mb-1">{{ project.title }}</h4>
                            <p class="text-xs text-muted-foreground mb-3">{{ project.description }}</p>
                            {% if project.url %}
                                <a href="{{ project.url }}" target="_blank" class="text-sm text-primary hover:underline">{{ 'View project' | trans }}</a>
                            {% endif %}
                        </div>
                    </div>
                 {% else %}
                     <div class="col-span-2 text-center py-8 text-muted-foreground">
                         {{ 'No project in the portfolio.' | trans }}
                     </div>
                 {% endfor %}
            </div>

             {% if app.user and app.user.id == user.id %}
            <details>
                <summary class="text-sm text-primary cursor-pointer hover:underline list-none font-medium">
                    + {{ 'Ajouter un projet' | trans }}
                </summary>
                <form action="{{ path('profile_add_portfolio') }}" method="POST" class="mt-4 space-y-3 bg-muted/30 p-4 rounded-lg">
                    <input type="hidden" name="_token" value="{{ csrf_token('add_portfolio') }}">
                    <div>
                        <label class="block text-xs font-medium mb-1">{{ 'Titre' | trans }}</label>
                        <input type="text" name="title" required class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1">{{ 'Description' | trans }}</label>
                        <textarea name="description" rows="2" class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm"></textarea>
                    </div>
                     <div>
                        <label class="block text-xs font-medium mb-1">{{ 'URL (Optionnel)' | trans }}</label>
                        <input type="url" name="url" class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm">
                    </div>
                    <button type="submit" class="bg-primary text-primary-foreground px-4 py-2 rounded-md text-sm w-full">{{ 'Ajouter au portfolio' | trans }}</button>
                </form>
            </details>
            {% endif %}
        </div>
    </div>

    {# Fin des onglets affichage profil #}

</div>
{% endblock %}
