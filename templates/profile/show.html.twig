{% extends 'ionic.html.twig' %}

{% block title %}
	{{'Profile' | trans}}
{% endblock %}


{% block pageTitle %}
	{{block('title')}}
{% endblock %}

{% block content %}
	<ion-card>
		<ion-card-header>
			<ion-card-title>
				<h2>
					{{'Hello' | trans}},
					{{ app.user.fullname }}
					👋
				</h2>
			</ion-card-title>
		</ion-card-header>

		<ion-card-content>
			<ion-item lines="none">
				<ion-thumbnail slot="start">
					<ion-img src="{{asset(app.user.image)}}" alt="{{'Profile image of'~ app.user.firstname}}"></ion-img>
				</ion-thumbnail>
				<ion-label>
					{{app.user.bio}}
				</ion-label>
			</ion-item>
		</ion-card-content>
	</ion-card>

	<ion-list>
		<ion-list-header>
			<h2>{{'Profile update' | trans}}</h2>
		</ion-list-header>

		{% include "profile/_form.html.twig" %}
	</ion-list>
	<ion-list>
		<ion-list-header>
			<h2>{{'Manage your account' | trans}}</h2>
		</ion-list-header>
		<ion-item>
			<ion-buttons>
				<ion-button href="{{path('forgot_password_request')}}" color="success" fill="outline">
					{{'Reset your password' | trans}}
				</ion-button>
				{% include "profile/_delete.html.twig" %}
			</ion-buttons>
		</ion-item>
	</ion-list>
{% endblock %}
