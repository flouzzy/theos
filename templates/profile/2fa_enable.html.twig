{% extends 'app.html.twig' %}

{% block title %}{{ 'Enable two-factor authentication' | trans }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto py-10 px-4">
    <div class="bg-card border border-border rounded-2xl shadow-sm p-8 text-center">
        <div class="inline-flex h-16 w-16 rounded-2xl bg-primary/10 text-primary items-center justify-center mb-6">
            <twig:ux:icon name="lucide:shield-check" class="w-10 h-10" />
        </div>
        
        <h1 class="text-3xl font-bold mb-4">{{ 'Secure your account' | trans }}</h1>
        <p class="text-muted-foreground mb-8">
            {{ 'Two-factor authentication adds an extra layer of security to your account by requiring a unique code generated by a mobile app.' | trans }}
        </p>

        <div class="bg-white p-4 inline-block rounded-xl border border-border mb-8">
            <img src="https://chart.googleapis.com/chart?chs=200x200&cht=qr&chl={{ qrCodeContent|url_encode }}&choe=UTF-8" alt="QR Code">
        </div>

        <div class="text-left space-y-4 mb-10 bg-muted/30 p-6 rounded-xl border border-border/50">
            <h3 class="font-bold flex items-center gap-2">
                <twig:ux:icon name="lucide:info" class="w-5 h-5 text-primary" />
                {{ 'How does it work?' | trans }}
            </h3>
            <ol class="list-decimal list-inside space-y-2 text-sm text-muted-foreground">
                <li>{{ 'Download an app like Google Authenticator or Microsoft Authenticator.' | trans }}</li>
                <li>{{ 'Scan the QR code above with the app.' | trans }}</li>
                <li>{{ 'Once the account is added, your app will generate a 6-digit code.' | trans }}</li>
                <li>{{ "That's it! Next time you log in, this code will be required." | trans }}</li>
            </ol>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="{{ path('profile_index') }}" class="btn btn-primary w-full sm:w-auto px-10 py-3">
                {{ "I've configured my app" | trans }}
            </a>
            <form action="{{ path('profile_2fa_disable') }}" method="post" onsubmit="return confirm('{{ 'Are you sure you want to cancel?' | trans }}')">
                <input type="hidden" name="_token" value="{{ csrf_token('disable_2fa') }}">
                <button type="submit" class="btn btn-outline text-destructive hover:bg-destructive/10 border-destructive/20 w-full sm:w-auto">
                    {{ 'Cancel activation' | trans }}
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
