{% extends 'app.html.twig' %}

{% block title %}
    {{ 'Calendrier' | trans }} - {{ cohort ? cohort.title : 'Mon planning' }}
{% endblock %}

{% block page_title %}
    {{ 'Calendrier de la promotion' | trans }}
{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto space-y-8">
    {% if cohort %}
        <div class="bg-card border border-border rounded-3xl overflow-hidden shadow-sm">
            <div class="p-6 md:p-8 bg-gradient-to-br from-primary/5 to-transparent border-b border-border">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 bg-primary/10 text-primary rounded-2xl flex items-center justify-center">
                        <twig:ux:icon name="lucide:calendar" class="w-6 h-6" />
                    </div>
                    <div>
                        <h2 class="text-2xl font-black tracking-tight">{{ cohort.title }}</h2>
                        <p class="text-muted-foreground">{{ 'Votre planning et événements à venir' | trans }}</p>
                    </div>
                </div>

                {% if calendar and calendar.description %}
                    <div class="prose prose-sm dark:prose-invert max-w-none text-muted-foreground">
                        {{ calendar.description|nl2br }}
                    </div>
                {% endif %}

                {% if calendar and calendar.url %}
                    <a href="{{ calendar.url }}" target="_blank" class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-primary text-primary-foreground font-bold rounded-xl hover:opacity-90 transition-all shadow-md shadow-primary/20">
                        <twig:ux:icon name="lucide:external-link" class="w-4 h-4" />
                        {{ 'Consulter le calendrier externe' | trans }}
                    </a>
                {% endif %}
            </div>

            {% if calendar and calendar.embed %}
                <div class="aspect-video w-full bg-muted">
                    <div class="w-full h-full">
                        {{ calendar.embed|raw }}
                    </div>
                </div>
            {% endif %}
        </div>

        {# Events List #}
        {% set calendar_events = calendar ? calendar.events : [] %}
        <div class="space-y-4">
            <h3 class="text-xl font-bold px-2 flex items-center gap-2">
                <twig:ux:icon name="lucide:list-todo" class="w-5 h-5 text-primary" />
                {{ 'Prochains événements' | trans }}
            </h3>

            {% if calendar_events is not empty %}
                <div class="grid gap-4">
                    {% for event in calendar_events | sort((a, b) => a.startAt <=> b.startAt) %}
                        <div class="group flex flex-col md:flex-row md:items-center gap-4 p-5 bg-card border border-border rounded-3xl hover:border-primary/20 transition-all duration-300">
                            <div class="flex-shrink-0 flex flex-col items-center justify-center w-16 h-16 bg-muted rounded-2xl text-center">
                                <span class="text-[10px] uppercase font-bold text-muted-foreground">{{ event.startAt|format_datetime('none', 'none', pattern='MMM') }}</span>
                                <span class="text-2xl font-black text-foreground leading-none">{{ event.startAt|date('d') }}</span>
                            </div>

                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[10px] font-bold uppercase">{{ event.type|trans }}</span>
                                    <span class="text-xs text-muted-foreground">{{ event.startAt|date('H:i') }}{% if event.endAt %} - {{ event.endAt|date('H:i') }}{% endif %}</span>
                                </div>
                                <h4 class="text-lg font-bold truncate group-hover:text-primary transition-colors">{{ event.title }}</h4>
                                {% if event.location %}
                                    <p class="text-sm text-muted-foreground flex items-center gap-1 mt-1">
                                        <twig:ux:icon name="lucide:map-pin" class="w-3 h-3" />
                                        {{ event.location }}
                                    </p>
                                {% endif %}
                            </div>

                            <div class="flex-shrink-0">
                                <button class="w-full md:w-auto px-4 py-2 bg-muted hover:bg-muted/80 rounded-xl text-sm font-bold transition-colors">
                                    {{ 'Détails' | trans }}
                                </button>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="p-8 text-center bg-card/50 border border-dashed border-border rounded-3xl text-muted-foreground">
                    {{ 'Aucun événement programmé pour le moment.' | trans }}
                </div>
            {% endif %}
        </div>

    {% else %}
        <div class="flex flex-col items-center justify-center p-12 text-center bg-card border border-dashed border-border rounded-3xl mt-12">
            <div class="w-20 h-20 bg-muted rounded-full flex items-center justify-center mb-6 text-muted-foreground">
                <twig:ux:icon name="lucide:users" class="w-10 h-10" />
            </div>
            <h3 class="text-2xl font-bold mb-2">{{ 'Pas de promotion active' | trans }}</h3>
            <p class="text-muted-foreground max-w-sm">{{ 'Vous devez être inscrit à une promotion pour accéder au calendrier.' | trans }}</p>
            <a href="{{ path('cohort_index') }}" class="mt-6 px-6 py-3 bg-primary text-primary-foreground font-bold rounded-2xl shadow-lg shadow-primary/20 hover:scale-105 transition-transform">
                {{ 'Voir les promotions' | trans }}
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
