{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen bg-background pb-16 md:pb-0"
     x-data="{ moreMenuOpen: false, desktopSidebarOpen: localStorage.getItem('desktopSidebarOpen') !== 'false' }"
     x-init="$watch('desktopSidebarOpen', value => localStorage.setItem('desktopSidebarOpen', value))">
    
    {# Desktop Sidebar #}
    <aside id="desktop-sidebar" data-turbo-permanent="true" class="hidden lg:fixed lg:inset-y-0 lg:left-0 lg:top-0 lg:bottom-0 lg:flex lg:flex-col bg-sidebar border-r border-border transition-all duration-300 z-40"
           :class="desktopSidebarOpen ? 'lg:w-64' : 'lg:w-20'">
        <div class="flex grow flex-col gap-y-5 overflow-y-auto py-6" :class="desktopSidebarOpen ? 'px-6' : 'px-3'">
            {# Logo #}
            <div class="flex h-16 shrink-0 items-center justify-between">
                <div class="flex items-center gap-3 overflow-hidden">
                    {% set activeCohort = active_cohort() %}
                    {% set logoUrl = (activeCohort and activeCohort.logoPath) ? asset(activeCohort.logoPath) : asset('images/logo.png') %}
                    <img src="{{ logoUrl }}" alt="Logo" class="h-16 w-auto shrink-0 transition-all duration-300" :class="!desktopSidebarOpen && 'scale-75 origin-left'" />
                </div>
                <button @click="desktopSidebarOpen = !desktopSidebarOpen" class="hidden lg:flex p-1.5 rounded-lg text-muted-foreground hover:bg-muted hover:text-foreground transition-colors">
                    <svg class="w-5 h-5 transition-transform duration-300" :class="!desktopSidebarOpen && 'rotate-180'" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                    </svg>
                </button>
            </div>

            {# Navigation #}
            {% include 'partials/_sidebar_navigation.html.twig' %}

            {# User Profile Footer #}
            <div class="mt-auto pb-4">
                {% if app.user %}
                   <a href="{{ path('profile_index') }}" class="flex items-center py-2 pt-4 hover:bg-muted/50 transition-colors rounded-xl mx-2 cursor-pointer group"
                    :class="desktopSidebarOpen ? 'gap-3 px-3 justify-start border-t border-border overflow-hidden' : 'gap-0 px-0 justify-center'">
                        <div class="h-10 w-10 shrink-0 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-semibold shadow-sm group-hover:scale-105 transition-transform">
                            {{ app.user.firstname|first }}{{ app.user.lastname|first }}
                        </div>

                        <div x-show="desktopSidebarOpen" x-transition.opacity class="flex-1 min-w-0">
                            <p class="text-sm font-semibold truncate">{{ app.user.firstname }} {{ app.user.lastname }}</p>
                            {% set activeCohort = active_cohort() %}
                            {% if activeCohort %}
                                <p class="text-xs text-muted-foreground truncate">{{ activeCohort.title }}</p>
                            {% endif %}
                        </div>
                    </a>
                    <a href="{{ path('offline') }}" class="mt-2 flex items-center gap-2 px-3 py-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
                        <twig:ux:icon name="lucide:download-cloud" class="h-4 w-4 shrink-0" />
                        <span :class="!desktopSidebarOpen && 'hidden'">{{ 'Mode Hors-ligne' | trans }}</span>
                    </a>
                   <a href="{{ path('_logout_main') }}" class="mt-2 flex items-center gap-2 px-3 py-2 text-sm rounded-xl transition-colors text-destructive hover:text-destructive">
                        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        <span :class="!desktopSidebarOpen && 'hidden'">{{ 'Déconnexion' | trans }}</span>
                    </a>
                {% endif %}
            </div>
        </div>
    </aside>

    {# Mobile Menu Overlay & Drawer #}
    <div x-show="moreMenuOpen" 
         class="fixed inset-0 z-50 lg:hidden"
         style="display: none;">
         
         {# Backdrop #}
         <div x-transition:enter="transition-opacity ease-linear duration-300"
              x-transition:enter-start="opacity-0"
              x-transition:enter-end="opacity-100"
              x-transition:leave="transition-opacity ease-linear duration-300"
              x-transition:leave-start="opacity-100"
              x-transition:leave-end="opacity-0"
              @click="moreMenuOpen = false"
              class="absolute inset-0 bg-black/60 backdrop-blur-sm">
         </div>

         {# Drawer #}
         <div x-transition:enter="transition ease-out duration-300 transform"
              x-transition:enter-start="translate-y-full"
              x-transition:enter-end="translate-y-0"
              x-transition:leave="transition ease-in duration-300 transform"
              x-transition:leave-start="translate-y-0"
              x-transition:leave-end="translate-y-full"
              class="absolute bottom-0 left-0 right-0 bg-background rounded-t-3xl shadow-2xl max-h-[85vh] overflow-y-auto w-full">
              
              <div class="p-6 space-y-6">
                   {# Handle #}
                   <div class="w-12 h-1.5 bg-muted-foreground/20 rounded-full mx-auto mb-2"></div>
                   
                   <div class="text-center mb-6">
                        <h2 class="text-xl font-bold">{{ 'Menu Principal' | trans }}</h2>
                   </div>

                   {% set currentRoute = app.request.attributes.get('_route') %}
                   <div class="flex flex-col gap-1">
                        {# Classement #}
                        {% set isActive = currentRoute == 'leaderboard_index' %}
                        <a href="{{ path('leaderboard_index') }}" @click="moreMenuOpen = false" class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold transition-colors {{ isActive ? 'text-primary bg-primary/10' : 'text-foreground hover:bg-muted' }}">
                            <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-muted text-muted-foreground group-hover:bg-primary/10 group-hover:text-primary' }}">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                                </svg>
                            </div>
                            <span class="flex-1">{{ 'Classement' | trans }}</span>
                        </a>

                        {# Calendrier #}
                        {% set isActive = currentRoute starts with 'calendar' %}
                        <a href="{{ path('calendar_index') }}" @click="moreMenuOpen = false" class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold transition-colors {{ isActive ? 'text-primary bg-primary/10' : 'text-foreground hover:bg-muted' }}">
                            <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-muted text-muted-foreground group-hover:bg-primary/10 group-hover:text-primary' }}">
                                <twig:ux:icon name="lucide:calendar" class="w-5 h-5" />
                            </div>
                            <span class="flex-1">{{ 'Calendrier' | trans }}</span>
                        </a>

                        {# Notifications #}
                        {% set isActive = currentRoute starts with 'notification' %}
                        <a href="{{ path('notification_index') }}" @click="moreMenuOpen = false" class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold transition-colors {{ isActive ? 'text-primary bg-primary/10' : 'text-foreground hover:bg-muted' }}">
                            <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-muted text-muted-foreground group-hover:bg-primary/10 group-hover:text-primary' }}">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                                </svg>
                            </div>
                            <span class="flex-1">{{ 'Notifications' | trans }}</span>
                            {% set unreadCount = unread_notifications_count() %}
                            {% if unreadCount > 0 %}
                                <span class="inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold leading-none text-white bg-red-500 rounded-full">{{ unreadCount }}</span>
                            {% endif %}
                        </a>

                        {# Mon Équipe (admin/manager) #}
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_MANAGER') %}
                        {% set isActive = currentRoute starts with 'team' %}
                        <a href="{{ path('team_dashboard') }}" @click="moreMenuOpen = false" class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold transition-colors {{ isActive ? 'text-primary bg-primary/10' : 'text-foreground hover:bg-muted' }}">
                            <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-muted text-muted-foreground group-hover:bg-primary/10 group-hover:text-primary' }}">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                            </div>
                            <span class="flex-1">{{ 'Mon Équipe' | trans }}</span>
                        </a>
                        {% endif %}

                        {# Profil #}
                        {% set isActive = currentRoute starts with 'profile' %}
                        <a href="{{ path('profile_index') }}" @click="moreMenuOpen = false" class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold transition-colors {{ isActive ? 'text-primary bg-primary/10' : 'text-foreground hover:bg-muted' }}">
                            <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-muted text-muted-foreground group-hover:bg-primary/10 group-hover:text-primary' }}">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </div>
                            <span class="flex-1">{{ 'Profil' | trans }}</span>
                        </a>

                        {# Admin (admin) #}
                        {% if is_granted('ROLE_ADMIN') %}
                        {% set isActive = currentRoute starts with 'admin' %}
                        <a href="{{ path('admin') }}" @click="moreMenuOpen = false" class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold transition-colors {{ isActive ? 'text-primary bg-primary/10' : 'text-foreground hover:bg-muted' }}">
                            <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-muted text-muted-foreground group-hover:bg-primary/10 group-hover:text-primary' }}">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </div>
                            <span class="flex-1">{{ 'Admin' | trans }}</span>
                        </a>
                        {% endif %}

                        <div class="my-2 border-t border-border"></div>

                        {# Mode Hors-ligne #}
                        {% set isActive = currentRoute == 'offline' %}
                        <a href="{{ path('offline') }}" @click="moreMenuOpen = false" class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold transition-colors {{ isActive ? 'text-primary bg-primary/10' : 'text-foreground hover:bg-muted' }}">
                            <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-lg transition-colors {{ isActive ? 'bg-primary text-white shadow-md shadow-primary/20' : 'bg-muted text-muted-foreground group-hover:bg-primary/10 group-hover:text-primary' }}">
                                <twig:ux:icon name="lucide:download-cloud" class="w-5 h-5" />
                            </div>
                            <span class="flex-1">{{ 'Mode Hors-ligne' | trans }}</span>
                        </a>

                        {# Déconnexion (red, like sidebar) #}
                        <a href="{{ path('_logout_main') }}" class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold text-destructive hover:bg-destructive/10 transition-colors">
                            <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-lg bg-destructive/10 text-destructive">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                </svg>
                            </div>
                            <span class="flex-1">{{ 'Déconnexion' | trans }}</span>
                        </a>
                   </div>
                   
                   <div class="mt-8 pt-4 border-t border-border">
                        <button @click="moreMenuOpen = false" class="w-full btn bg-muted text-foreground font-bold rounded-xl py-3">
                            {{ 'Fermer' | trans }}
                        </button>
                   </div>
              </div>
         </div>
    </div>

    {# Main Content Area with Dynamic Padding for Sidebar #}
    <div class="transition-all duration-300 flex flex-col min-h-screen"
         :class="desktopSidebarOpen ? 'lg:pl-64' : 'lg:pl-20'">
        
        {# Unified Sticky Toolbar (Desktop & Mobile) #}
        <header class="sticky top-0 z-30 flex h-16 items-center gap-x-4 border-b border-border bg-background/80 backdrop-blur-md px-4 lg:px-8 shadow-sm transition-all duration-300">
            
            {# Center/Left: Page Title #}
            <div class="flex-1 min-w-0 flex items-center gap-2">
                <h1 class="text-base lg:text-lg font-bold truncate">
                    {% block page_title %}{{ 'Le Rocher Académie' | trans }}{% endblock %}
                </h1>
            </div>

            {# Right: Streak + Notification Bell #}
            <div class="flex items-center gap-3">
                 {% block toolbar_right %}
                    {% if app.user %}
                    <div class="flex items-center gap-1 bg-orange-100 text-orange-600 px-2.5 py-1 rounded-full text-xs font-bold ring-1 ring-orange-200">
                        <span>🔥</span> {{ app.user.streak }}
                    </div>
                    <a href="{{ path('notification_index') }}" class="relative p-2 rounded-xl text-muted-foreground hover:text-foreground hover:bg-muted transition-colors">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                        </svg>
                        {% set unreadCount = unread_notifications_count() %}
                        {% if unreadCount > 0 %}
                            <span class="absolute -top-0.5 -right-0.5 inline-flex items-center justify-center w-5 h-5 text-[10px] font-bold text-white bg-red-500 rounded-full ring-2 ring-background">{{ unreadCount > 9 ? '9+' : unreadCount }}</span>
                        {% endif %}
                    </a>
                    {% endif %}
                 {% endblock %}
            </div>
        </header>

        {# Page Content #}
        <main class="py-6 px-4 lg:px-8 flex-1">
            <div class="max-w-7xl mx-auto">
                {% include "partials/_flash.html.twig" %}
                {% block content %}{% endblock %}
            </div>
        </main>
    </div>

    {# Mobile Bottom Navigation (Fixed) #}
    {% include 'partials/_mobile_bottom_nav.html.twig' %}
</div>
{% endblock %}
