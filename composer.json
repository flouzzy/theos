{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^2.13 || ^3.0",
        "doctrine/doctrine-migrations-bundle": "^3.3 || ^4.0",
        "doctrine/orm": "^3.0",
        "endroid/qr-code-bundle": "*",
        "getbrevo/brevo-php": "^1.0",
        "imagine/imagine": "^1.3",
        "knplabs/knp-time-bundle": "^2.5",
        "phpdocumentor/reflection-docblock": "^5.3",
        "phpstan/phpdoc-parser": "^1.25",
        "scheb/2fa-bundle": "*",
        "scheb/2fa-totp": "*",
        "symfony/asset": "8.0.*",
        "symfony/asset-mapper": "8.0.*",
        "symfony/brevo-mailer": "8.0.*",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/event-dispatcher": "8.0.*",
        "symfony/expression-language": "8.0.*",
        "symfony/flex": "^2",
        "symfony/form": "8.0.*",
        "symfony/framework-bundle": "8.0.*",
        "symfony/html-sanitizer": "8.0.*",
        "symfony/http-client": "8.0.*",
        "symfony/intl": "8.0.*",
        "symfony/mailer": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/monolog-bundle": "^3.0 || ^4.0",
        "symfony/notifier": "8.0.*",
        "symfony/process": "8.0.*",
        "symfony/property-access": "8.0.*",
        "symfony/property-info": "8.0.*",
        "symfony/rate-limiter": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/security-bundle": "8.0.*",
        "symfony/serializer": "8.0.*",
        "symfony/stimulus-bundle": "^2.13 || ^3.0",
        "symfony/string": "8.0.*",
        "symfony/translation": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/ux-icons": "^2.32",
        "symfony/ux-live-component": "^2.32",
        "symfony/ux-turbo": "^2.13 || ^3.0",
        "symfony/validator": "8.0.*",
        "symfony/web-link": "8.0.*",
        "symfony/yaml": "8.0.*",
        "symfonycasts/reset-password-bundle": "^1.20 || ^2.0",
        "symfonycasts/tailwind-bundle": "^0.12.0",
        "symfonycasts/verify-email-bundle": "^1.16 || ^2.0",
        "tales-from-a-dev/twig-tailwind-extra": "^1.0.0",
        "twig/cssinliner-extra": "^3.8 || ^4.0",
        "twig/extra-bundle": "^3.8 || ^4.0",
        "twig/html-extra": "*",
        "twig/inky-extra": "^3.8 || ^4.0",
        "twig/string-extra": "^3.8 || ^4.0",
        "twig/twig": "^3.10"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "endroid/installer": true
        },
        "sort-packages": true,
        "platform": {
            "ext-xsl": "1.0.0",
            "ext-xml": "1.0.0"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Sysil\\SysilBundle\\": "sysil/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/",
            "Sysil\\SysilBundle\\Tests\\": "sysil/tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*",
            "docker": true
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^3.5 || ^4.0",
        "phpstan/phpstan": "*",
        "phpunit/phpunit": "^9.5 || ^10.0 || ^11.0",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/debug-bundle": "8.0.*",
        "symfony/maker-bundle": "^1.0 || ^2.0",
        "symfony/phpunit-bridge": "^7.0 || ^8.0",
        "symfony/stopwatch": "8.0.*",
        "symfony/ux-toolkit": "^2.32",
        "symfony/web-profiler-bundle": "8.0.*"
    }
}
